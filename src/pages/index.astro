  <!-- ─── SCRIPTS ─── -->
  <script>
    // ── Animation setup (skew + float, run in standalone rAF) ──
    let lastScrollY = window.scrollY;
    let scrollVelocity = 0;
    const hasFineCursor = window.matchMedia('(pointer: fine)').matches;
    const grainOverlay = document.querySelector('.grain-overlay') as HTMLElement | null;
    const grainBase = document.documentElement.dataset.theme === 'dark' ? 0.1 : 0.06;
    const skewElements = document.querySelectorAll('[data-skew]');

    // Skew visibility — only transform elements in viewport
    const skewVisible = new Set<Element>();
    if (skewElements.length > 0) {
      const skewVis = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) skewVisible.add(entry.target);
          else skewVisible.delete(entry.target);
        });
      }, { threshold: 0, rootMargin: '50px 0px 50px 0px' });
      skewElements.forEach((el) => skewVis.observe(el));
    }

    // Float elements: parsed once, animated in standalone rAF via composed style.transform
    interface FloatItem {
      el: HTMLElement;
      speed: number;
      amp: number;
      phase: number;
      visible: boolean;
      hasSkew: boolean;
      hasTilt: boolean;
      currentY: number;
      // Tilt state (merged into main loop to avoid competing transforms)
      tiltHovering: boolean;
      tiltTargetX: number;
      tiltTargetY: number;
      tiltCurrentX: number;
      tiltCurrentY: number;
      // Zero-G: horizontal drift + subtle rotation
      xPhase: number;
      rotPhase: number;
      xAmp: number;
      rotAmp: number;
      xSpeed: number;
      rotSpeed: number;
      // Reveal composition — external systems set these, float loop composes them
      revealOpacity: number;
      revealX: number;
      revealY: number;
    }
    const floatItems: FloatItem[] = [];
    document.querySelectorAll('[data-float]').forEach((el) => {
      const htmlEl = el as HTMLElement;
      const seed = parseInt(htmlEl.dataset.float || '1');
      floatItems.push({
        el: htmlEl,
        speed: 0.0005 + (seed % 5) * 0.00008,
        amp: 6 + (seed % 4) * 2,
        phase: seed * 1.7,
        visible: false,
        hasSkew: htmlEl.hasAttribute('data-skew'),
        hasTilt: htmlEl.hasAttribute('data-tilt'),
        currentY: 0,
        tiltHovering: false,
        tiltTargetX: 0,
        tiltTargetY: 0,
        tiltCurrentX: 0,
        tiltCurrentY: 0,
        // Zero-G: each element drifts on its own orbit
        xPhase: seed * 2.3 + 0.5,
        rotPhase: seed * 3.1 + 1.2,
        xAmp: 3 + (seed % 3) * 1.5,          // 3-7.5px horizontal drift
        rotAmp: 0.3 + (seed % 4) * 0.15,      // 0.3-0.75° rotation
        xSpeed: 0.0003 + (seed % 6) * 0.00005, // slightly different from Y
        rotSpeed: 0.0002 + (seed % 7) * 0.00003,
        // Reveal composition defaults (fully visible, no offset)
        revealOpacity: 1,
        revealX: 0,
        revealY: 0,
      });
    });

    // IntersectionObserver for float visibility
    if (floatItems.length > 0) {
      const floatVis = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const item = floatItems.find(f => f.el === entry.target);
          if (item) item.visible = entry.isIntersecting;
        });
      }, { threshold: 0.05 });
      floatItems.forEach(f => floatVis.observe(f.el));
    }

    const animStart = performance.now();

    // ── Standalone animation loop (no Lenis) ──
    function raf(time: number) {
      const t = time - animStart;
      const viewH = window.innerHeight;

      // ── Skew velocity ──
      const currentScrollY = window.scrollY;
      const delta = currentScrollY - lastScrollY;
      lastScrollY = currentScrollY;
      scrollVelocity += (delta - scrollVelocity) * 0.15;
      if (Math.abs(scrollVelocity) < 0.01) scrollVelocity = 0;
      const skewVal = Math.max(-3, Math.min(3, scrollVelocity * 0.12));

      // ── Apply skew to skew-only elements (skip when velocity is zero) ──
      if (skewVal !== 0) {
        for (let i = 0; i < skewElements.length; i++) {
          const el = skewElements[i] as HTMLElement;
          if (el.hasAttribute('data-float')) continue;
          if (!skewVisible.has(el)) continue;
          el.style.transform = `skewY(${skewVal}deg)`;
        }
      }

      // ── Grain reactivity — opacity pulses with scroll velocity ──
      if (grainOverlay) {
        const absVel = Math.abs(scrollVelocity);
        const grainBoost = Math.min(0.06, absVel * 0.004);
        grainOverlay.style.opacity = String(grainBase + grainBoost);
      }

      // ── Float + zero-G drift + compose with skew + tilt + reveal (single writer) ──
      for (let i = 0; i < floatItems.length; i++) {
        const f = floatItems[i];
        if (!f.visible) continue;
        // Vertical float (existing)
        const y = Math.sin(t * f.speed + f.phase) * f.amp
                + Math.sin(t * f.speed * 0.7 + f.phase + 1.5) * (f.amp * 0.35);
        f.currentY = y;
        // Zero-G: horizontal drift + rotation (different frequencies = organic orbits)
        const x = Math.sin(t * f.xSpeed + f.xPhase) * f.xAmp
                + Math.sin(t * f.xSpeed * 1.3 + f.xPhase + 2.0) * (f.xAmp * 0.25);
        const rot = Math.sin(t * f.rotSpeed + f.rotPhase) * f.rotAmp
                  + Math.sin(t * f.rotSpeed * 0.6 + f.rotPhase + 1.0) * (f.rotAmp * 0.4);

        // Compose reveal offsets (set by contact reveal or other external systems)
        const tx = x + f.revealX;
        const ty = y + f.revealY;

        // Apply reveal opacity (1 = fully visible default, <1 during reveal animation)
        if (f.revealOpacity < 1) {
          f.el.style.opacity = `${f.revealOpacity}`;
        }

        // Tilt interpolation (runs in this loop, no separate rAF)
        if (f.hasTilt) {
          f.tiltCurrentX += (f.tiltTargetX - f.tiltCurrentX) * 0.08;
          f.tiltCurrentY += (f.tiltTargetY - f.tiltCurrentY) * 0.08;
          if (!f.tiltHovering && Math.abs(f.tiltCurrentX) < 0.01 && Math.abs(f.tiltCurrentY) < 0.01) {
            f.tiltCurrentX = 0;
            f.tiltCurrentY = 0;
          }
          const hasTiltValues = f.tiltCurrentX !== 0 || f.tiltCurrentY !== 0;
          if (hasTiltValues) {
            f.el.style.transform = `perspective(1000px) rotateX(${f.tiltCurrentX}deg) rotateY(${f.tiltCurrentY}deg) translate(${tx}px, ${ty}px) rotate(${rot}deg)`;
          } else if (f.hasSkew) {
            f.el.style.transform = `translate(${tx}px, ${ty}px) rotate(${rot}deg) skewY(${skewVal}deg)`;
          } else {
            f.el.style.transform = `translate(${tx}px, ${ty}px) rotate(${rot}deg)`;
          }
        } else if (f.hasSkew) {
          f.el.style.transform = `translate(${tx}px, ${ty}px) rotate(${rot}deg) skewY(${skewVal}deg)`;
        } else {
          f.el.style.transform = `translate(${tx}px, ${ty}px) rotate(${rot}deg)`;
        }
      }

      // ── Card layer parallax (index number + color block at different rates) ──
      for (let i = 0; i < cardLayers.length; i++) {
        const cl = cardLayers[i];
        if (!cl.visible) continue;
        const rect = cl.card.getBoundingClientRect();
        const progress = 1 - (rect.top + rect.height / 2) / (viewH + rect.height);
        const offset = (progress - 0.5) * 2; // -1 to 1

        // Smooth hover interpolation
        const targetHX = cl.hovering ? cl.hoverX : 0;
        const targetHY = cl.hovering ? cl.hoverY : 0;
        cl.currentHoverX += (targetHX - cl.currentHoverX) * 0.06;
        cl.currentHoverY += (targetHY - cl.currentHoverY) * 0.06;

        // On mobile, amplify scroll multipliers to compensate for no hover
        const isMobile = !hasFineCursor;

        // Index: floats higher, moves opposite on hover + zero-G orbit
        const idxScrollY = offset * (isMobile ? -50 : -35);
        const idxScrollX = isMobile ? offset * 8 : 0;
        const idxHoverX = cl.currentHoverX * -25;
        const idxHoverY = cl.currentHoverY * -20;
        const idxDriftX = Math.sin(t * 0.00013 + i * 3.7) * 5;
        const idxDriftY = Math.sin(t * 0.00018 + i * 2.1) * 4;
        const idxRot = Math.sin(t * 0.00009 + i * 5.4) * 0.6;
        cl.indexEl.style.transform = `translate(${idxScrollX + idxHoverX + idxDriftX}px, ${idxScrollY + idxHoverY + idxDriftY}px) rotate(${idxRot}deg)`;

        // Color block: drifts subtly, moves with cursor + zero-G orbit
        const blkScrollX = offset * (isMobile ? -10 : -6);
        const blkScrollY = offset * (isMobile ? 25 : 18);
        const blkHoverX = cl.currentHoverX * 15;
        const blkHoverY = cl.currentHoverY * 12;
        const blkDriftX = Math.sin(t * 0.00016 + i * 4.3 + 1.0) * 4;
        const blkDriftY = Math.sin(t * 0.00021 + i * 1.6 + 2.0) * 3;
        const blkRot = Math.sin(t * 0.00011 + i * 6.8 + 0.5) * 0.35;
        cl.blockEl.style.transform = `translate(${blkScrollX + blkHoverX + blkDriftX}px, ${blkScrollY + blkHoverY + blkDriftY}px) rotate(${blkRot}deg)`;

        // Stroke index: deepest plane — moves opposite, slower orbit, larger amplitude
        if (cl.strokeEl) {
          const stkScrollY = offset * (isMobile ? -65 : -48);
          const stkScrollX = isMobile ? offset * 12 : 0;
          const stkHoverX = cl.currentHoverX * -35;
          const stkHoverY = cl.currentHoverY * -28;
          const stkDriftX = Math.sin(t * 0.0001 + i * 2.9) * 7;
          const stkDriftY = Math.sin(t * 0.00014 + i * 1.5) * 5;
          const stkRot = Math.sin(t * 0.00007 + i * 4.8) * 0.8;
          cl.strokeEl.style.transform = `translate(${stkScrollX + stkHoverX + stkDriftX}px, ${stkScrollY + stkHoverY + stkDriftY}px) rotate(${stkRot}deg)`;
        }

        // Accent line: mid-plane, subtle horizontal drift
        if (cl.lineEl) {
          const lnScrollX = offset * (isMobile ? 6 : 4);
          const lnScrollY = offset * (isMobile ? 12 : 8);
          const lnDriftX = Math.sin(t * 0.00019 + i * 5.2 + 1.5) * 3;
          const lnHoverX = cl.currentHoverX * 8;
          cl.lineEl.style.transform = `translate(${lnScrollX + lnDriftX + lnHoverX}px, ${lnScrollY}px)`;
        }

        // Project label: deep plane, moves opposite like index
        if (cl.labelEl) {
          const lblScrollY = offset * (isMobile ? -28 : -20);
          const lblHoverX = cl.currentHoverX * -12;
          const lblHoverY = cl.currentHoverY * -10;
          const lblDriftX = Math.sin(t * 0.00015 + i * 3.1 + 2.5) * 4;
          const lblDriftY = Math.sin(t * 0.0002 + i * 2.4 + 1.8) * 3;
          cl.labelEl.style.transform = `translate(${lblHoverX + lblDriftX}px, ${lblScrollY + lblHoverY + lblDriftY}px)`;
        }
      }

      // ── Section bg text parallax + zero-G drift (visibility-gated) ──
      for (let i = 0; i < bgParallaxEls.length; i++) {
        const bp = bgParallaxEls[i];
        const parent = bp.parentElement!;
        const rect = parent.getBoundingClientRect();
        // Skip off-screen sections
        if (rect.bottom < -50 || rect.top > viewH + 50) continue;
        const progress = 1 - (rect.top + rect.height / 2) / (viewH + rect.height);
        const offset = (progress - 0.5) * 2;
        const bgDriftX = Math.sin(t * 0.00015 + i * 2.5) * 8;
        const bgDriftY = Math.sin(t * 0.0002 + i * 1.8) * 5;
        const bgRot = Math.sin(t * 0.0001 + i * 3.2) * 0.4;
        bp.style.transform = `translate(${bgDriftX}px, ${offset * -40 + bgDriftY}px) rotate(${bgRot}deg)`;
      }

      // ── Section depth layer parallax + zero-G drift ──
      for (let i = 0; i < depthLayers.length; i++) {
        const dl = depthLayers[i];
        if (!dl.visible) continue;
        const rect = dl.container.getBoundingClientRect();
        const progress = 1 - (rect.top + rect.height / 2) / (viewH + rect.height);
        const offset = (progress - 0.5) * 2; // -1 to 1
        const m = hasFineCursor ? 1 : 1.4; // amplify on mobile

        // Deep layer: moves opposite + ambient zero-G orbit
        if (dl.deepEl) {
          const driftX = Math.sin(t * 0.00018 + i * 4.1) * 6;
          const driftY = Math.sin(t * 0.00025 + i * 2.7) * 4;
          const driftRot = Math.sin(t * 0.00012 + i * 5.3) * 0.5;
          dl.deepEl.style.transform = `translate(${driftX}px, ${offset * -30 * m + driftY}px) rotate(${driftRot}deg)`;
        }
        // Mid layer: drifts subtly + ambient zero-G orbit (different phase)
        if (dl.midEl) {
          const driftX = Math.sin(t * 0.00022 + i * 3.4 + 1.0) * 5;
          const driftY = Math.sin(t * 0.00016 + i * 1.9 + 2.0) * 3;
          const driftRot = Math.sin(t * 0.00014 + i * 6.1 + 0.5) * 0.35;
          dl.midEl.style.transform = `translate(${offset * -5 * m + driftX}px, ${offset * 15 * m + driftY}px) rotate(${driftRot}deg)`;
        }
      }

      // ── Hero layer parallax + zero-G drift (skip when hero is off-screen) ──
      if (currentScrollY < viewH * 1.5) {
        const heroProgress = Math.min(1, currentScrollY / viewH);
        // Deep layers — slow scroll parallax + ambient zero-G orbit
        if (heroLayerOrb) {
          const dx = Math.sin(t * 0.00008 + 1.0) * 12;
          const dy = Math.sin(t * 0.00012 + 2.5) * 8;
          heroLayerOrb.style.transform = `translateX(calc(10% + ${dx}px)) translateY(${heroProgress * 60 + dy}px)`;
        }
        if (heroLayerWatermark) {
          const dx = Math.sin(t * 0.00010 + 3.0) * 6;
          const dy = Math.sin(t * 0.00014 + 0.7) * 4;
          const dr = Math.sin(t * 0.00007 + 5.0) * 0.3;
          heroLayerWatermark.style.transform = `translate(${dx}px, ${heroProgress * -30 + dy}px) rotate(${dr}deg)`;
        }
        if (heroLayerGrid) {
          heroLayerGrid.style.transform = `translateY(${heroProgress * -15}px)`;
        }
        if (heroLayerYear) {
          const dx = Math.sin(t * 0.00013 + 4.2) * 8;
          const dy = Math.sin(t * 0.00018 + 1.3) * 5;
          const dr = Math.sin(t * 0.00009 + 6.7) * 0.6;
          heroLayerYear.style.transform = `translate(${dx}px, ${heroProgress * -45 + dy}px) rotate(${dr}deg)`;
        }
        // Mid layers — subtle drift + zero-G orbit
        if (heroLayerBar) {
          const dx = Math.sin(t * 0.00015 + 2.1) * 4;
          heroLayerBar.style.transform = `translate(${dx}px, ${heroProgress * 25}px)`;
        }
        if (heroLayerRing) {
          const dx = Math.sin(t * 0.00011 + 5.5) * 10;
          const dy = Math.sin(t * 0.00016 + 3.8) * 7;
          const dr = Math.sin(t * 0.00008 + 1.6) * 0.8;
          heroLayerRing.style.transform = `translate(${heroProgress * -10 + dx}px, ${heroProgress * 35 + dy}px) rotate(${dr}deg)`;
        }
        // Title depth layers — zero-G orbit behind the name
        if (heroLayerIndex) {
          const dx = Math.sin(t * 0.00012 + 7.0) * 5;
          const dy = Math.sin(t * 0.00017 + 4.4) * 4;
          const dr = Math.sin(t * 0.00010 + 2.9) * 0.4;
          heroLayerIndex.style.transform = `translate(${dx}px, ${heroProgress * -40 + dy}px) rotate(${dr}deg)`;
        }
        if (heroLayerTitleBlock) {
          const dx = Math.sin(t * 0.00014 + 8.2) * 4;
          const dy = Math.sin(t * 0.00019 + 5.6) * 3;
          const dr = Math.sin(t * 0.00011 + 3.3) * 0.25;
          heroLayerTitleBlock.style.transform = `translate(${heroProgress * 15 + dx}px, ${heroProgress * 20 + dy}px) rotate(${dr}deg)`;
        }
        if (heroLayerTitleLine) {
          heroLayerTitleLine.style.transform = `scaleX(1) translateY(${heroProgress * 8}px)`;
          heroLayerTitleLine.style.transformOrigin = 'left';
        }
        if (heroLayerDataLine) {
          const dx = Math.sin(t * 0.00009 + 9.1) * 3;
          heroLayerDataLine.style.transform = `translateY(${heroProgress * 12 + dx}px)`;
        }
        // Foreground details
        heroLayerCorners.forEach((c) => {
          c.style.transform = `translateY(${heroProgress * 20}px)`;
        });
        heroLayerCoords.forEach((c) => {
          c.style.transform = `translateY(${heroProgress * -12}px)`;
        });
        // Contact section bg layers
        if (contactBgNum) {
          const contactRect = contactSection?.getBoundingClientRect();
          if (contactRect && contactRect.top < viewH) {
            const cp = 1 - contactRect.top / viewH;
            contactBgNum.style.transform = `translateY(${cp * -40}px)`;
            if (contactBgRing) contactBgRing.style.transform = `translate(${cp * 15}px, ${cp * -25}px)`;
          }
        }
        // Section-level depth layers (work, process, about — off-screen culled)
        for (let si = 0; si < sectionDepthEls.length; si++) {
          const sd = sectionDepthEls[si];
          if (!sd.section) continue;
          const sr = sd.section.getBoundingClientRect();
          if (sr.bottom < -100 || sr.top > viewH + 100) continue;
          const sp = 1 - (sr.top + sr.height / 2) / (viewH + sr.height);
          const so = (sp - 0.5) * 2;
          for (let ei = 0; ei < sd.els.length; ei++) {
            const e = sd.els[ei];
            e.el.style.transform = `translate(${so * e.tx}px, ${so * e.ty}px)`;
          }
        }
      }

      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);

    // ── Section bg text parallax setup ──
    const bgParallaxEls = Array.from(document.querySelectorAll('[data-bg-parallax]')) as HTMLElement[];

    // ── Hero layer parallax setup ──
    const heroLayerOrb = document.querySelector('[data-hero-layer="orb"]') as HTMLElement | null;
    const heroLayerWatermark = document.querySelector('[data-hero-layer="watermark"]') as HTMLElement | null;
    const heroLayerGrid = document.querySelector('[data-hero-layer="grid"]') as HTMLElement | null;
    const heroLayerYear = document.querySelector('[data-hero-layer="year"]') as HTMLElement | null;
    const heroLayerBar = document.querySelector('[data-hero-layer="bar"]') as HTMLElement | null;
    const heroLayerRing = document.querySelector('[data-hero-layer="ring"]') as HTMLElement | null;
    const heroLayerCorners = Array.from(document.querySelectorAll('[data-hero-layer="corner"]')) as HTMLElement[];
    const heroLayerCoords = Array.from(document.querySelectorAll('[data-hero-layer="coord"]')) as HTMLElement[];
    const heroLayerIndex = document.querySelector('[data-hero-layer="index"]') as HTMLElement | null;
    const heroLayerTitleBlock = document.querySelector('[data-hero-layer="title-block"]') as HTMLElement | null;
    const heroLayerTitleLine = document.querySelector('[data-hero-layer="title-line"]') as HTMLElement | null;
    const heroLayerDataLine = document.querySelector('[data-hero-layer="data-line"]') as HTMLElement | null;
    const contactBgNum = document.querySelector('[data-hero-layer="contact-num"]') as HTMLElement | null;
    const contactBgRing = document.querySelector('[data-hero-layer="contact-ring"]') as HTMLElement | null;
    const contactSection = document.getElementById('contact');
    // Section-level depth layer config: { section, els: [{ el, tx, ty }] }
    interface SectionDepthConfig {
      section: HTMLElement | null;
      els: { el: HTMLElement; tx: number; ty: number }[];
    }
    const sectionDepthEls: SectionDepthConfig[] = [];

    function addSectionDepth(sectionId: string, entries: { selector: string; tx: number; ty: number }[]) {
      const section = document.getElementById(sectionId);
      if (!section) return;
      const els: { el: HTMLElement; tx: number; ty: number }[] = [];
      entries.forEach(e => {
        const el = section.querySelector(e.selector) as HTMLElement | null;
        if (el) els.push({ el, tx: e.tx, ty: e.ty });
      });
      if (els.length) sectionDepthEls.push({ section, els });
    }

    addSectionDepth('work', [
      { selector: '.work-depth-number', tx: 0, ty: -50 },
      { selector: '.work-depth-line', tx: 0, ty: 30 },
      { selector: '.work-depth-ring', tx: -8, ty: 25 },
      { selector: '.work-depth-crosshair', tx: 5, ty: -35 },
      { selector: '.work-depth-rule', tx: -3, ty: 18 },
      { selector: '.work-depth-coord', tx: 6, ty: -40 },
      { selector: '.work-depth-diagonal', tx: -4, ty: -55 },
      { selector: '.work-depth-dot--1', tx: 3, ty: 20 },
      { selector: '.work-depth-dot--2', tx: -5, ty: -30 },
      { selector: '.work-depth-dot--3', tx: 4, ty: 15 },
    ]);
    addSectionDepth('process', [
      { selector: '.process-depth-number', tx: 0, ty: -45 },
