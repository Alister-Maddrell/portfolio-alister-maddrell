---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const projects = [
  {
    name: 'Hartley & Co Plumbing',
    description: 'Copper-and-navy plumbing identity with layered depth — wave dividers, floating stat badges, blueprint textures, before/after sliders, and a 24/7 emergency flow that converts urgent searches into booked jobs.',
    tags: ['Click-to-Call', 'Emergency Alerts', 'Before/After Sliders', 'Copper Design System', 'FAQ Schema', 'Quote Form'],
    thumbnail: '/thumbnails/hartley.png',
    link: 'https://demo-hartley-plumbing.vercel.app',
    color: '#C87533',
    floats: [
      { text: 'Click-to-Call Bar', style: 'badge', pos: 'top: 10%; right: 5%;', depth: 0.04 },
      { text: 'Emergency Contact Flow', style: 'cta', pos: 'bottom: 22%; left: 5%;', depth: 0.05 },
      { text: 'Before/After Gallery', style: 'pill', pos: 'top: 65%; left: 5%;', depth: 0.03 },
    ],
  },
  {
    name: 'Kin & Grain Café',
    description: 'Warm editorial hospitality site with an interactive digital menu, event listings, email capture, and catering enquiries — a community hub that drives repeat visits.',
    tags: ['Digital Menu', 'Events Calendar', 'Email Capture', 'Catering Form', 'Instagram Feed'],
    thumbnail: '/thumbnails/cafe.png',
    link: 'https://demo-kin-grain-cafe.vercel.app',
    color: '#b45309',
    floats: [
      { text: 'Digital Menu System', style: 'badge', pos: 'top: 10%; left: 5%;', depth: 0.04 },
      { text: 'Event Listings & RSVP', style: 'cta', pos: 'bottom: 22%; right: 5%;', depth: 0.05 },
      { text: 'Email Capture', style: 'pill', pos: 'top: 60%; right: 5%;', depth: 0.03 },
    ],
  },
  {
    name: 'Apex Performance Studio',
    description: 'Conversion-optimised fitness site built as a sales funnel — multi-step lead capture, membership pricing, class timetable, and urgency-driven CTAs that turn visitors into trial members.',
    tags: ['Sales Funnel', 'Multi-Step Form', 'Pricing Table', 'Class Timetable', 'Video Tour', 'Animated Stats'],
    thumbnail: '/thumbnails/fitness.png',
    link: 'https://demo-apex-fitness.vercel.app',
    color: '#dc2626',
    floats: [
      { text: 'Multi-Step Sign Up', style: 'cta', pos: 'top: 10%; right: 5%;', depth: 0.05 },
      { text: 'Before / After Slider', style: 'badge', pos: 'bottom: 22%; left: 5%;', depth: 0.04 },
      { text: 'Class Timetable', style: 'pill', pos: 'top: 60%; left: 5%;', depth: 0.03 },
    ],
  },
  {
    name: 'Whitfield & Associates',
    description: 'Authority-driven professional services site with insights blog, consultation booking, animated credibility metrics, and content marketing architecture that attracts organic search traffic.',
    tags: ['Blog with Filters', 'Booking Form', 'Animated Stats', 'Team Profiles', 'Client Logos', 'Newsletter'],
    thumbnail: '/thumbnails/accounting.png',
    link: 'https://demo-whitfield-accounting.vercel.app',
    color: '#1e3a5f',
    floats: [
      { text: 'Filterable Blog', style: 'badge', pos: 'top: 10%; left: 5%;', depth: 0.04 },
      { text: 'Consultation Booking', style: 'cta', pos: 'bottom: 22%; right: 5%;', depth: 0.05 },
      { text: 'Animated Stats', style: 'pill', pos: 'top: 60%; right: 5%;', depth: 0.03 },
    ],
  },
  {
    name: 'LUMA Hair & Beauty',
    description: 'Luxury appointment-based site with a full booking flow, expandable service menu with pricing, transformation gallery, and team showcase — replacing phone bookings with a seamless digital experience.',
    tags: ['4-Step Booking Flow', 'Service Pricing Menu', 'Before/After Sliders', 'Team Carousel', 'Newsletter', 'Product Showcase'],
    thumbnail: '/thumbnails/hair.png',
    link: 'https://demo-luma-hair-beauty.vercel.app',
    color: '#7c3aed',
    floats: [
      { text: 'Step-by-Step Booking', style: 'cta', pos: 'top: 10%; right: 5%;', depth: 0.05 },
      { text: 'Transformation Gallery', style: 'badge', pos: 'bottom: 22%; left: 5%;', depth: 0.04 },
      { text: 'Team Carousel', style: 'pill', pos: 'top: 60%; left: 5%;', depth: 0.03 },
    ],
  },
];

const steps = [
  {
    number: '01',
    title: 'Discovery',
    description: 'I study your business, your market, and your competitors. You get a free mockup before any commitment.',
    details: ['Competitor Audit', 'User Research', 'Free Mockup', 'Strategy Session'],
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`,
  },
  {
    number: '02',
    title: 'Design & Build',
    description: 'Custom-designed from scratch. Mobile-first, performance-tuned, search-optimised from the first line of code.',
    details: ['Custom UI', 'Mobile-First', 'SEO Architecture', 'Performance Budget'],
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`,
  },
  {
    number: '03',
    title: 'Launch',
    description: 'Domain, hosting, SSL, deployment — all handled. Your site goes live on edge infrastructure with zero downtime.',
    details: ['Domain Config', 'Edge CDN', 'SSL & Security', 'Zero-Downtime Deploy'],
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09zM12 15l-3-3M22 2l-7.5 7.5"/><path d="M9.05 12.95 5.5 16.5"/><path d="M11.05 10.95 14.5 7.5"/><circle cx="18" cy="6" r="3"/></svg>`,
  },
  {
    number: '04',
    title: 'Support',
    description: 'Monthly performance reports. Quick content updates. Ongoing hosting and SEO monitoring. You run your business.',
    details: ['Performance Reports', 'Content Updates', 'Hosting Managed', 'SEO Monitoring'],
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M12 6v6l4 2"/></svg>`,
  },
];

---

<Layout
  title="Alister Maddrell — Web Design & Development, Sydney"
  description="Independent web designer and developer in Sydney. Hand-coded websites — no templates, no WordPress. Custom-built, SEO-optimised, engineered to convert."
>
  <!-- Loader -->
  <div id="loader">
    <div class="loader-letters">
      <span class="loader-char">A</span>
      <span class="loader-char">M</span>
    </div>
    <div class="loader-line"></div>
  </div>

  <!-- Scroll progress -->
  <div id="scroll-progress"></div>

  <!-- Theme transition overlay -->
  <div id="theme-transition"></div>

  <!-- Site-wide dot paper texture — canvas for per-dot shimmer -->
  <canvas id="dot-grid" aria-hidden="true" style="opacity:0"></canvas>

  <!-- Custom cursor -->
  <div id="cursor-dot"></div>
  <div id="cursor-circle"></div>
  <div id="cursor-trail"></div>

  <!-- ─── Nav: Top bar (mobile only) ─── -->
  <div id="nav-top">
    <a href="#hero" class="nav-logo font-heading text-sm font-bold tracking-[0.15em] uppercase text-ink" data-cursor-hover data-magnetic>AM</a>
    <div class="flex items-center gap-3">
      <div id="theme-switcher-mobile" class="theme-switcher-mobile" data-cursor-hover>
        <button class="theme-option-mobile" data-theme-value="light" aria-label="Light theme">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </button>
        <button class="theme-option-mobile" data-theme-value="system" aria-label="System theme">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
        </button>
        <button class="theme-option-mobile" data-theme-value="dark" aria-label="Dark theme">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </div>
      <button id="menu-toggle" class="flex flex-col gap-[5px] p-2" data-cursor-hover aria-label="Menu">
        <span class="block w-5 h-[1.5px] bg-ink transition-all origin-center" id="menu-line-1"></span>
        <span class="block w-5 h-[1.5px] bg-ink transition-all origin-center" id="menu-line-2"></span>
      </button>
    </div>
  </div>

  <!-- ─── Nav: Full sidebar rail (desktop) ─── -->
  <nav id="nav-rail" aria-label="Section navigation">
    <a href="#hero" class="nav-rail-logo" data-cursor-hover data-magnetic>AM</a>

    <div class="nav-rail-nodes">
      <div class="nav-rail-line"></div>
      <div class="nav-rail-progress" id="nav-rail-progress"></div>
      <a href="#hero" class="nav-node active" data-nav-section="hero" data-cursor-hover data-magnetic="0.2">
        <span class="nav-node-label">Home</span>
        <span class="nav-node-dot"></span>
      </a>
      <a href="#work" class="nav-node" data-nav-section="work" data-cursor-hover data-magnetic="0.2">
        <span class="nav-node-label">Work</span>
        <span class="nav-node-dot"></span>
      </a>
      <a href="#process" class="nav-node" data-nav-section="process" data-cursor-hover data-magnetic="0.2">
        <span class="nav-node-label">Process</span>
        <span class="nav-node-dot"></span>
      </a>
      <a href="#about" class="nav-node" data-nav-section="about" data-cursor-hover data-magnetic="0.2">
        <span class="nav-node-label">About</span>
        <span class="nav-node-dot"></span>
      </a>
      <a href="#contact" class="nav-node" data-nav-section="contact" data-cursor-hover data-magnetic="0.2">
        <span class="nav-node-label">Contact</span>
        <span class="nav-node-dot"></span>
      </a>
    </div>

    <div id="theme-switcher" class="theme-switcher" data-cursor-hover>
      <div class="theme-switcher-prompt" id="theme-prompt">
        <span class="theme-prompt-text">Theme</span>
        <svg class="theme-prompt-arrow" viewBox="0 0 28 24" aria-hidden="true">
          <path d="M2 14 C6 4, 16 2, 20 10 C22 14, 20 18, 24 12 L22 14 M24 12 L22 9"/>
        </svg>
      </div>
      <div class="theme-switcher-options">
        <button class="theme-option" data-theme-value="light" aria-label="Light theme">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <span class="theme-option-label">Light</span>
        </button>
        <button class="theme-option active" data-theme-value="system" aria-label="System theme">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
          <span class="theme-option-label">Auto</span>
        </button>
        <button class="theme-option" data-theme-value="dark" aria-label="Dark theme">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <span class="theme-option-label">Dark</span>
        </button>
      </div>
    </div>
  </nav>

  <!-- ─── Nav: Mobile bottom pill ─── -->
  <nav id="nav-mobile" aria-label="Mobile navigation">
    <a href="#work" class="nav-mobile-link" data-nav-section="work">Work</a>
    <a href="#process" class="nav-mobile-link" data-nav-section="process">Process</a>
    <a href="#about" class="nav-mobile-link" data-nav-section="about">About</a>
    <a href="#contact" class="nav-mobile-link" data-nav-section="contact">Contact</a>
  </nav>

  <!-- Mobile fullscreen menu (fallback) -->
  <div id="mobile-menu" class="fixed inset-0 z-[99] bg-ink opacity-0 invisible flex items-center justify-center">
    <div class="flex flex-col items-center gap-8">
      <a href="#work" class="menu-link font-heading text-3xl font-light text-surface tracking-wide" data-cursor-hover>Work</a>
      <a href="#process" class="menu-link font-heading text-3xl font-light text-surface tracking-wide" data-cursor-hover>Process</a>
      <a href="#about" class="menu-link font-heading text-3xl font-light text-surface tracking-wide" data-cursor-hover>About</a>
      <a href="#contact" class="menu-link font-heading text-3xl font-light text-surface tracking-wide" data-cursor-hover>Contact</a>
    </div>
  </div>

  <main>
    <!-- ─── HERO ─── -->
    <section id="hero" class="relative min-h-screen flex flex-col justify-center px-6 md:px-10 overflow-hidden">
      <!-- Deep depth layers -->
      <span class="hero-watermark" data-hero-layer="watermark" aria-hidden="true">AM</span>
      <span class="hero-grid-overlay" data-hero-layer="grid" aria-hidden="true"></span>
      <span class="hero-year" data-hero-layer="year" aria-hidden="true">&rsquo;26</span>

      <!-- Mid depth layers -->
      <div class="hero-accent-bar" data-hero-layer="bar" aria-hidden="true"></div>
      <div class="hero-accent-ring" data-hero-layer="ring" aria-hidden="true"></div>

      <!-- Corner brackets (animated draw-in) -->
      <span class="hero-corner hero-corner--tl" data-hero-layer="corner" aria-hidden="true"></span>
      <span class="hero-corner hero-corner--br" data-hero-layer="corner" aria-hidden="true"></span>

      <!-- Scan line — periodic horizontal sweep -->
      <div class="hero-scan-line" aria-hidden="true"></div>

      <!-- Data line — full-width horizontal accent at midpoint -->
      <div class="hero-data-line" data-hero-layer="data-line" aria-hidden="true"></div>

      <!-- Coordinate marks -->
      <span class="hero-coord hero-coord--top" data-hero-layer="coord" aria-hidden="true">33.8688&deg;S</span>
      <span class="hero-coord hero-coord--bottom" data-hero-layer="coord" aria-hidden="true">151.2093&deg;E</span>

      <!-- Orb -->
      <div id="hero-orb-wrapper" data-hero-layer="orb" class="hidden md:block" style="position:absolute;right:0;top:5%;width:700px;height:700px;pointer-events:none;z-index:0;transform:translateX(10%);background:radial-gradient(circle at center, rgba(212,85,42,0.28) 0%, rgba(212,85,42,0.15) 25%, rgba(212,85,42,0.06) 50%, transparent 70%);border-radius:50%;"></div>

      <div class="container-main w-full pt-24 relative z-[1] hero-scroll-fade">
        <!-- Monospace status line -->
        <div class="hero-status" data-float="13">
          <span class="hero-status-dot" aria-hidden="true"></span>
          <span>Available for projects</span>
          <span class="hero-status-sep" aria-hidden="true">/</span>
          <span>Sydney, AU</span>
        </div>

        <!-- Hero depth layers behind text -->
        <div class="hero-title-wrap relative">
          <span class="hero-section-index" data-hero-layer="index" aria-hidden="true">/01</span>
          <div class="hero-title-block" data-hero-layer="title-block" aria-hidden="true"></div>
          <div class="hero-title-line" data-hero-layer="title-line" aria-hidden="true"></div>
          <h1 id="hero-name" class="hero-name text-ink" data-hero-typewriter style="visibility: hidden;">
            Alister Maddrell
          </h1>
        </div>

        <!-- Decorative rule -->
        <div class="hero-rule" aria-hidden="true"></div>

        <div id="hero-subtitle" class="mt-8 md:mt-12">
          <p class="subtitle-line font-heading text-muted text-lg md:text-xl tracking-wide max-w-xl" style="font-weight: 300;">
            Designed with intent. <span class="text-accent" style="font-weight: 700;">Built with precision.</span>
          </p>
          <p class="subtitle-line font-body text-xs mt-4 tracking-[0.15em] uppercase" style="color: var(--color-muted); opacity: 0.5;">
            Web Design + Engineering · Sydney, Australia
          </p>
        </div>

        <!-- Services micro-list -->
        <div class="hero-services" id="hero-services">
          <span>Design</span>
          <span class="hero-services-dot" aria-hidden="true"></span>
          <span>Engineering</span>
          <span class="hero-services-dot" aria-hidden="true"></span>
          <span>Search</span>
          <span class="hero-services-dot" aria-hidden="true"></span>
          <span>Infrastructure</span>
        </div>

        <!-- CTA -->
        <a href="#contact" class="hero-cta" id="hero-cta" data-cursor-hover data-magnetic>
          <span class="hero-cta-text">Start your project</span>
          <span class="hero-cta-arrow" aria-hidden="true">&rarr;</span>
        </a>
      </div>

      <div id="scroll-indicator" class="scroll-indicator absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3">
        <span class="font-body text-[0.6875rem] tracking-[0.2em] uppercase text-muted">Scroll</span>
        <div class="scroll-line"></div>
      </div>
    </section>

    <!-- Section mark: Hero → Work -->
    <div class="section-mark" aria-hidden="true"><span class="section-mark-dot"></span></div>

    <!-- ─── WORK ─── -->
    <section id="work" class="px-4 md:px-10 py-16 md:py-56 relative">
      <span class="section-bg-text" data-bg-parallax aria-hidden="true">Work</span>
      <!-- Section-level depth layers -->
      <span class="work-depth-number" data-depth-layer="deep" aria-hidden="true">W</span>
      <div class="work-depth-line" data-depth-layer="mid" aria-hidden="true"></div>
      <div class="work-depth-ring" data-depth-layer="mid" aria-hidden="true"></div>
      <div class="work-depth-crosshair" data-depth-layer="deep" aria-hidden="true"></div>
      <div class="work-depth-rule" data-depth-layer="mid" aria-hidden="true">
        <span class="work-rule-tick"></span>
        <span class="work-rule-tick"></span>
        <span class="work-rule-tick"></span>
        <span class="work-rule-tick"></span>
        <span class="work-rule-tick"></span>
      </div>
      <span class="work-depth-coord" data-depth-layer="deep" aria-hidden="true">05 / SELECTED</span>
      <div class="work-depth-diagonal" data-depth-layer="deep" aria-hidden="true"></div>
      <div class="work-depth-dot work-depth-dot--1" data-depth-layer="mid" aria-hidden="true"></div>
      <div class="work-depth-dot work-depth-dot--2" data-depth-layer="deep" aria-hidden="true"></div>
      <div class="work-depth-dot work-depth-dot--3" data-depth-layer="mid" aria-hidden="true"></div>
      <div class="container-main" data-depth-container>
        <div class="section-heading-wrap mb-12 md:mb-24" data-heading-reveal data-float="1" data-depth-container>
          <span class="work-heading-depth" data-depth-layer="deep" aria-hidden="true">/05</span>
          <div class="work-heading-block" data-depth-layer="mid" aria-hidden="true"></div>
          <div class="flex items-baseline gap-4">
            <h2 class="section-heading" data-heading-text="Work">Work</h2>
            <span class="section-heading-number">/05</span>
          </div>
          <div class="section-heading-line w-full max-w-[120px]"></div>
        </div>

        <div class="project-list flex flex-col gap-14 md:gap-40">
          {projects.map((project, i) => (
            <a
              href={project.link}
              target="_blank"
              rel="noopener noreferrer"
              class="project-card project-card-v group block"
              data-reveal="scale"
              data-tilt
              data-cursor-hover
              data-float={String(20 + i * 3)}
              style={`--card-color: ${project.color}; --card-index: ${i};`}
            >
              <span class="project-index-stroke" data-card-layer="stroke" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <span class="project-index" data-card-layer="index" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <div class="project-accent-line" data-card-layer="line" aria-hidden="true"></div>
              <div class="project-color-block" data-card-layer="block" aria-hidden="true"></div>
              <span class="project-label" data-card-layer="label" aria-hidden="true">PROJ.{String(i + 1).padStart(2, '0')}</span>
              <div class="browser-frame" data-skew data-parallax-container>
                <span class="browser-corner" aria-hidden="true"></span>
                <div class="browser-bar" aria-hidden="true">
                  <span class="browser-dot"></span>
                  <span class="browser-dot"></span>
                  <span class="browser-dot"></span>
                  <span class="browser-url">{new URL(project.link).hostname}</span>
                </div>
                <div class="project-image project-image-clip">
                  <img
                    src={project.thumbnail}
                    alt={`${project.name} website screenshot`}
                    class="project-image-inner"
                    loading="eager"
                    fetchpriority="high"
                    decoding="async"
                  />
                  {project.floats.map((f) => (
                    <span
                      class={`floating-ui floating-ui--${f.style}`}
                      style={`${f.pos} --depth: ${f.depth};`}
                      data-float-depth={f.depth}
                      aria-hidden="true"
                    >
                      {f.text}
                    </span>
                  ))}
                </div>
              </div>
              <div class="project-details" data-reveal data-skew>
                <div class="details-depth-block" aria-hidden="true"></div>
                <div class="details-accent-bar" aria-hidden="true"></div>
                <div class="project-details-header">
                  <h3 class="project-title font-heading text-lg md:text-2xl font-bold text-ink tracking-tight" data-scramble>
                    {project.name}
                  </h3>
                  <span class="link-hover inline-flex items-center gap-1.5 md:gap-2 font-heading text-xs md:text-sm font-semibold text-ink group-hover:text-accent tracking-wide transition-colors whitespace-nowrap">
                    <span class="status-dot" aria-hidden="true"></span>
                    View Site
                    <span class="inline-block transition-transform group-hover:translate-x-1.5">&rarr;</span>
                  </span>
                </div>
                <p class="font-body text-muted text-[0.875rem] md:text-[0.9375rem] leading-relaxed mb-3 md:mb-4 max-w-lg">
