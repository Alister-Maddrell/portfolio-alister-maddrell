---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const projects = [
  {
    name: 'Hartley & Co Plumbing',
    description: 'Professional plumbing website with emergency contact features and service area mapping',
    tags: ['Google Maps', 'FAQ Accordion', 'Contact Form', 'SEO'],
    thumbnail: '/thumbnails/hartley.webp',
    link: 'https://demo-hartley-plumbing.vercel.app',
    color: '#2563eb',
    floats: [
      { text: 'Interactive Service Map', style: 'badge', pos: 'top: 10%; right: 5%;', depth: 0.04 },
      { text: 'Emergency Contact Flow', style: 'cta', pos: 'bottom: 22%; left: 5%;', depth: 0.05 },
      { text: 'Live FAQ Accordion', style: 'pill', pos: 'top: 65%; left: 5%;', depth: 0.03 },
    ],
  },
  {
    name: 'Kin & Grain Café',
    description: 'Warm editorial-style cafe site with full menu, events, and email capture',
    tags: ['Email Newsletter', 'Tabbed Menu', 'Event Listings', 'Catering Form'],
    thumbnail: '/thumbnails/cafe.webp',
    link: 'https://demo-kin-grain-cafe.vercel.app',
    color: '#b45309',
    floats: [
      { text: 'Tabbed Menu System', style: 'badge', pos: 'top: 10%; left: 5%;', depth: 0.04 },
      { text: 'Event Listings & RSVP', style: 'cta', pos: 'bottom: 22%; right: 5%;', depth: 0.05 },
      { text: 'Newsletter Capture', style: 'pill', pos: 'top: 60%; right: 5%;', depth: 0.03 },
    ],
  },
  {
    name: 'Apex Performance Studio',
    description: 'Bold dark-themed fitness site with membership pricing and class timetable',
    tags: ['Pricing Table', 'Multi-Step Form', 'Class Timetable', 'Before/After'],
    thumbnail: '/thumbnails/fitness.webp',
    link: 'https://demo-apex-fitness.vercel.app',
    color: '#dc2626',
    floats: [
      { text: 'Multi-Step Sign Up', style: 'cta', pos: 'top: 10%; right: 5%;', depth: 0.05 },
      { text: 'Before / After Slider', style: 'badge', pos: 'bottom: 22%; left: 5%;', depth: 0.04 },
      { text: 'Class Timetable', style: 'pill', pos: 'top: 60%; left: 5%;', depth: 0.03 },
    ],
  },
  {
    name: 'Whitfield & Associates',
    description: 'Minimal professional services site with insights blog and consultation booking',
    tags: ['Blog with Filters', 'Booking Form', 'Scroll Animations', 'Client Logos'],
    thumbnail: '/thumbnails/accounting.webp',
    link: 'https://demo-whitfield-accounting.vercel.app',
    color: '#1e3a5f',
    floats: [
      { text: 'Filterable Blog', style: 'badge', pos: 'top: 10%; left: 5%;', depth: 0.04 },
      { text: 'Consultation Booking', style: 'cta', pos: 'bottom: 22%; right: 5%;', depth: 0.05 },
      { text: 'Scroll Animations', style: 'pill', pos: 'top: 60%; right: 5%;', depth: 0.03 },
    ],
  },
  {
    name: 'LUMA Hair & Beauty',
    description: 'Luxury salon site with full service menu, booking flow, and transformation gallery',
    tags: ['Booking Flow', 'Service Pricing', 'Before/After Slider', 'Team Carousel'],
    thumbnail: '/thumbnails/hair.webp',
    link: 'https://demo-luma-hair-beauty.vercel.app',
    color: '#7c3aed',
    floats: [
      { text: 'Step-by-Step Booking', style: 'cta', pos: 'top: 10%; right: 5%;', depth: 0.05 },
      { text: 'Transformation Gallery', style: 'badge', pos: 'bottom: 22%; left: 5%;', depth: 0.04 },
      { text: 'Team Carousel', style: 'pill', pos: 'top: 60%; left: 5%;', depth: 0.03 },
    ],
  },
];

const steps = [
  {
    number: '01',
    title: 'Discovery',
    description: 'I research your business, your competitors, and your customers. Then I build a free mockup so you can see what\'s possible before committing.',
  },
  {
    number: '02',
    title: 'Design & Build',
    description: 'Every site is custom-designed from scratch. Fast-loading, mobile-first, and optimised for Google search from day one.',
  },
  {
    number: '03',
    title: 'Launch',
    description: 'I handle hosting, domain setup, and deployment. Your site goes live on a fast, reliable platform with zero downtime.',
  },
  {
    number: '04',
    title: 'Support',
    description: 'Monthly performance reports, quick updates when you need them, and ongoing hosting management. You focus on your business.',
  },
];

---

<Layout
  title="Alister Maddrell — Web Designer & Developer, Sydney"
  description="I design and build fast, modern websites for local businesses across Sydney. Custom-built, SEO-optimised, and designed to convert."
>
  <!-- Loader -->
  <div id="loader"><span>AM</span></div>

  <!-- Scroll progress -->
  <div id="scroll-progress"></div>

  <!-- Theme transition overlay -->
  <div id="theme-transition"></div>


  <!-- Custom cursor -->
  <div id="cursor-dot"></div>
  <div id="cursor-circle"></div>
  <div id="cursor-trail"></div>

  <!-- ─── Nav: Top bar (mobile only) ─── -->
  <div id="nav-top">
    <a href="#hero" class="nav-logo font-heading text-sm font-bold tracking-[0.15em] uppercase text-ink" data-cursor-hover data-magnetic>AM</a>
    <div class="flex items-center gap-3">
      <button id="theme-toggle-mobile" class="w-8 h-8 flex items-center justify-center text-muted hover:text-ink" data-cursor-hover aria-label="Toggle theme">
        <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>
      <button id="menu-toggle" class="flex flex-col gap-[5px] p-2" data-cursor-hover aria-label="Menu">
        <span class="block w-5 h-[1.5px] bg-ink transition-all origin-center" id="menu-line-1"></span>
        <span class="block w-5 h-[1.5px] bg-ink transition-all origin-center" id="menu-line-2"></span>
      </button>
    </div>
  </div>

  <!-- ─── Nav: Full sidebar rail (desktop) ─── -->
  <nav id="nav-rail" aria-label="Section navigation">
    <a href="#hero" class="nav-rail-logo" data-cursor-hover data-magnetic>AM</a>

    <div class="nav-rail-nodes">
      <div class="nav-rail-line"></div>
      <div class="nav-rail-progress" id="nav-rail-progress"></div>
      <a href="#hero" class="nav-node active" data-nav-section="hero" data-cursor-hover>
        <span class="nav-node-label">Home</span>
        <span class="nav-node-dot"></span>
      </a>
      <a href="#work" class="nav-node" data-nav-section="work" data-cursor-hover>
        <span class="nav-node-label">Work</span>
        <span class="nav-node-dot"></span>
      </a>
      <a href="#process" class="nav-node" data-nav-section="process" data-cursor-hover>
        <span class="nav-node-label">Process</span>
        <span class="nav-node-dot"></span>
      </a>
      <a href="#about" class="nav-node" data-nav-section="about" data-cursor-hover>
        <span class="nav-node-label">About</span>
        <span class="nav-node-dot"></span>
      </a>
      <a href="#contact" class="nav-node" data-nav-section="contact" data-cursor-hover>
        <span class="nav-node-label">Contact</span>
        <span class="nav-node-dot"></span>
      </a>
    </div>

    <button id="theme-toggle" class="nav-rail-theme" data-cursor-hover aria-label="Toggle theme">
      <svg id="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
      <svg id="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
    </button>
  </nav>

  <!-- ─── Nav: Mobile bottom pill ─── -->
  <nav id="nav-mobile" aria-label="Mobile navigation">
    <a href="#work" class="nav-mobile-link" data-nav-section="work">Work</a>
    <a href="#process" class="nav-mobile-link" data-nav-section="process">Process</a>
    <a href="#about" class="nav-mobile-link" data-nav-section="about">About</a>
    <a href="#contact" class="nav-mobile-link" data-nav-section="contact">Contact</a>
  </nav>

  <!-- Mobile fullscreen menu (fallback) -->
  <div id="mobile-menu" class="fixed inset-0 z-[99] bg-ink opacity-0 invisible flex items-center justify-center">
    <div class="flex flex-col items-center gap-8">
      <a href="#work" class="menu-link font-heading text-3xl font-light text-surface tracking-wide" data-cursor-hover>Work</a>
      <a href="#process" class="menu-link font-heading text-3xl font-light text-surface tracking-wide" data-cursor-hover>Process</a>
      <a href="#about" class="menu-link font-heading text-3xl font-light text-surface tracking-wide" data-cursor-hover>About</a>
      <a href="#contact" class="menu-link font-heading text-3xl font-light text-surface tracking-wide" data-cursor-hover>Contact</a>
    </div>
  </div>

  <main>
    <!-- ─── HERO ─── -->
    <section id="hero" class="relative min-h-screen flex flex-col justify-center px-6 md:px-10">
      <div id="hero-orb-wrapper" class="hidden md:block" style="position:absolute;right:0;top:5%;width:700px;height:700px;pointer-events:none;z-index:0;transform:translateX(10%);background:radial-gradient(circle at center, rgba(212,85,42,0.28) 0%, rgba(212,85,42,0.15) 25%, rgba(212,85,42,0.06) 50%, transparent 70%);border-radius:50%;"></div>
      <div class="container-main w-full pt-24 relative z-[1]">
        <h1 id="hero-name" class="hero-name text-ink" data-hero-typewriter>
          Alister Maddrell
        </h1>
        <div id="hero-subtitle" class="mt-6 md:mt-10">
          <p class="subtitle-line font-heading text-muted text-base md:text-lg font-medium tracking-wide max-w-xl">
            Every pixel <span class="text-accent">earns its place.</span>
          </p>
          <p class="subtitle-line font-body text-xs mt-3 tracking-[0.15em] uppercase" style="color: var(--color-muted); opacity: 0.6;">
            Web Designer & Developer · Sydney
          </p>
        </div>
      </div>
      <div id="scroll-indicator" class="scroll-indicator absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3">
        <span class="font-body text-[0.6875rem] tracking-[0.2em] uppercase text-muted">Scroll</span>
        <div class="scroll-line"></div>
      </div>
    </section>

    <!-- ─── INTRO — Typewriter ─── -->
    <section id="intro" class="px-6 md:px-10 py-28 md:py-40">
      <div class="container-main">
        <div class="section-divider w-full max-w-[200px] mb-14" data-divider></div>
        <div id="intro-typewriter" class="max-w-[900px]" aria-label="I design and build fast, modern websites for local businesses across Sydney. Every site is custom-built, SEO-optimised, and designed to turn visitors into customers.">
          <div class="typewriter-text font-heading text-xl md:text-2xl lg:text-[1.75rem] font-bold text-ink leading-[1.25] tracking-tight" aria-hidden="true"></div>
        </div>
        <div id="intro-strikes" class="mt-12 md:mt-16 flex flex-wrap items-center gap-x-5 gap-y-3">
          <span class="intro-strike font-heading text-base md:text-lg font-medium text-muted">No templates</span>
          <span class="intro-strike font-heading text-base md:text-lg text-accent opacity-40">·</span>
          <span class="intro-strike font-heading text-base md:text-lg font-medium text-muted">No WordPress</span>
          <span class="intro-strike font-heading text-base md:text-lg text-accent opacity-40">·</span>
          <span class="intro-strike font-heading text-base md:text-lg font-semibold text-ink">Just clean, high-performance code.</span>
        </div>
      </div>
    </section>

    <!-- ─── WORK ─── -->
    <section id="work" class="px-6 md:px-10 py-28 md:py-40">
      <div class="container-main">
        <div class="section-heading-wrap mb-16 md:mb-24" data-heading-reveal>
          <div class="flex items-baseline gap-4">
            <h2 class="section-heading" data-heading-text="Work">Work</h2>
            <span class="section-heading-number">/05</span>
          </div>
          <div class="section-heading-line w-full max-w-[120px]"></div>
        </div>

        <div class="flex flex-col gap-32 md:gap-40" data-skew>
          {projects.map((project, i) => (
            <a
              href={project.link}
              target="_blank"
              rel="noopener noreferrer"
              class="project-card project-card-v group block"
              data-reveal="scale"
              data-tilt
              data-cursor-hover
              style={`--card-color: ${project.color}; --card-index: ${i};`}
            >
              <span class="project-index" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <div class="project-color-block" aria-hidden="true"></div>
              <div class="project-image" data-parallax-container>
                <img
                  src={project.thumbnail}
                  alt={`${project.name} website screenshot`}
                  class="project-image-inner"
                  loading="lazy"
                />
                {project.floats.map((f) => (
                  <span
                    class={`floating-ui floating-ui--${f.style}`}
                    style={`${f.pos} --depth: ${f.depth};`}
                    data-float-depth={f.depth}
                    aria-hidden="true"
                  >
                    {f.text}
                  </span>
                ))}
              </div>
              <div class="project-details" data-reveal>
                <div class="flex items-center justify-between mb-4">
                  <h3 class="font-heading text-xl md:text-2xl font-bold text-ink tracking-tight" data-scramble>
                    {project.name}
                  </h3>
                  <span class="link-hover inline-flex items-center gap-2 font-heading text-sm font-semibold text-ink group-hover:text-accent tracking-wide transition-colors">
                    View Site
                    <span class="inline-block transition-transform group-hover:translate-x-1.5">&rarr;</span>
                  </span>
                </div>
                <p class="font-body text-muted text-sm md:text-[0.9375rem] leading-relaxed mb-4 max-w-lg">
                  {project.description}
                </p>
                <div class="flex flex-wrap gap-2">
                  {project.tags.map((tag) => (
                    <span class="project-tag">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── PROCESS ─── -->
    <section id="process" class="px-6 md:px-10 py-28 md:py-40 bg-alt">
      <div class="container-main">
        <div class="section-heading-wrap mb-20 md:mb-28" data-heading-reveal>
          <div class="flex items-baseline gap-4">
            <h2 class="section-heading" data-heading-text="Process">Process</h2>
            <span class="section-heading-number">/04</span>
          </div>
          <div class="section-heading-line w-full max-w-[120px]"></div>
        </div>
        <div class="flex flex-col gap-0">
          {steps.map((step, i) => (
            <div
              class="process-step group grid grid-cols-1 md:grid-cols-[120px_1fr] gap-4 md:gap-12 py-10 md:py-14"
              style={`border-bottom: 1px solid var(--color-line); ${i === 0 ? 'border-top: 1px solid var(--color-line);' : ''}`}
              data-reveal
            >
              <span class="step-number" data-parallax="0.015">{step.number}</span>
              <div class="max-w-lg">
                <h3 class="font-heading text-lg md:text-xl font-bold text-ink tracking-tight">
                  {step.title}
                </h3>
                <p class="font-body text-muted text-sm md:text-[0.9375rem] leading-relaxed mt-3">
                  {step.description}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── ABOUT ─── -->
    <section id="about" class="px-6 md:px-10 py-28 md:py-40">
      <div class="container-main">
        <div class="section-heading-wrap mb-16 md:mb-20" data-heading-reveal>
          <div class="flex items-baseline gap-4">
            <h2 class="section-heading" data-heading-text="About">About</h2>
          </div>
          <div class="section-heading-line w-full max-w-[120px]"></div>
        </div>

        <!-- Manifesto — word-by-word scroll lighting -->
        <div id="manifesto" class="mb-14 md:mb-20 about-block" data-about-block>
          <p class="font-heading text-xl md:text-2xl lg:text-[1.75rem] font-bold text-ink leading-[1.3] tracking-tight" data-manifesto>
            I'm Alister — a web designer in Sydney who believes the best websites don't feel designed. They just work. Fast, modern, and built to turn visitors into customers.
          </p>
        </div>

        <!-- Stats — animated counters -->
        <div class="about-stats mb-14 md:mb-20" data-about-stats>
          <div class="about-stat" data-stat data-stat-target="100" data-stat-suffix="%">
            <span class="about-stat-number" data-stat-number>0%</span>
            <span class="about-stat-label">Custom Built</span>
          </div>
          <div class="about-stat" data-stat data-stat-target="3" data-stat-suffix="s">
            <span class="about-stat-number" data-stat-number>0s</span>
            <span class="about-stat-label">Avg Load Time</span>
          </div>
          <div class="about-stat" data-stat data-stat-target="0" data-stat-suffix="">
            <span class="about-stat-number" data-stat-number>0</span>
            <span class="about-stat-label">Templates Used</span>
          </div>
        </div>

        <!-- Body text -->
        <div class="max-w-2xl mb-14 md:mb-20 about-block" data-about-block>
          <p class="font-body text-muted text-[0.8125rem] md:text-[0.875rem] leading-relaxed">
            No templates. No WordPress. Every project is hand-coded from scratch — clean, semantic HTML, lightning-fast load times, and SEO baked in from day one. I obsess over the details so your customers don't have to think twice.
          </p>
        </div>

        <!-- Approach — icon cards that slide in -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-14 md:mb-20">
          <div class="approach-item" data-approach>
            <div class="approach-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            </div>
            <div>
              <h4 class="font-heading text-sm font-bold text-ink tracking-tight">Hand-Coded</h4>
              <p class="font-body text-muted text-xs mt-1 leading-relaxed">Every line written from scratch. Clean, semantic, performant.</p>
            </div>
          </div>
          <div class="approach-item" data-approach>
            <div class="approach-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            </div>
            <div>
              <h4 class="font-heading text-sm font-bold text-ink tracking-tight">Lightning Fast</h4>
              <p class="font-body text-muted text-xs mt-1 leading-relaxed">Sub-3 second loads. Optimised images, minimal JS, edge hosting.</p>
            </div>
          </div>
          <div class="approach-item" data-approach>
            <div class="approach-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.66 0 3-4.03 3-9s-1.34-9-3-9m0 18c-1.66 0-3-4.03-3-9s1.34-9 3-9"/></svg>
            </div>
            <div>
              <h4 class="font-heading text-sm font-bold text-ink tracking-tight">SEO-First</h4>
              <p class="font-body text-muted text-xs mt-1 leading-relaxed">Built for Google from day one. Semantic markup, meta, schema.</p>
            </div>
          </div>
          <div class="approach-item" data-approach>
            <div class="approach-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            </div>
            <div>
              <h4 class="font-heading text-sm font-bold text-ink tracking-tight">Responsive</h4>
              <p class="font-body text-muted text-xs mt-1 leading-relaxed">Pixel-perfect on every device. Mobile-first, tested everywhere.</p>
            </div>
          </div>
        </div>

        <!-- Skill pills — staggered reveal -->
        <div class="skill-pills" data-skill-pills>
          {['Web Design', 'Development', 'SEO', 'Hosting', 'UI/UX', 'Performance', 'Astro', 'React', 'Tailwind', 'Figma', 'Vercel', 'Node.js'].map((skill) => (
            <span class="skill-pill" data-cursor-hover>{skill}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── CONTACT ─── -->
    <section id="contact" class="px-6 md:px-10 py-28 md:py-40 bg-alt">
      <div class="container-main">
        <!-- Big typewriter prompt -->
        <p class="contact-prompt" data-contact-prompt>
          Got a project in mind? <span class="accent">Let's talk.</span>
        </p>

        <!-- Draw-in line -->
        <div class="contact-draw-line" data-contact-line></div>

        <!-- Form card -->
        <div class="contact-form-card" data-contact-card>
          <form id="contact-form" action="https://formspree.io/f/placeholder" method="POST">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8">
              <div class="contact-field" data-contact-field>
                <label for="name">Name</label>
                <input type="text" id="name" name="name" placeholder="Your name" required />
                <div class="field-line"></div>
              </div>
              <div class="contact-field" data-contact-field>
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="your@email.com" required />
                <div class="field-line"></div>
              </div>
              <div class="contact-field" data-contact-field>
                <label for="business">Business</label>
                <input type="text" id="business" name="business" placeholder="Company name (optional)" />
                <div class="field-line"></div>
              </div>
              <div class="contact-field" data-contact-field>
                <label for="budget">Budget</label>
                <input type="text" id="budget" name="budget" placeholder="e.g. $2k — $5k" />
                <div class="field-line"></div>
              </div>
            </div>
            <div class="contact-field" data-contact-field>
              <label for="message">Message</label>
              <textarea id="message" name="message" placeholder="Tell me about your project..." required rows="3" class="resize-none"></textarea>
              <div class="field-line"></div>
            </div>
            <div class="mt-8">
              <button type="submit" class="contact-send" data-contact-send data-cursor-hover>
                <span>Send Message</span>
                <span class="send-arrow">&rarr;</span>
              </button>
            </div>
          </form>

          <div id="form-success" class="hidden py-12 text-center">
            <p class="font-heading text-xl md:text-2xl font-bold text-ink tracking-tight">Message sent!</p>
            <p class="font-body text-muted text-sm mt-2">I'll be in touch within 24 hours.</p>
          </div>
          <div id="form-error" class="hidden font-body text-red-500 text-sm mt-4">
            Something went wrong. Please try emailing me directly.
          </div>
        </div>

        <!-- Info row -->
        <div class="contact-info-row">
          <a href="mailto:alistermaddrell@gmail.com" class="contact-info-item" data-contact-info data-cursor-hover>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            alistermaddrell@gmail.com
          </a>
          <div class="contact-info-item" data-contact-info>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            Sydney, Australia
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- ─── FOOTER ─── -->
  <footer class="px-6 md:px-10 py-8" style="border-top: 1px solid var(--color-line);">
    <div class="container-main flex items-center justify-between">
      <span class="font-body text-xs text-muted">&copy; 2026 Alister Maddrell</span>
      <div class="flex items-center gap-6">
        <div class="hidden sm:flex items-center gap-3">
          <div class="clock-face" id="analog-clock">
            <div class="clock-hand clock-hand-hour" id="clock-hour"></div>
            <div class="clock-hand clock-hand-minute" id="clock-minute"></div>
            <div class="clock-hand clock-hand-second" id="clock-second"></div>
            <div class="clock-dot"></div>
          </div>
          <div class="flex flex-col">
            <span class="font-heading text-[0.6875rem] font-semibold tracking-[0.08em] text-ink leading-none" id="sydney-time"></span>
            <span class="font-body text-[0.5625rem] tracking-[0.12em] uppercase text-muted mt-0.5">Sydney</span>
          </div>
        </div>
        <a href="#hero" class="link-hover font-body text-xs text-muted hover:text-ink" data-cursor-hover>
          Back to top &uarr;
        </a>
      </div>
    </div>
  </footer>

  <!-- ─── SCRIPTS ─── -->
  <script>
    import Lenis from 'lenis';

    // ── Lenis smooth scroll ──
    const lenis = new Lenis({
      duration: 1.2,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    });

    function raf(time: number) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);

    // Handle anchor clicks for Lenis
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener('click', (e) => {
        e.preventDefault();
        const href = (anchor as HTMLAnchorElement).getAttribute('href');
        if (!href) return;
        const target = document.querySelector(href);
        if (target) {
          lenis.scrollTo(target as HTMLElement, { offset: 0 });
          const mobileMenu = document.getElementById('mobile-menu');
          if (mobileMenu?.classList.contains('open')) {
            mobileMenu.classList.remove('open');
            document.body.style.overflow = '';
          }
        }
      });
    });

    // ── Loader ──
    const loader = document.getElementById('loader');
    const heroName = document.getElementById('hero-name');
    const heroSubtitle = document.getElementById('hero-subtitle');

    window.addEventListener('load', () => {
      setTimeout(() => {
        loader?.classList.add('done');
        setTimeout(() => {
          if (loader) loader.style.display = 'none';
          startHeroTypewriter();
        }, 800);
      }, 400);
    });

    // ── Hero name typewriter ──
    function startHeroTypewriter() {
      if (!heroName) return;
      const text = heroName.textContent?.trim() || '';
      heroName.innerHTML = '';
      heroName.style.minHeight = '1em';

      const cursor = document.createElement('span');
      cursor.classList.add('typewriter-cursor');

      let charIdx = 0;
      function typeNext() {
        if (charIdx >= text.length) {
          heroName.textContent = text;
          heroName.appendChild(cursor);
          // Remove cursor after a moment
          setTimeout(() => cursor.remove(), 1500);
          // Reveal subtitle with smooth animation
          setTimeout(() => heroSubtitle?.classList.add('revealed'), 300);
          // Reveal scroll indicator
          setTimeout(() => document.getElementById('scroll-indicator')?.classList.add('revealed'), 800);
          return;
        }
        heroName.textContent = text.slice(0, charIdx + 1);
        heroName.appendChild(cursor);
        charIdx++;
        const ch = text[charIdx - 1];
        const delay = ch === ' ' ? 60 : 50 + Math.random() * 30;
        setTimeout(typeNext, delay);
      }
      typeNext();
    }

    // ── Scroll-triggered reveals ──
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('[data-reveal]').forEach((el) => {
      revealObserver.observe(el);
    });

    // ── Section dividers ──
    document.querySelectorAll('[data-divider]').forEach((el) => {
      const obs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              setTimeout(() => (entry.target as HTMLElement).classList.add('animate-in'), 200);
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      obs.observe(el);
    });

    // ── Section heading char reveal ──
    document.querySelectorAll('[data-heading-reveal]').forEach((wrap) => {
      const heading = wrap.querySelector('.section-heading') as HTMLElement;
      if (!heading) return;
      const text = heading.textContent?.trim() || '';
      heading.innerHTML = '';
      text.split('').forEach((char, i) => {
        const span = document.createElement('span');
        span.textContent = char === ' ' ? '\u00A0' : char;
        span.classList.add('heading-char');
        span.style.transitionDelay = `${i * 0.04}s`;
        heading.appendChild(span);
      });

      const obs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              heading.classList.add('revealed');
              (entry.target as HTMLElement).classList.add('revealed');
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.2 }
      );
      obs.observe(wrap);

      // Hover bounce on heading chars
      if (window.matchMedia('(pointer: fine)').matches) {
        heading.addEventListener('mouseenter', () => {
          heading.querySelectorAll('.heading-char').forEach((ch, i) => {
            (ch as HTMLElement).style.animation = `none`;
            setTimeout(() => {
              (ch as HTMLElement).style.animation = ``;
              (ch as HTMLElement).style.transform = 'translateY(-8px)';
              setTimeout(() => {
                (ch as HTMLElement).style.transform = '';
              }, 150);
            }, i * 30);
          });
        });
      }
    });

    // ── Intro typewriter ──
    const typewriterEl = document.querySelector('#intro-typewriter .typewriter-text') as HTMLElement;
    const introStrikes = document.querySelectorAll('#intro-strikes .intro-strike');

    const introTemplate = [
      { text: 'I design and build ' },
      { text: 'fast, modern', keyword: true },
      { text: ' websites for local businesses across Sydney. Every site is ' },
      { text: 'custom-built', keyword: true },
      { text: ', SEO-optimised, and designed to ' },
      { text: 'turn visitors into customers', keyword: true },
      { text: '.' },
    ];

    let typewriterStarted = false;

    function startTypewriter() {
      if (typewriterStarted || !typewriterEl) return;
      typewriterStarted = true;

      // Build the full text with spans
      let html = '';
      introTemplate.forEach((part) => {
        if (part.keyword) {
          html += `<span class="intro-kw" data-cursor-hover>`;
          part.text.split('').forEach((ch) => {
            const sx = (Math.random() - 0.5) * 12;
            const sy = (Math.random() - 0.5) * 8;
            const sr = (Math.random() - 0.5) * 20;
            html += `<span class="kw-char" style="--sx:${sx}px;--sy:${sy}px;--sr:${sr}deg">${ch}</span>`;
          });
          html += `</span>`;
        } else {
          html += part.text;
        }
      });

      // Type it out character by character
      const fullHTML = html;
      const tempDiv = document.createElement('div');
      tempDiv.innerHTML = fullHTML;
      const fullText = tempDiv.textContent || '';

      typewriterEl.innerHTML = '';
      let charIdx = 0;
      const cursor = document.createElement('span');
      cursor.classList.add('typewriter-cursor');

      function typeNext() {
        if (charIdx >= fullText.length) {
          // Done typing, set final HTML and show strikes
          typewriterEl.innerHTML = fullHTML;
          typewriterEl.appendChild(cursor);
          // Re-bind cursor hover on keywords
          typewriterEl.querySelectorAll('[data-cursor-hover]').forEach((el) => {
            el.addEventListener('mouseenter', () => document.getElementById('cursor-circle')?.classList.add('hover'));
            el.addEventListener('mouseleave', () => document.getElementById('cursor-circle')?.classList.remove('hover'));
          });
          // Animate strikes
          setTimeout(() => {
            introStrikes.forEach((s, i) => {
              setTimeout(() => {
                s.classList.add('visible');
                if (s.classList.contains('font-medium')) {
                  setTimeout(() => s.classList.add('struck'), 400);
                }
              }, i * 120);
            });
          }, 300);
          return;
        }

        // Show plain text progressively
        const visibleText = fullText.slice(0, charIdx + 1);
        typewriterEl.textContent = visibleText;
        typewriterEl.appendChild(cursor);
        charIdx++;

        const delay = fullText[charIdx - 1] === '.' ? 120 : fullText[charIdx - 1] === ',' ? 80 : 25;
        setTimeout(typeNext, delay);
      }
      typeNext();
    }

    // Trigger typewriter on scroll
    const typeObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            startTypewriter();
            typeObs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3 }
    );
    if (typewriterEl) typeObs.observe(typewriterEl);

    // ── Manifesto word-by-word scroll reveal (setup) ──
    const manifestoData: { el: Element; wordSpans: NodeListOf<Element>; totalWords: number }[] = [];
    document.querySelectorAll('[data-manifesto]').forEach((el) => {
      const text = el.textContent?.trim() || '';
      el.innerHTML = '';
      const words = text.split(/\s+/);
      words.forEach((word, i) => {
        const span = document.createElement('span');
        span.textContent = word;
        span.classList.add('manifesto-word');
        el.appendChild(span);
        if (i < words.length - 1) el.appendChild(document.createTextNode(' '));
      });
      manifestoData.push({ el, wordSpans: el.querySelectorAll('.manifesto-word'), totalWords: words.length });
    });

    // ── Process steps (setup) ──
    const processSteps = document.querySelectorAll('.process-step');

    // ── Nav / scroll progress (setup) ──
    const scrollProgress = document.getElementById('scroll-progress');
    const navTop = document.getElementById('nav-top');
    const sections = document.querySelectorAll('section[id]');
    const navNodes = document.querySelectorAll('.nav-node[data-nav-section]');
    const navMobileLinks = document.querySelectorAll('.nav-mobile-link[data-nav-section]');
    const navRailProgress = document.getElementById('nav-rail-progress');

    // ── Skew (setup) ──
    let lastScrollY = window.scrollY;
    let scrollVelocity = 0;
    let velocityTarget = 0;
    const skewElements = document.querySelectorAll('[data-skew]');

    // ── Parallax (setup) ──
    const hasPointer = window.matchMedia('(pointer: fine)').matches;
    const parallaxElements = hasPointer ? document.querySelectorAll('[data-parallax]') : [];

    // ── Unified scroll handler (one rAF per frame) ──
    let scrollTicking = false;

    function onScrollFrame() {
      const scrollTop = window.scrollY;
      const viewH = window.innerHeight;
      const docHeight = document.documentElement.scrollHeight - viewH;
      const scrollPct = docHeight > 0 ? scrollTop / docHeight : 0;

      // Scroll progress bar
      if (scrollProgress) scrollProgress.style.width = `${scrollPct * 100}%`;

      // Nav top frosted glass
      if (scrollTop > 80) navTop?.classList.add('scrolled');
      else navTop?.classList.remove('scrolled');

      // Nav rail progress line
      if (navRailProgress) navRailProgress.style.height = `${scrollPct * 100}%`;

      // Active section detection
      let currentSection = 'hero';
      sections.forEach((section) => {
        const rect = section.getBoundingClientRect();
        if (rect.top <= 200 && rect.bottom >= 200) {
          currentSection = section.id;
        }
      });
      navNodes.forEach((node) => {
        const section = (node as HTMLElement).dataset.navSection;
        node.classList.toggle('active', section === currentSection);
      });
      navMobileLinks.forEach((link) => {
        const section = (link as HTMLElement).dataset.navSection;
        link.classList.toggle('active', section === currentSection);
      });

      // Manifesto word-by-word reveal
      manifestoData.forEach(({ el, wordSpans, totalWords }) => {
        const rect = el.getBoundingClientRect();
        const start = viewH * 0.85;
        const end = viewH * 0.15;
        const progress = Math.max(0, Math.min(1, (start - rect.top) / (start - end)));
        const litCount = Math.floor(progress * totalWords);
        wordSpans.forEach((w, i) => {
          w.classList.toggle('lit', i < litCount);
        });
      });

      // Process step highlighting
      if (processSteps.length > 0) {
        const viewCenter = viewH * 0.5;
        let closestStep: Element | null = null;
        let closestDist = Infinity;
        processSteps.forEach((step) => {
          const rect = step.getBoundingClientRect();
          const stepCenter = rect.top + rect.height / 2;
          const dist = Math.abs(stepCenter - viewCenter);
          if (dist < closestDist && rect.top < viewH && rect.bottom > 0) {
            closestDist = dist;
            closestStep = step;
          }
        });
        processSteps.forEach((step) => step.classList.toggle('active', step === closestStep));
      }

      // Scroll velocity for skew
      velocityTarget = scrollTop - lastScrollY;
      lastScrollY = scrollTop;
      scrollVelocity += (velocityTarget - scrollVelocity) * 0.1;
      if (skewElements.length > 0) {
        const skewVal = Math.max(-3, Math.min(3, scrollVelocity * 0.12));
        skewElements.forEach((el) => {
          (el as HTMLElement).style.transform = `skewY(${skewVal}deg)`;
        });
      }

      // Parallax depth layers
      if (hasPointer) {
        parallaxElements.forEach((el) => {
          const htmlEl = el as HTMLElement;
          if (htmlEl.id === 'hero-name') return;
          const speed = parseFloat(htmlEl.dataset.parallax || '0');
          const rect = el.getBoundingClientRect();
          const offset = (rect.top + rect.height / 2 - viewH / 2) * speed;
          htmlEl.style.transform = `translateY(${offset}px)`;
        });
      }

      scrollTicking = false;
    }

    window.addEventListener('scroll', () => {
      if (!scrollTicking) {
        scrollTicking = true;
        requestAnimationFrame(onScrollFrame);
      }
    }, { passive: true });

    // Run once on load
    onScrollFrame();

    // ── Mobile menu ──
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuLine1 = document.getElementById('menu-line-1');
    const menuLine2 = document.getElementById('menu-line-2');

    menuToggle?.addEventListener('click', () => {
      const isOpen = mobileMenu?.classList.contains('open');
      if (isOpen) {
        mobileMenu?.classList.remove('open');
        document.body.style.overflow = '';
        if (menuLine1) menuLine1.style.transform = '';
        if (menuLine2) menuLine2.style.transform = '';
      } else {
        mobileMenu?.classList.add('open');
        document.body.style.overflow = 'hidden';
        if (menuLine1) menuLine1.style.transform = 'translateY(3.25px) rotate(45deg)';
        if (menuLine2) menuLine2.style.transform = 'translateY(-3.25px) rotate(-45deg)';
      }
    });

    // ── Custom cursor ──
    const cursorDot = document.getElementById('cursor-dot');
    const cursorCircle = document.getElementById('cursor-circle');
    let mouseX = -100;
    let mouseY = -100;

    if (window.matchMedia('(pointer: fine)').matches && cursorDot && cursorCircle) {
      let circleX = -100, circleY = -100;
      let dotX = -100, dotY = -100;
      let mouseOnPage = true;

      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
      });

      // Build trail dots
      const trailContainer = document.getElementById('cursor-trail');
      const TRAIL_COUNT = 8;
      const trailDots: HTMLElement[] = [];
      const trailPositions = Array.from({ length: TRAIL_COUNT }, () => ({ x: -100, y: -100 }));
      if (trailContainer) {
        for (let i = 0; i < TRAIL_COUNT; i++) {
          const dot = document.createElement('div');
          dot.classList.add('cursor-trail-dot');
          dot.style.width = `${4 - i * 0.4}px`;
          dot.style.height = `${4 - i * 0.4}px`;
          trailContainer.appendChild(dot);
          trailDots.push(dot);
        }
      }

      // Single unified animation loop for dot + circle + trail
      function animateCursor() {
        dotX += (mouseX - dotX) * 0.85;
        dotY += (mouseY - dotY) * 0.85;
        cursorDot.style.transform = `translate(${dotX}px, ${dotY}px)`;

        circleX += (mouseX - circleX) * 0.12;
        circleY += (mouseY - circleY) * 0.12;
        cursorCircle.style.transform = `translate(${circleX}px, ${circleY}px)`;

        if (trailDots.length && mouseOnPage) {
          trailPositions[0].x += (mouseX - trailPositions[0].x) * 0.3;
          trailPositions[0].y += (mouseY - trailPositions[0].y) * 0.3;
          for (let i = 1; i < TRAIL_COUNT; i++) {
            trailPositions[i].x += (trailPositions[i - 1].x - trailPositions[i].x) * 0.25;
            trailPositions[i].y += (trailPositions[i - 1].y - trailPositions[i].y) * 0.25;
          }
          trailDots.forEach((dot, i) => {
            dot.style.transform = `translate(${trailPositions[i].x - 2}px, ${trailPositions[i].y - 2}px)`;
            dot.style.opacity = `${0.3 - i * 0.035}`;
          });
        }

        requestAnimationFrame(animateCursor);
      }
      animateCursor();

      document.querySelectorAll('a, button, [data-cursor-hover]').forEach((el) => {
        el.addEventListener('mouseenter', () => cursorCircle.classList.add('hover'));
        el.addEventListener('mouseleave', () => cursorCircle.classList.remove('hover'));
      });

      document.addEventListener('mouseleave', () => {
        mouseOnPage = false;
        cursorDot.style.opacity = '0';
        cursorCircle.style.opacity = '0';
        trailDots.forEach((dot) => { dot.style.opacity = '0'; });
      });
      document.addEventListener('mouseenter', () => {
        mouseOnPage = true;
        cursorDot.style.opacity = '1';
        cursorCircle.style.opacity = '0.4';
      });

      // Nav rail nodes magnetic pull toward cursor Y
      const navRailNodes = document.querySelector('.nav-rail-nodes');
      if (navRailNodes) {
        document.addEventListener('mousemove', (e) => {
          const rect = navRailNodes.getBoundingClientRect();
          const centerY = rect.top + rect.height / 2;
          const pull = (e.clientY - centerY) * 0.03;
          const clamped = Math.max(-10, Math.min(10, pull));
          (navRailNodes as HTMLElement).style.transform = `translateY(${clamped}px)`;
        });
      }
    }

    // ── Smooth image scroll on project card hover ──
    if (window.matchMedia('(pointer: fine)').matches) {
      document.querySelectorAll('.project-card-v').forEach((card) => {
        const img = card.querySelector('.project-image-inner') as HTMLImageElement;
        const container = card.querySelector('.project-image') as HTMLElement;
        if (!img || !container) return;

        let scrollPos = 0;
        let prevScrollPos = 0;
        let scrollRaf: number | null = null;
        let hovering = false;
        let currentStop = 0;
        let stopTarget = 0;
        const stops = [0, 0.25, 0.5, 0.75, 1];
        const pauseDuration = 90; // ~1.5s pause at each stop
        const initialDelay = 90; // ~1.5s delay before first move
        let pauseCounter = 0;
        let isPaused = false;
        let delayCounter = 0;
        let isDelaying = false;

        function ensureImageLoaded(cb: () => void) {
          if (img.naturalHeight > 0) { cb(); return; }
          img.addEventListener('load', cb, { once: true });
        }

        function animateScroll() {
          const maxScroll = img.offsetHeight - container.offsetHeight;
          if (maxScroll <= 0) { scrollRaf = null; return; }


          if (hovering) {
            // Initial delay before starting to scroll
            if (isDelaying) {
              delayCounter++;
              if (delayCounter >= initialDelay) {
                isDelaying = false;
              }
              img.style.transform = `translateY(${-scrollPos}px)`;
              scrollRaf = requestAnimationFrame(animateScroll);
              return;
            }

            stopTarget = stops[currentStop] * maxScroll;

            if (isPaused) {
              pauseCounter++;
              if (pauseCounter >= pauseDuration) {
                isPaused = false;
                pauseCounter = 0;
                if (currentStop < stops.length - 1) currentStop++;
              }
            } else {
              scrollPos += (stopTarget - scrollPos) * 0.04;

              if (Math.abs(scrollPos - stopTarget) < 1) {
                scrollPos = stopTarget;
                if (currentStop < stops.length - 1) {
                  isPaused = true;
                  pauseCounter = 0;
                }
              }
            }
          } else {
            scrollPos += (0 - scrollPos) * 0.05;
            if (Math.abs(scrollPos) < 0.5) {
              scrollPos = 0;
              prevScrollPos = 0;
              img.style.transform = '';
              currentStop = 0;
              isPaused = false;
              pauseCounter = 0;
              scrollRaf = null;
              return;
            }
          }

          // Motion blur based on scroll velocity
          const velocity = Math.abs(scrollPos - prevScrollPos);
          const blur = Math.min(velocity * 0.4, 6);
          prevScrollPos = scrollPos;

          img.style.transform = `translateY(${-scrollPos}px)`;
          if (blur > 0.3) {
            img.style.filter = `blur(${blur}px)`;
          }

          scrollRaf = requestAnimationFrame(animateScroll);
        }

        card.addEventListener('mouseenter', () => {
          hovering = true;
          currentStop = 1;
          isPaused = false;
          pauseCounter = 0;
          isDelaying = true;
          delayCounter = 0;
          ensureImageLoaded(() => {
            if (!scrollRaf) scrollRaf = requestAnimationFrame(animateScroll);
          });
        });

        card.addEventListener('mouseleave', () => {
          hovering = false;
          currentStop = 0;
          if (!scrollRaf) scrollRaf = requestAnimationFrame(animateScroll);
        });
      });
    }

    // ── Floating UI parallax on project cards ──
    if (window.matchMedia('(pointer: fine)').matches) {
      document.querySelectorAll('[data-parallax-container]').forEach((container) => {
        const floats = container.querySelectorAll('[data-float-depth]');
        if (!floats.length) return;

        let targetX = 0, targetY = 0;
        const currentPositions = Array.from(floats, () => ({ x: 0, y: 0 }));
        let isHovering = false;
        let rafId: number | null = null;

        function animateFloats() {
          floats.forEach((el, i) => {
            const depth = parseFloat((el as HTMLElement).dataset.floatDepth || '0.04');
            const goalX = isHovering ? targetX * depth * 600 : 0;
            const goalY = isHovering ? targetY * depth * 600 : 0;
            currentPositions[i].x += (goalX - currentPositions[i].x) * 0.08;
            currentPositions[i].y += (goalY - currentPositions[i].y) * 0.08;
            (el as HTMLElement).style.transform = `translate(${currentPositions[i].x}px, ${currentPositions[i].y}px)`;
          });

          if (!isHovering) {
            const settled = currentPositions.every(p => Math.abs(p.x) < 0.1 && Math.abs(p.y) < 0.1);
            if (settled) {
              floats.forEach((el) => { (el as HTMLElement).style.transform = ''; });
              rafId = null;
              return;
            }
          }
          rafId = requestAnimationFrame(animateFloats);
        }

        container.addEventListener('mouseenter', () => {
          isHovering = true;
          if (!rafId) rafId = requestAnimationFrame(animateFloats);
        });

        container.addEventListener('mousemove', (e: Event) => {
          const me = e as MouseEvent;
          const rect = (container as HTMLElement).getBoundingClientRect();
          targetX = (me.clientX - rect.left - rect.width / 2) / rect.width;
          targetY = (me.clientY - rect.top - rect.height / 2) / rect.height;
        });

        container.addEventListener('mouseleave', () => {
          isHovering = false;
          targetX = 0;
          targetY = 0;
          if (!rafId) rafId = requestAnimationFrame(animateFloats);
        });
      });
    }

    // ── 3D tilt on project cards ──
    if (window.matchMedia('(pointer: fine)').matches) {
      document.querySelectorAll('[data-tilt]').forEach((card) => {
        const el = card as HTMLElement;
        let targetX = 0, targetY = 0, currentX = 0, currentY = 0;
        let rafId: number | null = null;
        let isHovering = false;

        function animate() {
          currentX += (targetX - currentX) * 0.08;
          currentY += (targetY - currentY) * 0.08;
          el.style.transform = `perspective(1000px) rotateX(${currentX}deg) rotateY(${currentY}deg)`;
          if (!isHovering && Math.abs(targetX - currentX) < 0.01 && Math.abs(targetY - currentY) < 0.01) {
            el.style.transform = '';
            rafId = null;
            return;
          }
          rafId = requestAnimationFrame(animate);
        }
        function startLoop() { if (!rafId) rafId = requestAnimationFrame(animate); }

        el.addEventListener('mouseenter', () => { isHovering = true; startLoop(); });
        el.addEventListener('mousemove', (e: MouseEvent) => {
          const rect = el.getBoundingClientRect();
          targetX = ((e.clientY - rect.top - rect.height / 2) / (rect.height / 2)) * -2;
          targetY = ((e.clientX - rect.left - rect.width / 2) / (rect.width / 2)) * 2;
        });
        el.addEventListener('mouseleave', () => { isHovering = false; targetX = 0; targetY = 0; startLoop(); });
      });
    }

    // ── Magnetic effect ──
    if (window.matchMedia('(pointer: fine)').matches) {
      document.querySelectorAll('[data-magnetic]').forEach((el) => {
        const element = el as HTMLElement;
        element.addEventListener('mousemove', (e: MouseEvent) => {
          const rect = element.getBoundingClientRect();
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;
          element.style.transform = `translate(${x * 0.25}px, ${y * 0.25}px)`;
        });
        element.addEventListener('mouseleave', () => { element.style.transform = ''; });
      });
    }

    // ── Text scramble on project name — on scroll + hover ──
    if (window.matchMedia('(pointer: fine)').matches) {
      document.querySelectorAll('[data-scramble]').forEach((el) => {
        const element = el as HTMLElement;
        const originalText = element.textContent?.trim() || '';
        let intervalId: number | null = null;

        function runScramble() {
          if (intervalId) clearInterval(intervalId);
          const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ&0123456789';
          let step = 0;
          const totalSteps = 14;
          intervalId = window.setInterval(() => {
            step++;
            let result = '';
            for (let i = 0; i < originalText.length; i++) {
              if (originalText[i] === ' ' || originalText[i] === '&') result += originalText[i];
              else if (step / totalSteps > i / originalText.length) result += originalText[i];
              else result += chars[Math.floor(Math.random() * chars.length)];
            }
            element.textContent = result;
            if (step >= totalSteps) {
              clearInterval(intervalId!);
              intervalId = null;
              element.textContent = originalText;
            }
          }, 40);
        }

        // Scramble on scroll reveal
        const scrambleObs = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              runScramble();
              scrambleObs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.5 });
        scrambleObs.observe(element);

        // Also on hover
        element.addEventListener('mouseenter', runScramble);
        element.addEventListener('mouseleave', () => {
          if (intervalId) { clearInterval(intervalId); intervalId = null; }
          element.textContent = originalText;
        });
      });
    }

    // ── Contact section scroll animations ──
    // Prompt typewriter
    const contactPrompt = document.querySelector('[data-contact-prompt]') as HTMLElement;
    if (contactPrompt) {
      const promptText = contactPrompt.innerHTML;
      contactPrompt.innerHTML = '';
      contactPrompt.style.opacity = '1';
      let promptStarted = false;

      const promptObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !promptStarted) {
            promptStarted = true;
            // Strip HTML to get plain text, then type it back with HTML
            const tempDiv = document.createElement('div');
            tempDiv.innerHTML = promptText;
            const plainText = tempDiv.textContent || '';
            let idx = 0;
            const cursor = document.createElement('span');
            cursor.classList.add('typewriter-cursor');

            function typePrompt() {
              if (idx >= plainText.length) {
                contactPrompt.innerHTML = promptText;
                contactPrompt.classList.add('revealed');
                // Trigger the line draw
                setTimeout(() => {
                  document.querySelector('[data-contact-line]')?.classList.add('drawn');
                }, 200);
                // Trigger the card
                setTimeout(() => {
                  document.querySelector('[data-contact-card]')?.classList.add('revealed');
                }, 600);
                // Trigger fields staggered
                setTimeout(() => {
                  document.querySelectorAll('[data-contact-field]').forEach((f, i) => {
                    setTimeout(() => f.classList.add('revealed'), i * 100);
                  });
                }, 900);
                // Trigger send button
                setTimeout(() => {
                  document.querySelector('[data-contact-send]')?.classList.add('revealed');
                }, 1400);
                // Trigger info items
                setTimeout(() => {
                  document.querySelectorAll('[data-contact-info]').forEach((item, i) => {
                    setTimeout(() => item.classList.add('revealed'), i * 150);
                  });
                }, 1600);
                return;
              }
              contactPrompt.textContent = plainText.slice(0, idx + 1);
              contactPrompt.appendChild(cursor);
              idx++;
              const ch = plainText[idx - 1];
              const delay = ch === '?' ? 200 : ch === ' ' ? 40 : 30;
              setTimeout(typePrompt, delay);
            }
            typePrompt();
            promptObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });
      promptObs.observe(contactPrompt);
    }

    // Rotating conic gradient on form card
    const contactCard = document.querySelector('[data-contact-card]') as HTMLElement;
    if (contactCard) {
      let angle = 0;
      function rotateGradient() {
        angle = (angle + 0.5) % 360;
        contactCard.style.setProperty('--contact-angle', `${angle}deg`);
        requestAnimationFrame(rotateGradient);
      }
      rotateGradient();
    }

    // ── Contact form submit ──
    const formEl = document.getElementById('contact-form') as HTMLFormElement;
    const formSuccess = document.getElementById('form-success');
    const formError = document.getElementById('form-error');

    formEl?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(formEl);
      try {
        const response = await fetch(formEl.action, {
          method: 'POST',
          body: formData,
          headers: { Accept: 'application/json' },
        });
        if (response.ok) {
          formEl.style.display = 'none';
          formSuccess?.classList.remove('hidden');
        } else {
          formError?.classList.remove('hidden');
        }
      } catch {
        formError?.classList.remove('hidden');
      }
    });

    // ── About section scroll animations ──

    // About blocks — fade up on scroll
    document.querySelectorAll('[data-about-block]').forEach((el) => {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            obs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2 });
      obs.observe(el);
    });

    // Stat counters — count up on scroll
    document.querySelectorAll('[data-stat]').forEach((el) => {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            const target = parseInt((entry.target as HTMLElement).dataset.statTarget || '0');
            const suffix = (entry.target as HTMLElement).dataset.statSuffix || '';
            const numEl = entry.target.querySelector('[data-stat-number]') as HTMLElement;
            if (numEl) {
              let current = 0;
              const duration = 1200;
              const start = performance.now();
              function countUp(now: number) {
                const elapsed = now - start;
                const progress = Math.min(elapsed / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                current = Math.round(eased * target);
                numEl.textContent = `${current}${suffix}`;
                if (progress < 1) requestAnimationFrame(countUp);
              }
              requestAnimationFrame(countUp);
            }
            obs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });
      obs.observe(el);
    });

    // Approach items — staggered slide-in
    document.querySelectorAll('[data-approach]').forEach((el, i) => {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            setTimeout(() => entry.target.classList.add('revealed'), i * 120);
            obs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2 });
      obs.observe(el);
    });

    // Skill pills — staggered pop-in
    const pillContainer = document.querySelector('[data-skill-pills]');
    if (pillContainer) {
      const pillObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const pills = entry.target.querySelectorAll('.skill-pill');
            pills.forEach((pill, i) => {
              setTimeout(() => pill.classList.add('revealed'), i * 50);
            });
            pillObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2 });
      pillObs.observe(pillContainer);
    }

    // ── Dark mode toggle ──
    function toggleTheme(button: HTMLElement) {
      const overlay = document.getElementById('theme-transition');
      if (!overlay) return;
      const rect = button.getBoundingClientRect();
      const x = rect.left + rect.width / 2;
      const y = rect.top + rect.height / 2;
      const maxRadius = Math.ceil(Math.sqrt(
        Math.max(x, window.innerWidth - x) ** 2 +
        Math.max(y, window.innerHeight - y) ** 2
      ));
      const isDark = document.documentElement.dataset.theme === 'dark';
      const newTheme = isDark ? 'light' : 'dark';
      const newBg = newTheme === 'dark' ? '#0A0A0A' : '#FAFAFA';
      overlay.style.backgroundColor = newBg;
      overlay.style.transition = 'none';
      overlay.style.clipPath = `circle(0px at ${x}px ${y}px)`;
      overlay.offsetHeight;
      const duration = 900;
      const startTime = performance.now();
      function animateBlob(now: number) {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const eased = progress < 0.5 ? 4 * progress ** 3 : 1 - Math.pow(-2 * progress + 2, 3) / 2;
        const radius = eased * maxRadius;
        const w1 = Math.sin(progress * Math.PI * 3) * radius * 0.08;
        const w2 = Math.cos(progress * Math.PI * 2) * radius * 0.06;
        overlay.style.clipPath = `ellipse(${radius + w1}px ${radius + w2}px at ${x}px ${y}px)`;
        if (progress < 1) requestAnimationFrame(animateBlob);
        else overlay.style.clipPath = 'circle(0px at 50% 50%)';
      }
      requestAnimationFrame(animateBlob);
      setTimeout(() => {
        document.documentElement.dataset.theme = newTheme;
        localStorage.setItem('theme', newTheme);
        updateThemeIcons(newTheme);
      }, duration * 0.4);
    }

    function updateThemeIcons(theme: string) {
      const isDark = theme === 'dark';
      // Update all moon/sun icons (both rail and mobile)
      document.querySelectorAll('.icon-moon, #icon-moon').forEach((el) => {
        (el as HTMLElement).style.display = isDark ? 'none' : 'block';
      });
      document.querySelectorAll('.icon-sun, #icon-sun').forEach((el) => {
        (el as HTMLElement).style.display = isDark ? 'block' : 'none';
      });
    }

    updateThemeIcons(document.documentElement.dataset.theme || 'light');

    // Both theme toggles (rail + mobile)
    document.getElementById('theme-toggle')?.addEventListener('click', (e) => {
      toggleTheme(e.currentTarget as HTMLElement);
    });
    document.getElementById('theme-toggle-mobile')?.addEventListener('click', (e) => {
      toggleTheme(e.currentTarget as HTMLElement);
    });

    // ── Live Sydney time + analog clock ──
    const clockHour = document.getElementById('clock-hour');
    const clockMinute = document.getElementById('clock-minute');
    const clockSecond = document.getElementById('clock-second');

    function updateSydneyTime() {
      const el = document.getElementById('sydney-time');
      const now = new Date();
      const sydneyStr = now.toLocaleString('en-AU', { timeZone: 'Australia/Sydney' });
      const sydneyDate = new Date(sydneyStr);
      const h = sydneyDate.getHours();
      const m = sydneyDate.getMinutes();
      const s = sydneyDate.getSeconds();
      if (el) el.textContent = `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
      const hourDeg = ((h % 12) / 12) * 360 + (m / 60) * 30;
      const minDeg = (m / 60) * 360 + (s / 60) * 6;
      const secDeg = (s / 60) * 360;
      if (clockHour) clockHour.style.transform = `translateX(-50%) rotate(${hourDeg}deg)`;
      if (clockMinute) clockMinute.style.transform = `translateX(-50%) rotate(${minDeg}deg)`;
      if (clockSecond) clockSecond.style.transform = `translateX(-50%) rotate(${secDeg}deg)`;
    }
    updateSydneyTime();
    setInterval(updateSydneyTime, 1000);
  </script>
</Layout>
