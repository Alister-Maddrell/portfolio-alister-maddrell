  <script>
    /* ═══════════════════════════════════════════════════════════════════════════
     * ANIMATION ENGINE
     * ═══════════════════════════════════════════════════════════════════════════
     * Single-file animation system for the portfolio site. Architecture:
     *
     * 1. UTILITIES        — Shared easing, observer factories, DOM helpers
     * 2. STATE             — Global animation state (scroll, velocity, theme)
     * 3. DATA STRUCTURES   — Parsed element collections (floats, cards, depths)
     * 4. OBSERVERS         — Consolidated IntersectionObservers (visibility + reveal)
     * 5. MAIN RAF LOOP     — Single requestAnimationFrame driving all scroll animations
     * 6. HERO              — Typewriter, dot grid canvas, hero float/reveal
     * 7. INTERACTIONS      — Cursor, magnetic, tilt, scramble, card hover scroll
     * 8. CONTACT           — Marquee, split reveal, form submit
     * 9. THEME             — 3-way theme switcher with blob transition
     * 10. CLOCK            — Live Sydney time in footer
     *
     * Performance notes:
     * - All getBoundingClientRect() reads are batched before any style writes
     * - Expensive reads gated behind scroll-change threshold (0.5px)
     * - Canvas dot grid throttled to ~30fps via frame skipping
     * - IntersectionObservers gate all per-element work to visible elements only
     * - content-visibility: auto in CSS skips paint for off-screen sections
     * ═══════════════════════════════════════════════════════════════════════════ */

    // ── 1. UTILITIES ──

    /** Attempt-smoothstep easing: t² × (3 - 2t). Used for all reveal animations. */
    function smoothstep(t: number): number {
      return t * t * (3 - 2 * t);
    }

    /** Clamped smoothstep with delay and duration. Progress-based reveal easing. */
    function easedReveal(elapsed: number, delay: number, duration = 2000): number {
      const raw = Math.min(1, Math.max(0, (elapsed - delay) / duration));
      return smoothstep(raw);
    }

    // ── 2. STATE ──

    let lastScrollY = window.scrollY;
    let scrollVelocity = 0;
    const hasFineCursor = window.matchMedia('(pointer: fine)').matches;
    const grainOverlay = document.querySelector('.grain-overlay') as HTMLElement | null;
    const grainBase = document.documentElement.dataset.theme === 'dark' ? 0.1 : 0.06;
    const skewElements = document.querySelectorAll('[data-skew]');

    // ── 3. DATA STRUCTURES — parsed element collections ──

    // Skew visibility — only transform elements in viewport
    const skewVisible = new Set<Element>();
    if (skewElements.length > 0) {
      const skewVis = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) skewVisible.add(entry.target);
          else skewVisible.delete(entry.target);
        });
      }, { threshold: 0, rootMargin: '50px 0px 50px 0px' });
      skewElements.forEach((el) => skewVis.observe(el));
    }

    // Float elements: parsed once, animated in standalone rAF via composed style.transform
    interface FloatItem {
      el: HTMLElement;
      speed: number;
      amp: number;
      phase: number;
      visible: boolean;
      hasSkew: boolean;
      hasTilt: boolean;
      currentY: number;
      // Tilt state (merged into main loop to avoid competing transforms)
      tiltHovering: boolean;
      tiltTargetX: number;
      tiltTargetY: number;
      tiltCurrentX: number;
      tiltCurrentY: number;
      // Zero-G: horizontal drift + subtle rotation
      xPhase: number;
      rotPhase: number;
      xAmp: number;
      rotAmp: number;
      xSpeed: number;
      rotSpeed: number;
      // Reveal composition — external systems set these, float loop composes them
      revealOpacity: number;
      revealX: number;
      revealY: number;
    }
    const floatItems: FloatItem[] = [];
    document.querySelectorAll('[data-float]').forEach((el) => {
      const htmlEl = el as HTMLElement;
      const seed = parseInt(htmlEl.dataset.float || '1');
      floatItems.push({
        el: htmlEl,
        speed: 0.0005 + (seed % 5) * 0.00008,
        amp: 6 + (seed % 4) * 2,
        phase: seed * 1.7,
        visible: false,
        hasSkew: htmlEl.hasAttribute('data-skew'),
        hasTilt: htmlEl.hasAttribute('data-tilt'),
        currentY: 0,
        tiltHovering: false,
        tiltTargetX: 0,
        tiltTargetY: 0,
        tiltCurrentX: 0,
        tiltCurrentY: 0,
        // Zero-G: each element drifts on its own orbit
        xPhase: seed * 2.3 + 0.5,
        rotPhase: seed * 3.1 + 1.2,
        xAmp: 3 + (seed % 3) * 1.5,          // 3-7.5px horizontal drift
        rotAmp: 0.3 + (seed % 4) * 0.15,      // 0.3-0.75° rotation
        xSpeed: 0.0003 + (seed % 6) * 0.00005, // slightly different from Y
        rotSpeed: 0.0002 + (seed % 7) * 0.00003,
        // Reveal composition defaults (fully visible, no offset)
        revealOpacity: 1,
        revealX: 0,
        revealY: 0,
      });
    });

    // IntersectionObserver for float visibility
    if (floatItems.length > 0) {
      const floatVis = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const item = floatItems.find(f => f.el === entry.target);
          if (item) item.visible = entry.isIntersecting;
        });
      }, { threshold: 0.05 });
      floatItems.forEach(f => floatVis.observe(f.el));
    }

    const animStart = performance.now();

    // ── 5. MAIN RAF LOOP — single requestAnimationFrame for all scroll-driven animations ──
    let _lastRenderedScroll = -1;
    // Persistent rect caches (only updated when scroll changes)
    let _cr: { t: number; h: number }[] = [];
    let _br: { t: number; b: number; h: number }[] = [];
    let _dr: { t: number; h: number }[] = [];
    let _sr: { t: number; b: number; h: number }[] = [];
    let _mr: { t: number }[] = [];
    let _pr: { t: number; b: number; h: number }[] = [];
    let _pxr = new Map<Element, { t: number; h: number }>();
    let _contactTop = 0;
    let _contactVisible = false;

    function raf(time: number) {
      const t = time - animStart;
      const viewH = window.innerHeight;
      const currentScrollY = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - viewH;
      const scrollPct = docHeight > 0 ? currentScrollY / docHeight : 0;
      const skewVal = Math.max(-3, Math.min(3, scrollVelocity * 0.12));
      const isMobileDevice = !hasFineCursor;

      // Track scroll velocity
      const delta = currentScrollY - lastScrollY;
      lastScrollY = currentScrollY;
      scrollVelocity += (delta - scrollVelocity) * 0.15;
      if (Math.abs(scrollVelocity) < 0.01) scrollVelocity = 0;

      // Only do expensive reads when scroll position actually changed
      const scrollChanged = Math.abs(currentScrollY - _lastRenderedScroll) > 0.5;
      if (scrollChanged) {
        _lastRenderedScroll = currentScrollY;

        // ═══ BATCH READS (only on scroll change) ═══
        _cr = [];
        for (let i = 0; i < cardLayers.length; i++) {
          if (cardLayers[i].visible) {
            const r = cardLayers[i].card.getBoundingClientRect();
            _cr.push({ t: r.top, h: r.height });
          } else { _cr.push({ t: 0, h: 0 }); }
        }

        _br = [];
        for (let i = 0; i < bgParallaxEls.length; i++) {
          const r = bgParallaxEls[i].parentElement!.getBoundingClientRect();
          _br.push({ t: r.top, b: r.bottom, h: r.height });
        }

        _dr = [];
        for (let i = 0; i < depthLayers.length; i++) {
          if (depthLayers[i].visible) {
            const r = depthLayers[i].container.getBoundingClientRect();
            _dr.push({ t: r.top, h: r.height });
          } else { _dr.push({ t: 0, h: 0 }); }
        }

        _sr = [];
        for (let i = 0; i < sectionDepthEls.length; i++) {
          if (sectionDepthEls[i].section) {
            const r = sectionDepthEls[i].section!.getBoundingClientRect();
            _sr.push({ t: r.top, b: r.bottom, h: r.height });
          } else { _sr.push({ t: 0, b: 0, h: 0 }); }
        }

        _contactTop = 0; _contactVisible = false;
        if (contactSection) {
          const r = contactSection.getBoundingClientRect();
          _contactTop = r.top;
          _contactVisible = r.top < viewH;
        }

        _mr = [];
        for (let i = 0; i < manifestoData.length; i++) {
          if (manifestoVisible.get(manifestoData[i].el)) {
            const r = (manifestoData[i].el as HTMLElement).getBoundingClientRect();
            _mr.push({ t: r.top });
          } else { _mr.push({ t: 0 }); }
        }

        _pr = [];
        if (processSteps.length > 0 && processTimeline && processVisible) {
          for (let i = 0; i < processSteps.length; i++) {
            const r = (processSteps[i] as HTMLElement).getBoundingClientRect();
            _pr.push({ t: r.top, b: r.bottom, h: r.height });
          }
        }

        _pxr = new Map();
        if (hasPointer) {
          parallaxVisible.forEach(el => {
            const r = el.getBoundingClientRect();
            _pxr.set(el, { t: r.top, h: r.height });
          });
        }

        // ═══ SCROLL-DEPENDENT WRITES ═══
        if (scrollProgress) scrollProgress.style.width = `${scrollPct * 100}%`;

        if (heroScrollFade) {
          const fadeEnd = viewH * 0.6;
          const fadeProg = Math.min(1, Math.max(0, currentScrollY / fadeEnd));
          heroScrollFade.style.opacity = String(1 - fadeProg);
          heroScrollFade.style.transform = `translate3d(0, ${fadeProg * -40}px, 0)`;
        }

        const shouldScrollNav = currentScrollY > 80;
        if (shouldScrollNav !== navTop?.classList.contains('scrolled')) {
          navTop?.classList.toggle('scrolled', shouldScrollNav);
        }

        if (navRailProgress) navRailProgress.style.height = `${scrollPct * 100}%`;

        if (currentSection !== lastActiveSection) {
          lastActiveSection = currentSection;
          navNodes.forEach(node => { node.classList.toggle('active', (node as HTMLElement).dataset.navSection === currentSection); });
          navMobileLinks.forEach(link => { link.classList.toggle('active', (link as HTMLElement).dataset.navSection === currentSection); });
        }

        // Manifesto word reveal
        for (let mi = 0; mi < manifestoData.length; mi++) {
          if (!manifestoVisible.get(manifestoData[mi].el)) continue;
          const mrt = _mr[mi].t;
          const mStart = viewH * 0.85;
          const mEnd = viewH * 0.15;
          const mProg = Math.max(0, Math.min(1, (mStart - mrt) / (mStart - mEnd)));
          const litCount = Math.floor(mProg * manifestoData[mi].totalWords);
          manifestoData[mi].wordSpans.forEach((w, j) => { w.classList.toggle('lit', j < litCount); });
        }

        // Process step highlighting
        if (_pr.length > 0) {
          const viewCenter = viewH * 0.5;
          let closestStep: Element | null = null;
          let closestDist = Infinity;
          let activeIndex = 0;
          processSteps.forEach((step, si) => {
            const sr = _pr[si];
            const stepCenter = sr.t + sr.h / 2;
            const dist = Math.abs(stepCenter - viewCenter);
            if (dist < closestDist && sr.t < viewH && sr.b > 0) {
              closestDist = dist; closestStep = step; activeIndex = si;
            }
          });
          processSteps.forEach(step => step.classList.toggle('active', step === closestStep));
          if (processRailFill) processRailFill.style.transform = `scaleY(${(activeIndex + 1) / processSteps.length})`;
        }

        // Parallax depth layers
        if (hasPointer) {
          _pxr.forEach((pr, el) => {
            const htmlEl = el as HTMLElement;
            if (htmlEl.id === 'hero-name') return;
            const speed = parseFloat(htmlEl.dataset.parallax || '0');
            const offset = (pr.t + pr.h / 2 - viewH / 2) * speed;
            htmlEl.style.transform = `translate3d(0, ${offset}px, 0)`;
          });
        }
      } // end scrollChanged

      // ── Skew ──
      if (skewVal !== 0) {
        for (let i = 0; i < skewElements.length; i++) {
          const el = skewElements[i] as HTMLElement;
          if (el.hasAttribute('data-float')) continue;
          if (!skewVisible.has(el)) continue;
          el.style.transform = `skewY(${skewVal}deg)`;
        }
      }

      // ── Grain ──
      if (grainOverlay) {
        grainOverlay.style.opacity = String(grainBase + Math.min(0.06, Math.abs(scrollVelocity) * 0.004));
      }

      // ── Float items (translate3d forces GPU compositing) ──
      for (let i = 0; i < floatItems.length; i++) {
        const f = floatItems[i];
        if (!f.visible) continue;
        const y = Math.sin(t * f.speed + f.phase) * f.amp
                + Math.sin(t * f.speed * 0.7 + f.phase + 1.5) * (f.amp * 0.35);
        f.currentY = y;
        const x = Math.sin(t * f.xSpeed + f.xPhase) * f.xAmp
                + Math.sin(t * f.xSpeed * 1.3 + f.xPhase + 2.0) * (f.xAmp * 0.25);
        const rot = Math.sin(t * f.rotSpeed + f.rotPhase) * f.rotAmp
                  + Math.sin(t * f.rotSpeed * 0.6 + f.rotPhase + 1.0) * (f.rotAmp * 0.4);
        const tx = x + f.revealX;
        const ty = y + f.revealY;
        if (f.revealOpacity < 1) f.el.style.opacity = `${f.revealOpacity}`;
        if (f.hasTilt) {
          f.tiltCurrentX += (f.tiltTargetX - f.tiltCurrentX) * 0.08;
          f.tiltCurrentY += (f.tiltTargetY - f.tiltCurrentY) * 0.08;
          if (!f.tiltHovering && Math.abs(f.tiltCurrentX) < 0.01 && Math.abs(f.tiltCurrentY) < 0.01) {
            f.tiltCurrentX = 0; f.tiltCurrentY = 0;
          }
          if (f.tiltCurrentX !== 0 || f.tiltCurrentY !== 0) {
            f.el.style.transform = `perspective(1000px) rotateX(${f.tiltCurrentX}deg) rotateY(${f.tiltCurrentY}deg) translate3d(${tx}px, ${ty}px, 0) rotate(${rot}deg)`;
          } else if (f.hasSkew) {
            f.el.style.transform = `translate3d(${tx}px, ${ty}px, 0) rotate(${rot}deg) skewY(${skewVal}deg)`;
          } else {
            f.el.style.transform = `translate3d(${tx}px, ${ty}px, 0) rotate(${rot}deg)`;
          }
        } else if (f.hasSkew) {
          f.el.style.transform = `translate3d(${tx}px, ${ty}px, 0) rotate(${rot}deg) skewY(${skewVal}deg)`;
        } else {
          f.el.style.transform = `translate3d(${tx}px, ${ty}px, 0) rotate(${rot}deg)`;
        }
      }

      // ── Card layer parallax (translate3d for GPU compositing) ──
      for (let i = 0; i < cardLayers.length; i++) {
        const cl = cardLayers[i];
        if (!cl.visible) continue;
        const progress = 1 - (_cr[i].t + _cr[i].h / 2) / (viewH + _cr[i].h);
        const offset = (progress - 0.5) * 2;
        const targetHX = cl.hovering ? cl.hoverX : 0;
        const targetHY = cl.hovering ? cl.hoverY : 0;
        cl.currentHoverX += (targetHX - cl.currentHoverX) * 0.06;
        cl.currentHoverY += (targetHY - cl.currentHoverY) * 0.06;
        const mob = isMobileDevice;
        cl.indexEl.style.transform = `translate3d(${(mob ? offset * 8 : 0) + cl.currentHoverX * -25 + Math.sin(t * 0.00013 + i * 3.7) * 5}px, ${offset * (mob ? -50 : -35) + cl.currentHoverY * -20 + Math.sin(t * 0.00018 + i * 2.1) * 4}px, 0) rotate(${Math.sin(t * 0.00009 + i * 5.4) * 0.6}deg)`;
        cl.blockEl.style.transform = `translate3d(${offset * (mob ? -10 : -6) + cl.currentHoverX * 15 + Math.sin(t * 0.00016 + i * 4.3 + 1.0) * 4}px, ${offset * (mob ? 25 : 18) + cl.currentHoverY * 12 + Math.sin(t * 0.00021 + i * 1.6 + 2.0) * 3}px, 0) rotate(${Math.sin(t * 0.00011 + i * 6.8 + 0.5) * 0.35}deg)`;
        if (cl.strokeEl) {
          cl.strokeEl.style.transform = `translate3d(${(mob ? offset * 12 : 0) + cl.currentHoverX * -35 + Math.sin(t * 0.0001 + i * 2.9) * 7}px, ${offset * (mob ? -65 : -48) + cl.currentHoverY * -28 + Math.sin(t * 0.00014 + i * 1.5) * 5}px, 0) rotate(${Math.sin(t * 0.00007 + i * 4.8) * 0.8}deg)`;
        }
        if (cl.lineEl) {
          cl.lineEl.style.transform = `translate3d(${offset * (mob ? 6 : 4) + Math.sin(t * 0.00019 + i * 5.2 + 1.5) * 3 + cl.currentHoverX * 8}px, ${offset * (mob ? 12 : 8)}px, 0)`;
        }
        if (cl.labelEl) {
          cl.labelEl.style.transform = `translate3d(${cl.currentHoverX * -12 + Math.sin(t * 0.00015 + i * 3.1 + 2.5) * 4}px, ${offset * (mob ? -28 : -20) + cl.currentHoverY * -10 + Math.sin(t * 0.0002 + i * 2.4 + 1.8) * 3}px, 0)`;
        }
      }

      // ── Bg text parallax (translate3d for GPU) ──
      for (let i = 0; i < bgParallaxEls.length; i++) {
        if (_br[i].b < -50 || _br[i].t > viewH + 50) continue;
        const progress = 1 - (_br[i].t + _br[i].h / 2) / (viewH + _br[i].h);
        const offset = (progress - 0.5) * 2;
        bgParallaxEls[i].style.transform = `translate3d(${Math.sin(t * 0.00015 + i * 2.5) * 8}px, ${offset * -40 + Math.sin(t * 0.0002 + i * 1.8) * 5}px, 0) rotate(${Math.sin(t * 0.0001 + i * 3.2) * 0.4}deg)`;
      }

      // ── Depth layer parallax (translate3d for GPU) ──
      for (let i = 0; i < depthLayers.length; i++) {
        const dl = depthLayers[i];
        if (!dl.visible) continue;
        const progress = 1 - (_dr[i].t + _dr[i].h / 2) / (viewH + _dr[i].h);
        const offset = (progress - 0.5) * 2;
        const m = hasFineCursor ? 1 : 1.4;
        if (dl.deepEl) {
          dl.deepEl.style.transform = `translate3d(${Math.sin(t * 0.00018 + i * 4.1) * 6}px, ${offset * -30 * m + Math.sin(t * 0.00025 + i * 2.7) * 4}px, 0) rotate(${Math.sin(t * 0.00012 + i * 5.3) * 0.5}deg)`;
        }
        if (dl.midEl) {
          dl.midEl.style.transform = `translate3d(${offset * -5 * m + Math.sin(t * 0.00022 + i * 3.4 + 1.0) * 5}px, ${offset * 15 * m + Math.sin(t * 0.00016 + i * 1.9 + 2.0) * 3}px, 0) rotate(${Math.sin(t * 0.00014 + i * 6.1 + 0.5) * 0.35}deg)`;
        }
      }

      // ── Hero layer parallax (translate3d, skip when hero off-screen) ──
      if (currentScrollY < viewH * 1.5) {
        const heroProgress = Math.min(1, currentScrollY / viewH);
        if (heroLayerOrb) {
          heroLayerOrb.style.transform = `translate3d(calc(10% + ${Math.sin(t * 0.00008 + 1.0) * 12}px), ${heroProgress * 60 + Math.sin(t * 0.00012 + 2.5) * 8}px, 0)`;
        }
        if (heroLayerWatermark) {
          heroLayerWatermark.style.transform = `translate3d(${Math.sin(t * 0.00010 + 3.0) * 6}px, ${heroProgress * -30 + Math.sin(t * 0.00014 + 0.7) * 4}px, 0) rotate(${Math.sin(t * 0.00007 + 5.0) * 0.3}deg)`;
        }
        if (heroLayerGrid) heroLayerGrid.style.transform = `translate3d(0, ${heroProgress * -15}px, 0)`;
        if (heroLayerYear) {
          heroLayerYear.style.transform = `translate3d(${Math.sin(t * 0.00013 + 4.2) * 8}px, ${heroProgress * -45 + Math.sin(t * 0.00018 + 1.3) * 5}px, 0) rotate(${Math.sin(t * 0.00009 + 6.7) * 0.6}deg)`;
        }
        if (heroLayerBar) heroLayerBar.style.transform = `translate3d(${Math.sin(t * 0.00015 + 2.1) * 4}px, ${heroProgress * 25}px, 0)`;
        if (heroLayerRing) {
          heroLayerRing.style.transform = `translate3d(${heroProgress * -10 + Math.sin(t * 0.00011 + 5.5) * 10}px, ${heroProgress * 35 + Math.sin(t * 0.00016 + 3.8) * 7}px, 0) rotate(${Math.sin(t * 0.00008 + 1.6) * 0.8}deg)`;
        }
        if (heroLayerIndex) {
          heroLayerIndex.style.transform = `translate3d(${Math.sin(t * 0.00012 + 7.0) * 5}px, ${heroProgress * -40 + Math.sin(t * 0.00017 + 4.4) * 4}px, 0) rotate(${Math.sin(t * 0.00010 + 2.9) * 0.4}deg)`;
        }
        if (heroLayerTitleBlock) {
          heroLayerTitleBlock.style.transform = `translate3d(${heroProgress * 15 + Math.sin(t * 0.00014 + 8.2) * 4}px, ${heroProgress * 20 + Math.sin(t * 0.00019 + 5.6) * 3}px, 0) rotate(${Math.sin(t * 0.00011 + 3.3) * 0.25}deg)`;
        }
        if (heroLayerTitleLine) {
          heroLayerTitleLine.style.transform = `scaleX(1) translate3d(0, ${heroProgress * 8}px, 0)`;
          heroLayerTitleLine.style.transformOrigin = 'left';
        }
        if (heroLayerDataLine) {
          heroLayerDataLine.style.transform = `translate3d(0, ${heroProgress * 12 + Math.sin(t * 0.00009 + 9.1) * 3}px, 0)`;
        }
        heroLayerCorners.forEach(c => { c.style.transform = `translate3d(0, ${heroProgress * 20}px, 0)`; });
        heroLayerCoords.forEach(c => { c.style.transform = `translate3d(0, ${heroProgress * -12}px, 0)`; });
      }

      // Contact bg layers (using pre-read rect)
      if (contactBgNum && _contactVisible) {
        const cp = 1 - _contactTop / viewH;
        contactBgNum.style.transform = `translate3d(0, ${cp * -40}px, 0)`;
        if (contactBgRing) contactBgRing.style.transform = `translate3d(${cp * 15}px, ${cp * -25}px, 0)`;
      }

      // Section depth layers (translate3d for GPU)
      for (let si = 0; si < sectionDepthEls.length; si++) {
        const sd = sectionDepthEls[si];
        if (!sd.section) continue;
        if (_sr[si].b < -100 || _sr[si].t > viewH + 100) continue;
        const sp = 1 - (_sr[si].t + _sr[si].h / 2) / (viewH + _sr[si].h);
        const so = (sp - 0.5) * 2;
        for (let ei = 0; ei < sd.els.length; ei++) {
          sd.els[ei].el.style.transform = `translate3d(${so * sd.els[ei].tx}px, ${so * sd.els[ei].ty}px, 0)`;
        }
      }

      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);

    // ── 4. OBSERVERS + ELEMENT SETUP (below main rAF, referenced by hoisting) ──

    // ── Section bg text parallax setup ──
    const bgParallaxEls = Array.from(document.querySelectorAll('[data-bg-parallax]')) as HTMLElement[];

    // ── Hero layer parallax setup ──
    const heroLayerOrb = document.querySelector('[data-hero-layer="orb"]') as HTMLElement | null;
    const heroLayerWatermark = document.querySelector('[data-hero-layer="watermark"]') as HTMLElement | null;
    const heroLayerGrid = document.querySelector('[data-hero-layer="grid"]') as HTMLElement | null;
    const heroLayerYear = document.querySelector('[data-hero-layer="year"]') as HTMLElement | null;
    const heroLayerBar = document.querySelector('[data-hero-layer="bar"]') as HTMLElement | null;
    const heroLayerRing = document.querySelector('[data-hero-layer="ring"]') as HTMLElement | null;
    const heroLayerCorners = Array.from(document.querySelectorAll('[data-hero-layer="corner"]')) as HTMLElement[];
    const heroLayerCoords = Array.from(document.querySelectorAll('[data-hero-layer="coord"]')) as HTMLElement[];
    const heroLayerIndex = document.querySelector('[data-hero-layer="index"]') as HTMLElement | null;
    const heroLayerTitleBlock = document.querySelector('[data-hero-layer="title-block"]') as HTMLElement | null;
    const heroLayerTitleLine = document.querySelector('[data-hero-layer="title-line"]') as HTMLElement | null;
    const heroLayerDataLine = document.querySelector('[data-hero-layer="data-line"]') as HTMLElement | null;
    const contactBgNum = document.querySelector('[data-hero-layer="contact-num"]') as HTMLElement | null;
    const contactBgRing = document.querySelector('[data-hero-layer="contact-ring"]') as HTMLElement | null;
    const contactSection = document.getElementById('contact');
    // Section-level depth layer config: { section, els: [{ el, tx, ty }] }
    interface SectionDepthConfig {
      section: HTMLElement | null;
      els: { el: HTMLElement; tx: number; ty: number }[];
    }
    const sectionDepthEls: SectionDepthConfig[] = [];

    function addSectionDepth(sectionId: string, entries: { selector: string; tx: number; ty: number }[]) {
      const section = document.getElementById(sectionId);
      if (!section) return;
      const els: { el: HTMLElement; tx: number; ty: number }[] = [];
      entries.forEach(e => {
        const el = section.querySelector(e.selector) as HTMLElement | null;
        if (el) els.push({ el, tx: e.tx, ty: e.ty });
      });
      if (els.length) sectionDepthEls.push({ section, els });
    }

    addSectionDepth('work', [
      { selector: '.work-depth-number', tx: 0, ty: -50 },
      { selector: '.work-depth-line', tx: 0, ty: 30 },
      { selector: '.work-depth-ring', tx: -8, ty: 25 },
      { selector: '.work-depth-crosshair', tx: 5, ty: -35 },
      { selector: '.work-depth-rule', tx: -3, ty: 18 },
      { selector: '.work-depth-coord', tx: 6, ty: -40 },
      { selector: '.work-depth-diagonal', tx: -4, ty: -55 },
      { selector: '.work-depth-dot--1', tx: 3, ty: 20 },
      { selector: '.work-depth-dot--2', tx: -5, ty: -30 },
      { selector: '.work-depth-dot--3', tx: 4, ty: 15 },
    ]);
    addSectionDepth('process', [
      { selector: '.process-depth-number', tx: 0, ty: -45 },
      { selector: '.process-depth-ring', tx: 10, ty: -20 },
    ]);
    addSectionDepth('about', [
      { selector: '.about-depth-number', tx: 0, ty: -50 },
      { selector: '.about-depth-line', tx: 0, ty: 28 },
      { selector: '.about-depth-ring', tx: -6, ty: 22 },
    ]);

    // ── Card layer parallax setup ──
    interface CardLayer {
      card: HTMLElement;
      indexEl: HTMLElement;
      blockEl: HTMLElement;
      strokeEl: HTMLElement | null;
      lineEl: HTMLElement | null;
      labelEl: HTMLElement | null;
      visible: boolean;
      hoverX: number;
      hoverY: number;
      currentHoverX: number;
      currentHoverY: number;
      hovering: boolean;
    }
    const cardLayers: CardLayer[] = [];
    document.querySelectorAll('.project-card-v').forEach((card) => {
      const indexEl = card.querySelector('[data-card-layer="index"]') as HTMLElement;
      const blockEl = card.querySelector('[data-card-layer="block"]') as HTMLElement;
      const strokeEl = card.querySelector('[data-card-layer="stroke"]') as HTMLElement | null;
      const lineEl = card.querySelector('[data-card-layer="line"]') as HTMLElement | null;
      const labelEl = card.querySelector('[data-card-layer="label"]') as HTMLElement | null;
      if (!indexEl || !blockEl) return;
      const cl: CardLayer = {
        card: card as HTMLElement, indexEl, blockEl, strokeEl, lineEl, labelEl, visible: false,
        hoverX: 0, hoverY: 0, currentHoverX: 0, currentHoverY: 0, hovering: false,
      };
      cardLayers.push(cl);

      // Hover tracking for layer parallax
      if (hasFineCursor) {
        card.addEventListener('mouseenter', () => { cl.hovering = true; }, { passive: true });
        card.addEventListener('mousemove', (e: Event) => {
          if (Math.abs(scrollVelocity) > 0.5) return;
          const me = e as MouseEvent;
          const rect = (card as HTMLElement).getBoundingClientRect();
          cl.hoverX = (me.clientX - rect.left - rect.width / 2) / rect.width;
          cl.hoverY = (me.clientY - rect.top - rect.height / 2) / rect.height;
        }, { passive: true });
        card.addEventListener('mouseleave', () => {
          cl.hovering = false;
          cl.hoverX = 0;
          cl.hoverY = 0;
        }, { passive: true });
      }
    });

    if (cardLayers.length > 0) {
      const cardLayerVis = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const cl = cardLayers.find(c => c.card === entry.target);
          if (cl) cl.visible = entry.isIntersecting;
        });
      }, { threshold: 0, rootMargin: '100px 0px 100px 0px' });
      cardLayers.forEach(cl => cardLayerVis.observe(cl.card));
    }

    // ── Section depth layer parallax setup ──
    interface DepthLayer {
      container: HTMLElement;
      deepEl: HTMLElement | null;
      midEl: HTMLElement | null;
      visible: boolean;
    }
    const depthLayers: DepthLayer[] = [];
    document.querySelectorAll('[data-depth-container]').forEach((container) => {
      const deepEl = container.querySelector('[data-depth-layer="deep"]') as HTMLElement | null;
      const midEl = container.querySelector('[data-depth-layer="mid"]') as HTMLElement | null;
      if (!deepEl && !midEl) return;
      depthLayers.push({
        container: container as HTMLElement,
        deepEl,
        midEl,
        visible: false,
      });
    });

    if (depthLayers.length > 0) {
      const depthVis = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const dl = depthLayers.find(d => d.container === entry.target);
          if (dl) dl.visible = entry.isIntersecting;
        });
      }, { threshold: 0, rootMargin: '100px 0px 100px 0px' });
      depthLayers.forEach(dl => depthVis.observe(dl.container));
    }

    // Handle anchor clicks with native smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener('click', (e) => {
        e.preventDefault();
        const href = (anchor as HTMLAnchorElement).getAttribute('href');
        if (!href) return;
        const target = document.querySelector(href);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth' });
          const mobileMenu = document.getElementById('mobile-menu');
          if (mobileMenu?.classList.contains('open')) {
            mobileMenu.classList.remove('open');
            document.body.style.overflow = '';
          }
        }
      });
    });

    // ── Pre-decode project thumbnails so they're pixel-ready before scroll ──
    document.querySelectorAll('.card-work-img img').forEach((img: HTMLImageElement) => {
      if (img.complete) {
        img.decode().catch(() => {});
      } else {
        img.addEventListener('load', () => img.decode().catch(() => {}), { once: true });
      }
    });

    // ── Loader ──
    const loader = document.getElementById('loader');
    const heroName = document.getElementById('hero-name');
    const heroSubtitle = document.getElementById('hero-subtitle');

    window.addEventListener('load', () => {
      setTimeout(() => {
        loader?.classList.add('done');
        setTimeout(() => {
          if (loader) loader.style.display = 'none';
          document.body.classList.add('loaded');
          startHeroTypewriter();
        }, 800);
      }, 400);
    });

    // ── Hero name typewriter ──
    function startHeroTypewriter() {
      if (!heroName) return;
      const text = heroName.textContent?.trim() || '';
      heroName.textContent = '';
      heroName.style.minHeight = '1em';
      heroName.style.visibility = 'visible';

      const cursor = document.createElement('span');
      cursor.classList.add('tw-cursor');

      let charIdx = 0;
      const scrollIndicator = document.getElementById('scroll-indicator');

      function typeNext() {
        if (charIdx >= text.length) {
          // Fade cursor out instead of removing (avoids layout snap)
          cursor.style.transition = 'opacity 1s ease';
          cursor.style.opacity = '0';

          // Reveal subtitle and scroll indicator via JS opacity/transform
          // (no CSS transitions — float will handle transforms)
          const subLines = heroSubtitle?.querySelectorAll('.subtitle-line') as NodeListOf<HTMLElement>;

          // Start float immediately — it handles reveal + drift together
          const floatEls = [
            { el: heroName, speed: 0.0008, amp: 12, phase: 0 },
            { el: heroSubtitle, speed: 0.0006, amp: 10, phase: 2 },
            { el: scrollIndicator, speed: 0.0005, amp: 8, phase: 4 },
          ];
          const startTime = performance.now();
          const rampDuration = 2500;

          // Reveal timings (ms after typing ends)
          const subtitleDelay = 150;
          const sub2Delay = 400;
          const scrollDelay = 600;
          const statusDelay = 100;
          const servicesDelay = 500;
          const watermarkDelay = 200;

          // Grab hero detail elements
          const heroStatusEl = document.querySelector('.hero-status') as HTMLElement | null;
          const heroServicesEl = document.querySelector('.hero-services') as HTMLElement | null;
          const heroWatermarkEl = document.querySelector('.hero-watermark') as HTMLElement | null;
          const heroRuleEl = document.querySelector('.hero-rule') as HTMLElement | null;
          const heroYearEl = document.querySelector('.hero-year') as HTMLElement | null;
          const heroBarEl = document.querySelector('.hero-accent-bar') as HTMLElement | null;
          const heroRingEl = document.querySelector('.hero-accent-ring') as HTMLElement | null;
          const heroGridEl = document.querySelector('.hero-grid-overlay') as HTMLElement | null;
          const heroSectionIndex = document.querySelector('.hero-section-index') as HTMLElement | null;
          const heroTitleBlock = document.querySelector('.hero-title-block') as HTMLElement | null;
          const heroTitleLine = document.querySelector('.hero-title-line') as HTMLElement | null;
          const heroCtaEl = document.querySelector('.hero-cta') as HTMLElement | null;
          const heroDataLine = document.querySelector('.hero-data-line') as HTMLElement | null;
          const heroCoordsEls = Array.from(document.querySelectorAll('.hero-coord')) as HTMLElement[];

          // Gate hero float to only run when hero is in viewport
          let heroInView = true;
          const heroSection = document.getElementById('hero');
          if (heroSection) {
            const heroVis = new IntersectionObserver((entries) => {
              entries.forEach((entry) => {
                heroInView = entry.isIntersecting;
              });
            }, { threshold: 0 });
            heroVis.observe(heroSection);
          }

          // Alias shared easing for hero reveals
          const smoothReveal = easedReveal;

          // ── Canvas dot grid with per-dot shimmer ──
          // Viewport-sized canvas. Parallax + shimmer in draw loop.
          // Dots drawn as fillRect (integer coords) — no anti-aliasing jitter.
          const dotCanvas = document.getElementById('dot-grid') as HTMLCanvasElement | null;
          let dotCtx: CanvasRenderingContext2D | null = null;
          const DOT_SPACING = 28;
          // Total grid covers entire document — per-dot properties seeded by grid index
          const TOTAL_COLS = 200; // enough for any viewport width
          const TOTAL_ROWS = 600; // enough for full page height with parallax
          const TOTAL_DOTS = TOTAL_COLS * TOTAL_ROWS;
          // Pre-compute per-dot properties using deterministic seed from grid index
          const dotPhases = new Float32Array(TOTAL_DOTS);
          const dotJitterX = new Float32Array(TOTAL_DOTS);
          const dotJitterY = new Float32Array(TOTAL_DOTS);
          const dotSizes = new Float32Array(TOTAL_DOTS);
          const dotBrightness = new Float32Array(TOTAL_DOTS);
          // Simple seeded PRNG for deterministic per-dot properties
          function mulberry32(a: number) { return () => { a |= 0; a = a + 0x6D2B79F5 | 0; let t = Math.imul(a ^ a >>> 15, 1 | a); t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t; return ((t ^ t >>> 14) >>> 0) / 4294967296; }; }
          for (let i = 0; i < TOTAL_DOTS; i++) {
            const rng = mulberry32(i * 2654435761);
            dotPhases[i] = rng() * Math.PI * 2;
            dotJitterX[i] = (rng() - 0.5) * 10;
            dotJitterY[i] = (rng() - 0.5) * 10;
            dotSizes[i] = 1 + Math.round(rng() * 2); // 1, 2, or 3 px squares
            dotBrightness[i] = 0.2 + rng() * 0.8;
          }
          let dotW = 0, dotH = 0, dotDpr = 1;
          let lastShimmerDraw = 0;

          if (dotCanvas) {
            dotCtx = dotCanvas.getContext('2d');
            function resizeDotGrid() {
              dotDpr = window.devicePixelRatio || 1;
              dotW = window.innerWidth;
              dotH = window.innerHeight;
              dotCanvas!.width = dotW * dotDpr;
              dotCanvas!.height = dotH * dotDpr;
              dotCanvas!.style.width = dotW + 'px';
              dotCanvas!.style.height = dotH + 'px';
              lastShimmerDraw = 0;
            }
            resizeDotGrid();
            window.addEventListener('resize', resizeDotGrid);
          }

          let smoothScrollY = window.scrollY || 0;

          let dotFrameSkip = 0;

          function heroFloat(now: number) {
            if (dotCanvas && dotCtx) {
              const t0 = now - startTime;
              const revealEase = smoothReveal(t0, subtitleDelay, 2500);
              const isDark = document.documentElement.dataset.theme === 'dark';
              const baseAlpha = isDark ? 0.10 : 0.18;
              const masterAlpha = revealEase * baseAlpha;

              // Smooth scroll lerp
              const targetScrollY = window.scrollY || 0;
              smoothScrollY += (targetScrollY - smoothScrollY) * 0.06;
              dotCanvas.style.opacity = `${revealEase}`;

              // Throttle canvas to ~20fps (skip 2 of 3 frames)
              dotFrameSkip++;
              if (dotFrameSkip % 3 !== 0) {
                // Skip canvas draw but still run hero reveals below
              } else {
              // Full redraw — alpha-binned for fewer globalAlpha changes
              dotCtx.setTransform(dotDpr, 0, 0, dotDpr, 0, 0);
              dotCtx.clearRect(0, 0, dotW, dotH);

              const dotColor = isDark ? '255,255,255' : '0,0,0';
              const time = now * 0.001;

              // Parallax offset
              const parallaxY = smoothScrollY * 0.3;
              const parallaxX = Math.sin(smoothScrollY * 0.0006) * 15;

              // Which grid rows/cols are visible
              const startRow = Math.max(0, Math.floor((parallaxY - 15) / DOT_SPACING));
              const endRow = Math.min(TOTAL_ROWS, Math.ceil((parallaxY + dotH + 15) / DOT_SPACING));
              const startCol = Math.max(0, Math.floor((parallaxX - 15) / DOT_SPACING));
              const endCol = Math.min(TOTAL_COLS, Math.ceil((parallaxX + dotW + 15) / DOT_SPACING));

              // Bin dots into 8 alpha buckets to minimize globalAlpha switches
              // (switching globalAlpha per-dot breaks canvas draw batching)
              const ALPHA_BINS = 8;
              const bins: { x: number; y: number; s: number }[][] = Array.from({ length: ALPHA_BINS }, () => []);

              dotCtx.fillStyle = `rgb(${dotColor})`;
              for (let row = startRow; row < endRow; row++) {
                for (let col = startCol; col < endCol; col++) {
                  const idx = row * TOTAL_COLS + col;
                  // Simplified shimmer — single sin instead of two
                  const shimmer = 0.5 + 0.5 * Math.sin(time * 3.0 + dotPhases[idx]);
                  const alpha = masterAlpha * dotBrightness[idx] * (0.1 + 0.9 * shimmer);
                  if (alpha < 0.01) continue;

                  const bin = Math.min(ALPHA_BINS - 1, (alpha * ALPHA_BINS) | 0);
                  const x = col * DOT_SPACING + dotJitterX[idx] - parallaxX;
                  const y = row * DOT_SPACING + dotJitterY[idx] - parallaxY;
                  bins[bin].push({ x, y, s: dotSizes[idx] });
                }
              }

              // Draw each bin with a single globalAlpha
              for (let b = 0; b < ALPHA_BINS; b++) {
                if (bins[b].length === 0) continue;
                dotCtx.globalAlpha = (b + 0.5) / ALPHA_BINS * masterAlpha * 1.5;
                for (let d = 0; d < bins[b].length; d++) {
                  dotCtx.fillRect(bins[b][d].x, bins[b][d].y, bins[b][d].s, bins[b][d].s);
                }
              }
              dotCtx.globalAlpha = 1;
              } // end throttle
            }

            if (!heroInView) {
              requestAnimationFrame(heroFloat);
              return;
            }
            const t = now - startTime;
            const ramp = Math.min(1, t / rampDuration);
            const easedRamp = smoothstep(ramp);

            // Cache theme once per frame (avoids repeated DOM reads in reveal blocks below)
            const isDark = document.documentElement.dataset.theme === 'dark';

            // Float the title
            const titleY = (Math.sin(t * 0.0008) * 12 + Math.sin(t * 0.00056 + 1) * 4.8) * easedRamp;
            heroName.style.transform = `translate3d(0, ${titleY}px, 0)`;

            // Reveal + float subtitle
            if (heroSubtitle) {
              heroSubtitle.style.opacity = '1';
              if (subLines) {
                subLines.forEach((line, i) => {
                  const delay = i === 0 ? subtitleDelay : sub2Delay;
                  const eased = smoothReveal(t, delay);
                  const floatY = (Math.sin(t * 0.0006 + 2) * 10 + Math.sin(t * 0.00042 + 3) * 4) * easedRamp;
                  const revealY = (1 - eased) * 24;
                  line.style.opacity = `${eased}`;
                  line.style.transform = `translate3d(0, ${revealY + floatY}px, 0)`;
                });
              }
            }

            // Reveal + float scroll indicator
            if (scrollIndicator) {
              const sEased = smoothReveal(t, scrollDelay);
              const sFloatY = (Math.sin(t * 0.0005 + 4) * 8 + Math.sin(t * 0.00035 + 5) * 3.2) * easedRamp;
              const sRevealY = (1 - sEased) * 20;
              scrollIndicator.style.opacity = `${sEased}`;
              scrollIndicator.style.transform = `translate3d(0, ${sRevealY + sFloatY}px, 0)`;
            }

            // Reveal status line
            if (heroStatusEl) {
              const e = smoothReveal(t, statusDelay);
              heroStatusEl.style.opacity = `${e * 0.7}`;
              heroStatusEl.style.transform = `translate3d(0, ${(1 - e) * 16}px, 0)`;
            }

            // Reveal services
            if (heroServicesEl) {
              const e = smoothReveal(t, servicesDelay);
              heroServicesEl.style.opacity = `${e * 0.5}`;
              heroServicesEl.style.transform = `translate3d(0, ${(1 - e) * 16}px, 0)`;
            }

            // Reveal CTA (after services)
            if (heroCtaEl) {
              const e = smoothReveal(t, 650, 2000);
              heroCtaEl.style.opacity = `${e}`;
              heroCtaEl.style.transform = `translate3d(0, ${(1 - e) * 12}px, 0)`;
            }

            // Reveal data line (mid-depth horizontal accent)
            if (heroDataLine) {
              const e = smoothReveal(t, 300, 3000);
              heroDataLine.style.opacity = `${e}`;
            }

            // Reveal watermark
            if (heroWatermarkEl) {
              const e = smoothReveal(t, watermarkDelay, 3000);
              heroWatermarkEl.style.opacity = `${e * (isDark ? 0.03 : 0.018)}`;
              heroWatermarkEl.style.transform = `translate3d(0, ${(1 - e) * 30}px, 0)`;
            }

            // Reveal accent rule
            if (heroRuleEl) {
              const e = smoothReveal(t, subtitleDelay);
              heroRuleEl.style.opacity = `${e}`;
              heroRuleEl.style.transform = `scaleX(${e})`;
            }

            // Reveal year marker (deep layer)
            if (heroYearEl) {
              const e = smoothReveal(t, 300, 2500);
              heroYearEl.style.opacity = `${e * (isDark ? 0.06 : 0.04)}`;
              heroYearEl.style.transform = `translate3d(0, ${(1 - e) * 20}px, 0)`;
            }

            // Reveal accent bar (mid layer)
            if (heroBarEl) {
              const e = smoothReveal(t, 400, 2500);
              heroBarEl.style.opacity = `${e * (isDark ? 0.12 : 0.08)}`;
            }

            // Reveal accent ring (mid layer)
            if (heroRingEl) {
              const e = smoothReveal(t, 350, 2500);
              heroRingEl.style.opacity = `${e * (isDark ? 0.08 : 0.05)}`;
              heroRingEl.style.transform = `scale(${0.8 + e * 0.2})`;
            }

            // Reveal grid overlay (deep layer)
            if (heroGridEl) {
              const e = smoothReveal(t, 200, 3000);
              heroGridEl.style.opacity = `${e * (isDark ? 0.05 : 0.03)}`;
            }

            // (dot grid parallax handled above, outside heroInView check)

            // Reveal hero title depth layers (timed with typewriter)
            if (heroSectionIndex) {
              const e = smoothReveal(t, watermarkDelay, 2500);
              heroSectionIndex.style.opacity = `${e * (isDark ? 0.05 : 0.03)}`;
              heroSectionIndex.style.transform = `translate3d(0, ${(1 - e) * 25}px, 0)`;
            }
            if (heroTitleBlock) {
              const e = smoothReveal(t, 100, 2500);
              heroTitleBlock.style.opacity = `${e * (isDark ? 0.04 : 0.025)}`;
              heroTitleBlock.style.transform = `translate3d(${(1 - e) * 20}px, 0, 0)`;
            }
            if (heroTitleLine) {
              const e = smoothReveal(t, subtitleDelay, 2000);
              heroTitleLine.style.opacity = `${e * (isDark ? 0.15 : 0.1)}`;
              heroTitleLine.style.transform = `scaleX(${e})`;
              heroTitleLine.style.transformOrigin = 'left';
            }

            // Reveal coordinates
            heroCoordsEls.forEach((c, i) => {
              const e = smoothReveal(t, 600 + i * 200, 2000);
              c.style.opacity = `${e * 0.3}`;
              c.style.transform = `translate3d(0, ${(1 - e) * 10}px, 0)`;
            });

            requestAnimationFrame(heroFloat);
          }
          requestAnimationFrame(heroFloat); // initial kick-off
          return;
        }
        heroName.textContent = text.slice(0, charIdx + 1);
        heroName.appendChild(cursor);
        charIdx++;
        const ch = text[charIdx - 1];
        const delay = ch === ' ' ? 40 : 30 + Math.random() * 20;
        setTimeout(typeNext, delay);
      }
      typeNext();
    }

    // ── 6. SCROLL-TRIGGERED REVEALS ──
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('[data-reveal]').forEach((el) => {
      revealObserver.observe(el);
    });
    // Section marks — reuse same reveal observer
    document.querySelectorAll('.section-mark').forEach((el) => {
      revealObserver.observe(el);
    });

    // (Float animation runs in main rAF loop above)

    // ── Section dividers (shared observer — one for all dividers) ──
    const dividerObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          setTimeout(() => (entry.target as HTMLElement).classList.add('animate-in'), 200);
          dividerObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('[data-divider]').forEach((el) => dividerObs.observe(el));

    // ── Section heading char reveal (shared observers) ──
    const headingWraps: { wrap: Element; heading: HTMLElement }[] = [];
    document.querySelectorAll('[data-heading-reveal]').forEach((wrap) => {
      const heading = wrap.querySelector('.section-heading') as HTMLElement;
      if (!heading) return;
      const text = heading.textContent?.trim() || '';
      heading.innerHTML = '';
      text.split('').forEach((char, i) => {
        const span = document.createElement('span');
        span.textContent = char === ' ' ? '\u00A0' : char;
        span.classList.add('heading-char');
        span.style.transitionDelay = `${i * 0.04}s`;
        heading.appendChild(span);
      });
      headingWraps.push({ wrap, heading });

      // Hover bounce on heading chars (desktop only)
      if (hasFineCursor) {
        heading.addEventListener('mouseenter', () => {
          heading.querySelectorAll('.heading-char').forEach((ch, i) => {
            (ch as HTMLElement).style.animation = `none`;
            setTimeout(() => {
              (ch as HTMLElement).style.animation = ``;
              (ch as HTMLElement).style.transform = 'translateY(-8px)';
              setTimeout(() => { (ch as HTMLElement).style.transform = ''; }, 150);
            }, i * 30);
          });
        });
      }
    });

    // Single observer for heading reveal (replaces N per-heading observers)
    const headingRevealObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const match = headingWraps.find(h => h.wrap === entry.target);
        if (match) {
          match.heading.classList.add('revealed');
          (entry.target as HTMLElement).classList.add('revealed');
        }
        headingRevealObs.unobserve(entry.target);
      });
    }, { threshold: 0.2 });
    headingWraps.forEach(h => headingRevealObs.observe(h.wrap));

    // Mobile: single observer for heading bounce (replaces N per-heading bounce observers)
    if (!hasFineCursor && headingWraps.length > 0) {
      const headingBounceObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const match = headingWraps.find(h => h.wrap === entry.target);
          if (match) {
            match.heading.querySelectorAll('.heading-char').forEach((ch, i) => {
              setTimeout(() => {
                (ch as HTMLElement).style.transform = 'translateY(-6px)';
                setTimeout(() => { (ch as HTMLElement).style.transform = ''; }, 150);
              }, i * 30);
            });
          }
          headingBounceObs.unobserve(entry.target);
        });
      }, { threshold: 0.8 });
      headingWraps.forEach(h => headingBounceObs.observe(h.wrap));
    }

    // ── Manifesto word-by-word scroll reveal (setup) ──
    const manifestoData: { el: Element; wordSpans: NodeListOf<Element>; totalWords: number }[] = [];
    document.querySelectorAll('[data-manifesto]').forEach((el) => {
      const text = el.textContent?.trim() || '';
      el.innerHTML = '';
      const words = text.split(/\s+/);
      words.forEach((word, i) => {
        const span = document.createElement('span');
        span.textContent = word;
        span.classList.add('manifesto-word');
        el.appendChild(span);
        if (i < words.length - 1) el.appendChild(document.createTextNode(' '));
      });
      manifestoData.push({ el, wordSpans: el.querySelectorAll('.manifesto-word'), totalWords: words.length });
    });

    // ── Process tagline typewriter ──
    const processTypewriter = document.querySelector('[data-process-typewriter]') as HTMLElement;
    const processSub = document.querySelector('[data-process-sub]') as HTMLElement;

    if (processTypewriter) {
      const fullText = processTypewriter.getAttribute('aria-label') || '';
      let started = false;

      const twObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !started) {
            started = true;
            let idx = 0;
            const cursor = document.createElement('span');
            cursor.className = 'tw-cursor';

            function typeChar() {
              if (idx >= fullText.length) {
                cursor.remove();
                // Fade in the sub-line
                if (processSub) {
                  processSub.style.transition = 'opacity 0.6s ease';
                  processSub.style.opacity = '1';
                }
                return;
              }
              processTypewriter.textContent = fullText.slice(0, idx + 1);
              processTypewriter.appendChild(cursor);
              idx++;
              const ch = fullText[idx - 1];
              const delay = ch === '.' ? 140 : ch === ',' ? 80 : ch === ' ' ? 30 : 25;
              setTimeout(typeChar, delay);
            }
            typeChar();
            twObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });
      twObs.observe(processTypewriter);
    }

    // ── Process steps (setup) ──
    const processSteps = document.querySelectorAll('[data-process-step]');
    const processRailFill = document.querySelector('[data-process-rail]') as HTMLElement;
    const processTimeline = document.querySelector('.process-timeline') as HTMLElement;

    // Staggered reveal for process steps
    if (processSteps.length > 0) {
      const stepRevealObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            stepRevealObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });
      processSteps.forEach((step) => stepRevealObs.observe(step));
    }

    // ── Nav / scroll progress (setup) ──
    const scrollProgress = document.getElementById('scroll-progress');
    const navTop = document.getElementById('nav-top');
    const sections = document.querySelectorAll('section[id]');
    const navNodes = document.querySelectorAll('.nav-node[data-nav-section]');
    const navMobileLinks = document.querySelectorAll('.nav-mobile-link[data-nav-section]');
    const navRailProgress = document.getElementById('nav-rail-progress');

    // ── IntersectionObserver for active section (replaces per-frame getBoundingClientRect) ──
    let currentSection = 'hero';
    let lastActiveSection = '';
    const sectionObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          currentSection = entry.target.id;
        }
      });
    }, { threshold: 0, rootMargin: '-199px 0px -50% 0px' });
    sections.forEach((s) => sectionObs.observe(s));

    // ── IntersectionObserver for manifesto visibility ──
    const manifestoVisible = new Map<Element, boolean>();
    manifestoData.forEach(({ el }) => manifestoVisible.set(el, false));
    const manifestoObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        manifestoVisible.set(entry.target, entry.isIntersecting);
      });
    }, { threshold: 0.05 });
    manifestoData.forEach(({ el }) => manifestoObs.observe(el));

    // ── IntersectionObserver for process timeline visibility ──
    let processVisible = false;
    if (processTimeline) {
      const processObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          processVisible = entry.isIntersecting;
        });
      }, { threshold: 0.05 });
      processObs.observe(processTimeline);
    }

    // ── Skew (variables — logic runs in main rAF above) ──

    // ── Parallax (setup) ──
    const hasPointer = hasFineCursor;
    const parallaxElements = hasPointer ? document.querySelectorAll('[data-parallax]') : [];
    const parallaxVisible = new Set<Element>();
    if (hasPointer && parallaxElements.length > 0) {
      const parObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) parallaxVisible.add(entry.target);
          else parallaxVisible.delete(entry.target);
        });
      }, { threshold: 0, rootMargin: '100px 0px 100px 0px' });
      parallaxElements.forEach((el) => parObs.observe(el));
    }

    // (Scroll reads batched in main rAF loop — no separate scroll handler needed)
    const heroScrollFade = document.querySelector('.hero-scroll-fade') as HTMLElement | null;

    // ── Mobile menu ──
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuLine1 = document.getElementById('menu-line-1');
    const menuLine2 = document.getElementById('menu-line-2');

    menuToggle?.addEventListener('click', () => {
      const isOpen = mobileMenu?.classList.contains('open');
      if (isOpen) {
        mobileMenu?.classList.remove('open');
        document.body.style.overflow = '';
        if (menuLine1) menuLine1.style.transform = '';
        if (menuLine2) menuLine2.style.transform = '';
      } else {
        mobileMenu?.classList.add('open');
        document.body.style.overflow = 'hidden';
        if (menuLine1) menuLine1.style.transform = 'translateY(3.25px) rotate(45deg)';
        if (menuLine2) menuLine2.style.transform = 'translateY(-3.25px) rotate(-45deg)';
      }
    });

    // ── 7. INTERACTIONS — magnetic, cursor, tilt, scramble ──

    // Magnetic hover elements (lerp-smoothed)
    if (hasFineCursor) {
      const magEls: { el: HTMLElement; strength: number; targetX: number; targetY: number; currentX: number; currentY: number; active: boolean }[] = [];
      document.querySelectorAll('[data-magnetic]').forEach((el) => {
        const htmlEl = el as HTMLElement;
        const m = { el: htmlEl, strength: parseFloat(htmlEl.dataset.magnetic || '0.3'), targetX: 0, targetY: 0, currentX: 0, currentY: 0, active: false };
        magEls.push(m);
        htmlEl.addEventListener('mousemove', (e: Event) => {
          const me = e as MouseEvent;
          const rect = htmlEl.getBoundingClientRect();
          m.targetX = (me.clientX - rect.left - rect.width / 2) * m.strength;
          m.targetY = (me.clientY - rect.top - rect.height / 2) * m.strength;
          m.active = true;
        }, { passive: true });
        htmlEl.addEventListener('mouseleave', () => {
          m.targetX = 0;
          m.targetY = 0;
        }, { passive: true });
      });
      // Single rAF loop for all magnetic elements
      function animateMagnetic() {
        for (const m of magEls) {
          m.currentX += (m.targetX - m.currentX) * 0.15;
          m.currentY += (m.targetY - m.currentY) * 0.15;
          if (m.active || Math.abs(m.currentX) > 0.1 || Math.abs(m.currentY) > 0.1) {
            m.el.style.transform = `translate3d(${m.currentX}px, ${m.currentY}px, 0)`;
            if (Math.abs(m.currentX) < 0.1 && Math.abs(m.currentY) < 0.1 && m.targetX === 0) {
              m.currentX = 0; m.currentY = 0;
              m.el.style.transform = '';
              m.active = false;
            }
          }
        }
        requestAnimationFrame(animateMagnetic);
      }
      animateMagnetic();
    }

    // ── Custom cursor ──
    const cursorDot = document.getElementById('cursor-dot');
    const cursorCircle = document.getElementById('cursor-circle');
    let mouseX = -100;
    let mouseY = -100;

    if (hasFineCursor && cursorDot && cursorCircle) {
      let mouseOnPage = true;
      let dotX = -100, dotY = -100;
      let circleX = -100, circleY = -100;
      let isHovering = false;
      let isClicking = false;
      let circleScale = 1;
      let dotScale = 1;

      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
      }, { passive: true });

      // Build trail dots
      const trailContainer = document.getElementById('cursor-trail');
      const TRAIL_COUNT = 5;
      const trailDots: HTMLElement[] = [];
      const trailPositions = Array.from({ length: TRAIL_COUNT }, () => ({ x: -100, y: -100 }));
      if (trailContainer) {
        for (let i = 0; i < TRAIL_COUNT; i++) {
          const dot = document.createElement('div');
          dot.classList.add('cursor-trail-dot');
          dot.style.width = `${4 - i * 0.4}px`;
          dot.style.height = `${4 - i * 0.4}px`;
          trailContainer.appendChild(dot);
          trailDots.push(dot);
        }
      }

      // Animation loop — dot + circle lerp + trail + scale
      function animateCursor() {
        dotX += (mouseX - dotX) * 0.5;
        dotY += (mouseY - dotY) * 0.5;

        circleX += (mouseX - circleX) * 0.1;
        circleY += (mouseY - circleY) * 0.1;

        // Smooth scale transitions via lerp
        const targetCircleScale = isHovering ? 1.35 : 1;
        const targetDotScale = isClicking ? 0.5 : (isHovering ? 0.75 : 1);
        circleScale += (targetCircleScale - circleScale) * 0.15;
        dotScale += (targetDotScale - dotScale) * 0.2;

        cursorDot.style.transform = `translate3d(${dotX}px,${dotY}px,0) scale(${dotScale})`;
        cursorCircle.style.transform = `translate3d(${circleX}px,${circleY}px,0) scale(${circleScale})`;

        // Trail — only write DOM when moving
        if (trailDots.length && mouseOnPage) {
          const dx = mouseX - trailPositions[0].x;
          const dy = mouseY - trailPositions[0].y;
          const velocity = Math.sqrt(dx * dx + dy * dy);
          const trailIntensity = Math.min(1, velocity / 30);

          trailPositions[0].x += (mouseX - trailPositions[0].x) * 0.3;
          trailPositions[0].y += (mouseY - trailPositions[0].y) * 0.3;
          for (let i = 1; i < TRAIL_COUNT; i++) {
            trailPositions[i].x += (trailPositions[i - 1].x - trailPositions[i].x) * 0.25;
            trailPositions[i].y += (trailPositions[i - 1].y - trailPositions[i].y) * 0.25;
          }
          // Skip trail DOM writes when stationary
          if (velocity > 0.5) {
            trailDots.forEach((dot, i) => {
              dot.style.transform = `translate3d(${trailPositions[i].x - 2}px,${trailPositions[i].y - 2}px,0)`;
              dot.style.opacity = `${(0.3 - i * 0.035) * trailIntensity}`;
            });
          }
        }

        requestAnimationFrame(animateCursor);
      }
      animateCursor();

      // Hover state — scale circle up, shrink dot
      document.querySelectorAll('a, button, [data-cursor-hover]').forEach((el) => {
        el.addEventListener('mouseenter', () => {
          isHovering = true;
          cursorCircle.classList.add('hover');
        });
        el.addEventListener('mouseleave', () => {
          isHovering = false;
          cursorCircle.classList.remove('hover');
        });
      });

      // Click feedback — squeeze dot
      document.addEventListener('mousedown', () => { isClicking = true; });
      document.addEventListener('mouseup', () => { isClicking = false; });

      document.addEventListener('mouseleave', () => {
        mouseOnPage = false;
        cursorDot.style.visibility = 'hidden';
        cursorCircle.style.visibility = 'hidden';
        trailDots.forEach((dot) => { dot.style.visibility = 'hidden'; });
      });
      document.addEventListener('mouseenter', () => {
        mouseOnPage = true;
        cursorDot.style.visibility = '';
        cursorCircle.style.visibility = '';
        trailDots.forEach((dot) => { dot.style.visibility = ''; });
      });

      // Nav rail nodes magnetic pull toward cursor Y
      const navRailNodes = document.querySelector('.nav-rail-nodes');
      if (navRailNodes) {
        let navPullRaf = 0;
        document.addEventListener('mousemove', (e) => {
          if (Math.abs(scrollVelocity) > 0.5) return;
          const mY = e.clientY;
          if (navPullRaf) return;
          navPullRaf = requestAnimationFrame(() => {
            const rect = navRailNodes.getBoundingClientRect();
            const centerY = rect.top + rect.height / 2;
            const pull = (mY - centerY) * 0.03;
            const clamped = Math.max(-10, Math.min(10, pull));
            (navRailNodes as HTMLElement).style.transform = `translateY(${clamped}px)`;
            navPullRaf = 0;
          });
        }, { passive: true });
      }
    }

    // ── Smooth image scroll on project card hover ──
    if (hasFineCursor) {
      document.querySelectorAll('.project-card-v').forEach((card) => {
        const img = card.querySelector('.card-work-img img') as HTMLImageElement;
        const container = card.querySelector('.project-image') as HTMLElement;
        if (!img || !container) return;

        let scrollPos = 0;
        let scrollRaf: number | null = null;
        let hovering = false;
        let currentStop = 0;
        const stops = [0, 0.25, 0.5, 0.75, 1];
        const pauseDuration = 90; // ~1.5s pause at each stop
        const initialDelay = 90; // ~1.5s delay before first move
        let pauseCounter = 0;
        let isPaused = false;
        let delayCounter = 0;
        let isDelaying = false;
        let cachedMaxScroll = 0;

        function ensureImageLoaded(cb: () => void) {
          if (img.naturalHeight > 0) { cb(); return; }
          img.addEventListener('load', cb, { once: true });
        }

        function cacheMaxScroll() {
          cachedMaxScroll = img.offsetHeight - container.offsetHeight;
        }

        function animateScroll() {
          if (cachedMaxScroll <= 0) { scrollRaf = null; return; }


          if (hovering) {
            // Initial delay before starting to scroll
            if (isDelaying) {
              delayCounter++;
              if (delayCounter >= initialDelay) {
                isDelaying = false;
              }
              img.style.transform = `translateY(${-scrollPos}px)`;
              scrollRaf = requestAnimationFrame(animateScroll);
              return;
            }

            const stopTarget = stops[currentStop] * cachedMaxScroll;

            if (isPaused) {
              pauseCounter++;
              if (pauseCounter >= pauseDuration) {
                isPaused = false;
                pauseCounter = 0;
                if (currentStop < stops.length - 1) currentStop++;
              }
            } else {
              scrollPos += (stopTarget - scrollPos) * 0.04;

              if (Math.abs(scrollPos - stopTarget) < 1) {
                scrollPos = stopTarget;
                if (currentStop < stops.length - 1) {
                  isPaused = true;
                  pauseCounter = 0;
                }
              }
            }
          } else {
            scrollPos += (0 - scrollPos) * 0.05;
            if (Math.abs(scrollPos) < 0.5) {
              scrollPos = 0;
              img.style.transform = '';
              currentStop = 0;
              isPaused = false;
              pauseCounter = 0;
              scrollRaf = null;
              return;
            }
          }

          img.style.transform = `translateY(${-scrollPos}px)`;

          scrollRaf = requestAnimationFrame(animateScroll);
        }

        card.addEventListener('mouseenter', () => {
          hovering = true;
          currentStop = 1;
          isPaused = false;
          pauseCounter = 0;
          isDelaying = true;
          delayCounter = 0;
          ensureImageLoaded(() => {
            cacheMaxScroll(); // read offsetHeight once, not every frame
            if (!scrollRaf) scrollRaf = requestAnimationFrame(animateScroll);
          });
        });

        card.addEventListener('mouseleave', () => {
          hovering = false;
          currentStop = 0;
          if (!scrollRaf) scrollRaf = requestAnimationFrame(animateScroll);
        });
      });
    }

    // ── Mobile: scroll-triggered card effects (single shared observer) ──
    if (!hasFineCursor) {
      interface MobileCardState {
        card: HTMLElement; img: HTMLImageElement; container: HTMLElement;
        scrollPos: number; scrollRaf: number | null; active: boolean;
        currentStop: number; pauseCounter: number; isPaused: boolean;
        delayCounter: number; isDelaying: boolean; cachedMaxScroll: number;
      }
      const mobileCards: MobileCardState[] = [];
      const MOBILE_STOPS = [0, 0.25, 0.5, 0.75, 1];

      function animateMobileCard(state: MobileCardState) {
        if (state.cachedMaxScroll <= 0) { state.scrollRaf = null; return; }
        if (state.active) {
          if (state.isDelaying) {
            state.delayCounter++;
            if (state.delayCounter >= 60) state.isDelaying = false;
            state.img.style.transform = `translateY(${-state.scrollPos}px)`;
            state.scrollRaf = requestAnimationFrame(() => animateMobileCard(state));
            return;
          }
          const stopTarget = MOBILE_STOPS[state.currentStop] * state.cachedMaxScroll;
          if (state.isPaused) {
            state.pauseCounter++;
            if (state.pauseCounter >= 100) { state.isPaused = false; state.pauseCounter = 0; if (state.currentStop < MOBILE_STOPS.length - 1) state.currentStop++; }
          } else {
            state.scrollPos += (stopTarget - state.scrollPos) * 0.04;
            if (Math.abs(state.scrollPos - stopTarget) < 1) {
              state.scrollPos = stopTarget;
              if (state.currentStop < MOBILE_STOPS.length - 1) { state.isPaused = true; state.pauseCounter = 0; }
            }
          }
        } else {
          state.scrollPos += (0 - state.scrollPos) * 0.05;
          if (Math.abs(state.scrollPos) < 0.5) {
            state.scrollPos = 0; state.img.style.transform = ''; state.currentStop = 0;
            state.isPaused = false; state.pauseCounter = 0; state.scrollRaf = null; return;
          }
        }
        state.img.style.transform = `translateY(${-state.scrollPos}px)`;
        state.scrollRaf = requestAnimationFrame(() => animateMobileCard(state));
      }

      document.querySelectorAll('.project-card-v').forEach((card) => {
        const img = card.querySelector('.card-work-img img') as HTMLImageElement;
        const container = card.querySelector('.project-image') as HTMLElement;
        if (!img || !container) return;
        mobileCards.push({
          card: card as HTMLElement, img, container,
          scrollPos: 0, scrollRaf: null, active: false, currentStop: 0,
          pauseCounter: 0, isPaused: false, delayCounter: 0, isDelaying: false, cachedMaxScroll: 0,
        });
      });

      // Single observer for all mobile cards (replaces N per-card observers)
      const mobileCardObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const state = mobileCards.find(s => s.card === entry.target);
          if (!state) return;
          if (entry.isIntersecting && !state.active) {
            state.active = true; state.card.classList.add('scroll-active');
            state.currentStop = 1; state.isPaused = false; state.pauseCounter = 0;
            state.isDelaying = true; state.delayCounter = 0;
            const startAnim = () => { state.cachedMaxScroll = state.img.offsetHeight - state.container.offsetHeight; if (!state.scrollRaf) state.scrollRaf = requestAnimationFrame(() => animateMobileCard(state)); };
            if (state.img.naturalHeight > 0) startAnim();
            else state.img.addEventListener('load', startAnim, { once: true });
          } else if (!entry.isIntersecting && state.active) {
            state.active = false; state.card.classList.remove('scroll-active'); state.currentStop = 0;
            if (!state.scrollRaf) state.scrollRaf = requestAnimationFrame(() => animateMobileCard(state));
          }
        });
      }, { threshold: 0.5 });
      mobileCards.forEach(s => mobileCardObs.observe(s.card));
    }

    // ── Card-work layer parallax — each layer moves independently on hover ──
    if (hasFineCursor) {
      document.querySelectorAll('[data-card-parallax]').forEach((container) => {
        const layers = container.querySelectorAll('[data-card-depth]');
        if (!layers.length) return;

        let targetX = 0, targetY = 0;
        const current = Array.from(layers, () => ({ x: 0, y: 0 }));
        let isHovering = false;
        let rafId: number | null = null;

        // Track which layers are nested inside other layers
        // so we can subtract the parent's movement
        const parentIndex: (number | null)[] = Array.from(layers, (el, i) => {
          for (let j = 0; j < layers.length; j++) {
            if (j !== i && layers[j].contains(el)) {
              // Find the closest ancestor layer
              let closest: number | null = null;
              for (let k = 0; k < layers.length; k++) {
                if (k !== i && layers[k].contains(el)) {
                  if (closest === null || layers[closest].contains(layers[k])) {
                    closest = k;
                  }
                }
              }
              return closest;
            }
          }
          return null;
        });

        function animateLayers() {
          layers.forEach((el, i) => {
            const depth = parseFloat((el as HTMLElement).dataset.cardDepth || '0.02');
            const goalX = isHovering ? targetX * depth * 800 : 0;
            const goalY = isHovering ? targetY * depth * 800 : 0;
            current[i].x += (goalX - current[i].x) * 0.06;
            current[i].y += (goalY - current[i].y) * 0.06;

            // Subtract parent movement so transforms don't compound
            let tx = current[i].x;
            let ty = current[i].y;
            if (parentIndex[i] !== null) {
              tx -= current[parentIndex[i]!].x;
              ty -= current[parentIndex[i]!].y;
            }

            (el as HTMLElement).style.transform = `translate3d(${tx}px, ${ty}px, 0)`;
          });

          if (!isHovering) {
            const settled = current.every(p => Math.abs(p.x) < 0.1 && Math.abs(p.y) < 0.1);
            if (settled) {
              layers.forEach((el) => { (el as HTMLElement).style.transform = 'translate3d(0, 0, 0)'; });
              rafId = null;
              return;
            }
          }
          rafId = requestAnimationFrame(animateLayers);
        }

        container.addEventListener('mouseenter', () => {
          isHovering = true;
          if (!rafId) rafId = requestAnimationFrame(animateLayers);
        }, { passive: true });

        container.addEventListener('mousemove', (e: Event) => {
          if (Math.abs(scrollVelocity) > 0.5) return;
          const me = e as MouseEvent;
          const rect = (container as HTMLElement).getBoundingClientRect();
          targetX = (me.clientX - rect.left - rect.width / 2) / rect.width;
          targetY = (me.clientY - rect.top - rect.height / 2) / rect.height;
        }, { passive: true });

        container.addEventListener('mouseleave', () => {
          isHovering = false;
          targetX = 0;
          targetY = 0;
          if (!rafId) rafId = requestAnimationFrame(animateLayers);
        }, { passive: true });
      });
    }

    // ── 3D tilt on project cards (state only — animation runs in main rAF) ──
    if (hasFineCursor) {
      document.querySelectorAll('[data-tilt]').forEach((card) => {
        const el = card as HTMLElement;
        const f = floatItems.find(item => item.el === el);
        if (!f) return;

        el.addEventListener('mouseenter', () => { f.tiltHovering = true; }, { passive: true });
        el.addEventListener('mousemove', (e: MouseEvent) => {
          if (Math.abs(scrollVelocity) > 0.5) return;
          const rect = el.getBoundingClientRect();
          const cx = rect.width / 2, cy = rect.height / 2;
          f.tiltTargetX = ((e.clientY - rect.top - cy) / cy) * -3;
          f.tiltTargetY = ((e.clientX - rect.left - cx) / cx) * 3;
        }, { passive: true });
        el.addEventListener('mouseleave', () => {
          f.tiltHovering = false;
          f.tiltTargetX = 0;
          f.tiltTargetY = 0;
        }, { passive: true });
      });
    }

    // ── Text scramble on project name — shared observer + hover ──
    if (hasFineCursor) {
      const SCRAMBLE_CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ&0123456789';
      const scrambleMap = new Map<Element, { original: string; intervalId: number | null }>();

      function runScramble(element: HTMLElement, data: { original: string; intervalId: number | null }) {
        if (data.intervalId) clearInterval(data.intervalId);
        let step = 0;
        const totalSteps = 14;
        data.intervalId = window.setInterval(() => {
          step++;
          let result = '';
          for (let i = 0; i < data.original.length; i++) {
            if (data.original[i] === ' ' || data.original[i] === '&') result += data.original[i];
            else if (step / totalSteps > i / data.original.length) result += data.original[i];
            else result += SCRAMBLE_CHARS[Math.floor(Math.random() * SCRAMBLE_CHARS.length)];
          }
          element.textContent = result;
          if (step >= totalSteps) {
            clearInterval(data.intervalId!);
            data.intervalId = null;
            element.textContent = data.original;
          }
        }, 40);
      }

      document.querySelectorAll('[data-scramble]').forEach((el) => {
        const element = el as HTMLElement;
        const data = { original: element.textContent?.trim() || '', intervalId: null as number | null };
        scrambleMap.set(element, data);
        element.addEventListener('mouseenter', () => runScramble(element, data));
        element.addEventListener('mouseleave', () => {
          if (data.intervalId) { clearInterval(data.intervalId); data.intervalId = null; }
          element.textContent = data.original;
        });
      });

      // Single observer for scroll-triggered scramble (replaces N per-element observers)
      const scrambleObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const data = scrambleMap.get(entry.target);
          if (data) runScramble(entry.target as HTMLElement, data);
          scrambleObs.unobserve(entry.target);
        });
      }, { threshold: 0.5 });
      scrambleMap.forEach((_, el) => scrambleObs.observe(el));
    }

    // ── 8. CONTACT — marquee, split reveal, form ──

    // Contact section — velocity-reactive marquee
    const marqueeSection = document.querySelector('[data-contact-marquee]');
    const leftTrack = document.querySelector('[data-marquee-track="left"]') as HTMLElement;
    const rightTrack = document.querySelector('[data-marquee-track="right"]') as HTMLElement;

    if (leftTrack && rightTrack) {
      let leftPos = 0;
      let rightPos = 0;
      const baseSpeed = 0.8;
      let marqueeActive = false;
      let marqueeVelocity = 0;

      // Track scroll velocity for marquee speed
      let lastMarqueeScroll = window.scrollY;
      window.addEventListener('scroll', () => {
        const now = window.scrollY;
        marqueeVelocity = (now - lastMarqueeScroll) * 0.5;
        lastMarqueeScroll = now;
      }, { passive: true });

      // Get the width of one full repeat unit (half the track since we duplicated content)
      function getResetWidth(track: HTMLElement) {
        return track.scrollWidth / 2;
      }

      function animateMarquee() {
        if (!marqueeActive) return;

        // Decay velocity smoothly and clamp to prevent jumps from anchor-link scrolls
        marqueeVelocity *= 0.92;
        if (Math.abs(marqueeVelocity) < 0.01) marqueeVelocity = 0;
        const clampedVel = Math.min(Math.abs(marqueeVelocity), 20);
        const speedMultiplier = 1 + clampedVel * 0.05;
        const speed = baseSpeed * speedMultiplier;

        const leftReset = getResetWidth(leftTrack);
        const rightReset = getResetWidth(rightTrack);

        // Left track moves left, right track moves right
        leftPos -= speed;
        rightPos += speed;

        if (Math.abs(leftPos) >= leftReset) leftPos = 0;
        if (rightPos >= rightReset) rightPos = 0;

        leftTrack.style.transform = `translate3d(${leftPos}px, 0, 0)`;
        rightTrack.style.transform = `translate3d(${rightPos - rightReset}px, 0, 0)`;

        requestAnimationFrame(animateMarquee);
      }

      // Start marquee when section enters viewport
      const marqueeObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            if (!marqueeActive) {
              marqueeActive = true;
              requestAnimationFrame(animateMarquee);
            }
            marqueeSection?.classList.add('revealed');
          } else {
            marqueeActive = false;
          }
        });
      }, { threshold: 0.1 });
      if (marqueeSection) marqueeObs.observe(marqueeSection);
    }

    // Contact split reveal — composites with float system via shared FloatItem state
    const contactDivider = document.querySelector('[data-contact-divider]') as HTMLElement | null;
    const contactLeft = document.querySelector('[data-contact-left]') as HTMLElement | null;
    const contactRight = document.querySelector('[data-contact-right]') as HTMLElement | null;
    const contactFields = Array.from(document.querySelectorAll('[data-contact-field]')) as HTMLElement[];
    const contactSend = document.querySelector('.contact-send') as HTMLElement | null;

    // Find the FloatItems for contact panels so reveal can compose with float
    const contactLeftFloat = floatItems.find(f => f.el === contactLeft);
    const contactRightFloat = floatItems.find(f => f.el === contactRight);

    // Initialize contact panels as hidden (reveal will animate them in)
    if (contactLeftFloat) { contactLeftFloat.revealOpacity = 0; contactLeftFloat.revealX = -12; contactLeftFloat.revealY = 20; }
    if (contactRightFloat) { contactRightFloat.revealOpacity = 0; contactRightFloat.revealX = 12; contactRightFloat.revealY = 20; }

    /** Contact reveal uses the shared easing with 1800ms default duration */
    const contactSmooth = (t: number, delay: number, dur = 1800) => easedReveal(t, delay, dur);

    if (contactDivider) {
      let contactRevealStart = 0;
      let contactRevealing = false;

      // Remove CSS transitions on non-float elements — JS drives everything
      [contactSend, ...contactFields].forEach(el => {
        if (el) el.style.transition = 'none';
      });

      function contactRevealLoop(now: number) {
        if (!contactRevealing) return;
        const t = now - contactRevealStart;

        // Divider line draws over 1.5s
        if (contactDivider) {
          const e = contactSmooth(t, 0, 1500);
          (contactDivider as HTMLElement).style.width = `${e * 100}%`;
        }

        // Left panel — update FloatItem reveal state (float loop composes the transform)
        if (contactLeftFloat) {
          const e = contactSmooth(t, 400, 1800);
          contactLeftFloat.revealOpacity = e;
          contactLeftFloat.revealX = (1 - e) * -12;
          contactLeftFloat.revealY = (1 - e) * 20;
        }

        // Right panel — update FloatItem reveal state
        if (contactRightFloat) {
          const e = contactSmooth(t, 700, 1800);
          contactRightFloat.revealOpacity = e;
          contactRightFloat.revealX = (1 - e) * 12;
          contactRightFloat.revealY = (1 - e) * 20;
        }

        // Form fields — staggered fade up (no float conflict, direct write OK)
        contactFields.forEach((field, i) => {
          const e = contactSmooth(t, 1000 + i * 250, 1500);
          field.style.opacity = `${e}`;
          field.style.transform = `translate3d(0, ${(1 - e) * 14}px, 0)`;
        });

        // Send button — last to appear
        if (contactSend) {
          const e = contactSmooth(t, 1000 + contactFields.length * 250 + 150, 1500);
          contactSend.style.opacity = `${e}`;
          contactSend.style.transform = `translate3d(0, ${(1 - e) * 14}px, 0)`;
        }

        // Keep running until everything is fully revealed
        const totalDuration = 1000 + contactFields.length * 250 + 150 + 1500;
        if (t < totalDuration + 100) {
          requestAnimationFrame(contactRevealLoop);
        }
      }

      const splitObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !contactRevealing) {
            contactRevealing = true;
            contactRevealStart = performance.now();
            requestAnimationFrame(contactRevealLoop);
            splitObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.25 });
      splitObs.observe(contactDivider);
    }

    // ── Contact form submit ──
    const formEl = document.getElementById('contact-form') as HTMLFormElement;
    const formSuccess = document.getElementById('form-success');
    const formError = document.getElementById('form-error');

    formEl?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(formEl);
      try {
        const response = await fetch(formEl.action, {
          method: 'POST',
          body: formData,
          headers: { Accept: 'application/json' },
        });
        if (response.ok) {
          formEl.style.display = 'none';
          formSuccess?.classList.remove('hidden');
        } else {
          formError?.classList.remove('hidden');
        }
      } catch {
        formError?.classList.remove('hidden');
      }
    });

    // ── About section scroll animations ──

    // ── About section reveals (shared observers — replaces N per-element observers) ──

    // About blocks — single observer for all blocks
    const aboutBlockObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          aboutBlockObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });
    document.querySelectorAll('[data-about-block]').forEach((el) => aboutBlockObs.observe(el));

    // Stat counters — single observer triggers count-up animation
    const statObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('revealed');
        const target = parseInt((entry.target as HTMLElement).dataset.statTarget || '0');
        const suffix = (entry.target as HTMLElement).dataset.statSuffix || '';
        const numEl = entry.target.querySelector('[data-stat-number]') as HTMLElement;
        if (numEl) {
          const duration = 1200;
          const start = performance.now();
          function countUp(now: number) {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            numEl.textContent = `${Math.round(eased * target)}${suffix}`;
            if (progress < 1) requestAnimationFrame(countUp);
          }
          requestAnimationFrame(countUp);
        }
        statObs.unobserve(entry.target);
      });
    }, { threshold: 0.3 });
    document.querySelectorAll('[data-stat]').forEach((el) => statObs.observe(el));

    // Approach items — single observer with stagger index stored as data attribute
    const approachEls = document.querySelectorAll('[data-approach]');
    const approachObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const idx = Array.prototype.indexOf.call(approachEls, entry.target);
          setTimeout(() => entry.target.classList.add('revealed'), idx * 120);
          approachObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });
    approachEls.forEach((el) => approachObs.observe(el));

    // Skill pills — staggered pop-in
    const pillContainer = document.querySelector('[data-skill-pills]');
    if (pillContainer) {
      const pillObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const pills = entry.target.querySelectorAll('.skill-pill');
            pills.forEach((pill, i) => {
              setTimeout(() => pill.classList.add('revealed'), i * 50);
            });
            pillObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2 });
      pillObs.observe(pillContainer);
    }

    // ── 9. THEME — 3-way switcher (light / system / dark) with blob transition ──
    function getEffectiveTheme(mode: string): string {
      if (mode === 'system') {
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      return mode;
    }

    function applyTheme(mode: string, button?: HTMLElement) {
      const effectiveTheme = getEffectiveTheme(mode);
      const overlay = document.getElementById('theme-transition');

      if (button && overlay) {
        const rect = button.getBoundingClientRect();
        const x = rect.left + rect.width / 2;
        const y = rect.top + rect.height / 2;
        const maxRadius = Math.ceil(Math.sqrt(
          Math.max(x, window.innerWidth - x) ** 2 +
          Math.max(y, window.innerHeight - y) ** 2
        ));
        const newBg = effectiveTheme === 'dark' ? '#0c0c0c' : '#FAFAFA';
        overlay.style.backgroundColor = newBg;
        overlay.style.transition = 'none';
        overlay.style.clipPath = `circle(0px at ${x}px ${y}px)`;
        overlay.offsetHeight;
        const duration = 900;
        const startTime = performance.now();
        function animateBlob(now: number) {
          const elapsed = now - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const eased = progress < 0.5 ? 4 * progress ** 3 : 1 - Math.pow(-2 * progress + 2, 3) / 2;
          const radius = eased * maxRadius;
          const w1 = Math.sin(progress * Math.PI * 3) * radius * 0.08;
          const w2 = Math.cos(progress * Math.PI * 2) * radius * 0.06;
          overlay.style.clipPath = `ellipse(${radius + w1}px ${radius + w2}px at ${x}px ${y}px)`;
          if (progress < 1) requestAnimationFrame(animateBlob);
          else overlay.style.clipPath = 'circle(0px at 50% 50%)';
        }
        requestAnimationFrame(animateBlob);
        setTimeout(() => {
          document.documentElement.dataset.theme = effectiveTheme;
          updateThemeMeta(effectiveTheme);
        }, duration * 0.4);
      } else {
        document.documentElement.dataset.theme = effectiveTheme;
        updateThemeMeta(effectiveTheme);
      }

      // Persist preference
      if (mode === 'system') {
        localStorage.removeItem('theme');
      } else {
        localStorage.setItem('theme', mode);
      }

      // Update active states on all option buttons
      document.querySelectorAll('.theme-option, .theme-option-mobile').forEach((btn) => {
        btn.classList.toggle('active', (btn as HTMLElement).dataset.themeValue === mode);
      });
    }

    function updateThemeMeta(effectiveTheme: string) {
      const meta = document.querySelector('meta[name="theme-color"]');
      if (meta) meta.setAttribute('content', effectiveTheme === 'dark' ? '#0c0c0c' : '#FAFAFA');
    }

    // Listen for system theme changes (applies only when mode is 'system')
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
      if (localStorage.getItem('theme')) return; // user chose light or dark explicitly
      const effectiveTheme = e.matches ? 'dark' : 'light';
      document.documentElement.dataset.theme = effectiveTheme;
      updateThemeMeta(effectiveTheme);
    });

    // Determine initial mode from localStorage
    const storedTheme = localStorage.getItem('theme');
    const initialMode = storedTheme || 'system';
    // Apply effective theme on load (no animation) to ensure system mode works
    const effectiveOnLoad = getEffectiveTheme(initialMode);
    document.documentElement.dataset.theme = effectiveOnLoad;
    updateThemeMeta(effectiveOnLoad);
    // Set correct active button on load
    document.querySelectorAll('.theme-option, .theme-option-mobile').forEach((btn) => {
      btn.classList.toggle('active', (btn as HTMLElement).dataset.themeValue === initialMode);
    });

    // Bind click handlers for all theme option buttons
    document.querySelectorAll('.theme-option, .theme-option-mobile').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        const mode = target.dataset.themeValue || 'system';
        applyTheme(mode, target);
      });
    });

    // ── JS-driven pill expand/collapse (uses shared smoothstep) ──
    const pillEl = document.querySelector('.theme-switcher-options') as HTMLElement | null;
    const labelEls = document.querySelectorAll('.theme-option-label') as NodeListOf<HTMLElement>;
    const themeSwitcherEl = document.getElementById('theme-switcher');
    const themePromptEl = document.getElementById('theme-prompt');

    if (pillEl && themeSwitcherEl) {
      const allOptions = pillEl.querySelectorAll('.theme-option') as NodeListOf<HTMLElement>;
      let pillAnim: number | null = null;
      let pillOpen = false;
      let introHolding = false;

      function animatePill(open: boolean, duration = 550) {
        if (pillAnim) cancelAnimationFrame(pillAnim);
        const startTime = performance.now();
        // Snapshot current state of each non-active option
        const inactiveOpts: HTMLElement[] = [];
        allOptions.forEach(o => { if (!o.classList.contains('active')) inactiveOpts.push(o); });

        // Show inactive options and labels for animation (they start as display:none)
        if (open) {
          inactiveOpts.forEach(o => { o.style.display = 'flex'; });
          labelEls.forEach(l => { l.style.display = 'inline'; });
        }

        // Set overflow hidden during animation
        pillEl!.style.overflow = 'hidden';

        function tick(now: number) {
          const elapsed = now - startTime;
          const raw = Math.min(elapsed / duration, 1);
          const t = smoothstep(raw);
          const val = open ? t : 1 - t;

          // Animate non-active options height + opacity
          inactiveOpts.forEach(o => {
            o.style.height = (val * 26) + 'px';
            o.style.opacity = String(val);
          });

          // All options stretch to fill width when expanded
          allOptions.forEach(o => {
            o.style.width = val > 0.01 ? '100%' : '';
            o.style.justifyContent = val > 0.01 ? 'flex-start' : 'center';
            o.style.paddingLeft = (val * 8) + 'px';
          });

          // Container: circle (32×32) → pill (auto height, wider)
          const r = 50 - val * 32; // 50% → 18%
          pillEl!.style.borderRadius = r + '%';
          pillEl!.style.width = (32 + val * 50) + 'px'; // 32px → 82px
          pillEl!.style.height = 'auto';
          pillEl!.style.gap = (val * 2) + 'px';
          pillEl!.style.justifyContent = val < 0.01 ? 'center' : 'flex-start';
          pillEl!.style.boxShadow = `0 ${8 * val}px 28px rgba(0,0,0,${val * 0.2})`;

          // Labels
          const labelDelay = open ? 0.25 : 0;
          const labelRaw = open
            ? Math.max(0, (raw - labelDelay) / (1 - labelDelay))
            : Math.min(raw / 0.4, 1);
          const labelVal = open ? smoothstep(labelRaw) : 1 - smoothstep(labelRaw);
          labelEls.forEach(l => {
            l.style.opacity = String(labelVal);
            l.style.maxWidth = (labelVal * 50) + 'px';
          });

          if (raw < 1) {
            pillAnim = requestAnimationFrame(tick);
          } else {
            pillAnim = null;
            if (!open) {
              // Clean collapsed: perfect circle, hide inactive
              inactiveOpts.forEach(o => {
                o.style.height = '0';
                o.style.opacity = '0';
                o.style.display = 'none';
              });
              // Reset active option to centered circle state
              allOptions.forEach(o => {
                if (o.classList.contains('active')) {
                  o.style.width = '24px';
                  o.style.height = '24px';
                  o.style.justifyContent = 'center';
                  o.style.paddingLeft = '0';
                }
              });
              labelEls.forEach(l => { l.style.opacity = '0'; l.style.maxWidth = '0'; l.style.display = 'none'; });
              pillEl!.style.borderRadius = '50%';
              pillEl!.style.width = '32px';
              pillEl!.style.height = '32px';
              pillEl!.style.overflow = 'visible';
            } else {
              pillEl!.style.overflow = 'visible';
            }
          }
        }
        pillAnim = requestAnimationFrame(tick);
      }

      // Hover handlers
      themeSwitcherEl.addEventListener('mouseenter', () => {
        if (!pillOpen && !introHolding) {
          pillOpen = true;
          animatePill(true);
        }
      });
      themeSwitcherEl.addEventListener('mouseleave', () => {
        if (pillOpen && !introHolding) {
          pillOpen = false;
          animatePill(false, 650); // slower close
        }
      });

      // ── Intro animation — tooltip + pill expand ──
      if (themePromptEl && !sessionStorage.getItem('theme-prompt-shown')) {
        sessionStorage.setItem('theme-prompt-shown', '1');

        // Step 1: tooltip + curly arrow fade in (2.5s after load)
        setTimeout(() => {
          themePromptEl.classList.add('visible');
          themeSwitcherEl.classList.add('intro-glow');

          // Step 2: pill expands smoothly (1s later)
          setTimeout(() => {
            introHolding = true;
            pillOpen = true;
            animatePill(true, 800);

            // Step 3: hold for 3s, then collapse
            setTimeout(() => {
              pillOpen = false;
              animatePill(false, 900);

              // Step 4: dismiss tooltip after pill starts closing
              setTimeout(() => {
                themePromptEl.classList.remove('visible');
                themeSwitcherEl.classList.remove('intro-glow');
                introHolding = false;
              }, 500);
            }, 3000);
          }, 1000);
        }, 2500);
      }
    }

    // ── 10. CLOCK — live Sydney time + analog clock (only ticks when footer visible) ──
    const clockHour = document.getElementById('clock-hour');
    const clockMinute = document.getElementById('clock-minute');
    const clockSecond = document.getElementById('clock-second');

    const footerEl = document.querySelector('footer');
    let clockIntervalId: ReturnType<typeof setInterval> | null = null;

    function updateSydneyTime() {
      const el = document.getElementById('sydney-time');
      const now = new Date();
      const parts = new Intl.DateTimeFormat('en-AU', {
        timeZone: 'Australia/Sydney',
        hour: 'numeric', minute: 'numeric', second: 'numeric',
        hour12: false,
      }).formatToParts(now);
      const h = Number(parts.find(p => p.type === 'hour')?.value ?? 0);
      const m = Number(parts.find(p => p.type === 'minute')?.value ?? 0);
      const s = Number(parts.find(p => p.type === 'second')?.value ?? 0);
      if (el) el.textContent = `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
      const hourDeg = ((h % 12) / 12) * 360 + (m / 60) * 30;
      const minDeg = (m / 60) * 360 + (s / 60) * 6;
      const secDeg = (s / 60) * 360;
      if (clockHour) clockHour.style.transform = `translateX(-50%) rotate(${hourDeg}deg)`;
      if (clockMinute) clockMinute.style.transform = `translateX(-50%) rotate(${minDeg}deg)`;
      if (clockSecond) clockSecond.style.transform = `translateX(-50%) rotate(${secDeg}deg)`;
    }

    // Only tick clock when footer is visible
    if (footerEl) {
      const footerObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            updateSydneyTime();
            if (!clockIntervalId) clockIntervalId = setInterval(updateSydneyTime, 1000);
          } else {
            if (clockIntervalId) { clearInterval(clockIntervalId); clockIntervalId = null; }
          }
        });
      }, { threshold: 0 });
      footerObs.observe(footerEl);
    }
  </script>
</Layout>
