    ]);
    addSectionDepth('about', [
      { selector: '.about-depth-number', tx: 0, ty: -50 },
      { selector: '.about-depth-line', tx: 0, ty: 28 },
      { selector: '.about-depth-ring', tx: -6, ty: 22 },
    ]);

    // ── Card layer parallax setup ──
    interface CardLayer {
      card: HTMLElement;
      indexEl: HTMLElement;
      blockEl: HTMLElement;
      strokeEl: HTMLElement | null;
      lineEl: HTMLElement | null;
      labelEl: HTMLElement | null;
      visible: boolean;
      hoverX: number;
      hoverY: number;
      currentHoverX: number;
      currentHoverY: number;
      hovering: boolean;
    }
    const cardLayers: CardLayer[] = [];
    document.querySelectorAll('.project-card-v').forEach((card) => {
      const indexEl = card.querySelector('[data-card-layer="index"]') as HTMLElement;
      const blockEl = card.querySelector('[data-card-layer="block"]') as HTMLElement;
      const strokeEl = card.querySelector('[data-card-layer="stroke"]') as HTMLElement | null;
      const lineEl = card.querySelector('[data-card-layer="line"]') as HTMLElement | null;
      const labelEl = card.querySelector('[data-card-layer="label"]') as HTMLElement | null;
      if (!indexEl || !blockEl) return;
      const cl: CardLayer = {
        card: card as HTMLElement, indexEl, blockEl, strokeEl, lineEl, labelEl, visible: false,
        hoverX: 0, hoverY: 0, currentHoverX: 0, currentHoverY: 0, hovering: false,
      };
      cardLayers.push(cl);

      // Hover tracking for layer parallax
      if (window.matchMedia('(pointer: fine)').matches) {
        card.addEventListener('mouseenter', () => { cl.hovering = true; }, { passive: true });
        card.addEventListener('mousemove', (e: Event) => {
          if (Math.abs(scrollVelocity) > 0.5) return;
          const me = e as MouseEvent;
          const rect = (card as HTMLElement).getBoundingClientRect();
          cl.hoverX = (me.clientX - rect.left - rect.width / 2) / rect.width;
          cl.hoverY = (me.clientY - rect.top - rect.height / 2) / rect.height;
        }, { passive: true });
        card.addEventListener('mouseleave', () => {
          cl.hovering = false;
          cl.hoverX = 0;
          cl.hoverY = 0;
        }, { passive: true });
      }
    });

    if (cardLayers.length > 0) {
      const cardLayerVis = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const cl = cardLayers.find(c => c.card === entry.target);
          if (cl) cl.visible = entry.isIntersecting;
        });
      }, { threshold: 0, rootMargin: '100px 0px 100px 0px' });
      cardLayers.forEach(cl => cardLayerVis.observe(cl.card));
    }

    // ── Section depth layer parallax setup ──
    interface DepthLayer {
      container: HTMLElement;
      deepEl: HTMLElement | null;
      midEl: HTMLElement | null;
      visible: boolean;
    }
    const depthLayers: DepthLayer[] = [];
    document.querySelectorAll('[data-depth-container]').forEach((container) => {
      const deepEl = container.querySelector('[data-depth-layer="deep"]') as HTMLElement | null;
      const midEl = container.querySelector('[data-depth-layer="mid"]') as HTMLElement | null;
      if (!deepEl && !midEl) return;
      depthLayers.push({
        container: container as HTMLElement,
        deepEl,
        midEl,
        visible: false,
      });
    });

    if (depthLayers.length > 0) {
      const depthVis = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const dl = depthLayers.find(d => d.container === entry.target);
          if (dl) dl.visible = entry.isIntersecting;
        });
      }, { threshold: 0, rootMargin: '100px 0px 100px 0px' });
      depthLayers.forEach(dl => depthVis.observe(dl.container));
    }

    // Handle anchor clicks with native smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener('click', (e) => {
        e.preventDefault();
        const href = (anchor as HTMLAnchorElement).getAttribute('href');
        if (!href) return;
        const target = document.querySelector(href);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth' });
          const mobileMenu = document.getElementById('mobile-menu');
          if (mobileMenu?.classList.contains('open')) {
            mobileMenu.classList.remove('open');
            document.body.style.overflow = '';
          }
        }
      });
    });

    // ── Pre-decode project thumbnails so they're pixel-ready before scroll ──
    document.querySelectorAll('.project-image-inner').forEach((img: HTMLImageElement) => {
      if (img.complete) {
        img.decode().catch(() => {});
      } else {
        img.addEventListener('load', () => img.decode().catch(() => {}), { once: true });
      }
    });

    // ── Loader ──
    const loader = document.getElementById('loader');
    const heroName = document.getElementById('hero-name');
    const heroSubtitle = document.getElementById('hero-subtitle');

    window.addEventListener('load', () => {
      setTimeout(() => {
        loader?.classList.add('done');
        setTimeout(() => {
          if (loader) loader.style.display = 'none';
          document.body.classList.add('loaded');
          startHeroTypewriter();
        }, 800);
      }, 400);
    });

    // ── Hero name typewriter ──
    function startHeroTypewriter() {
      if (!heroName) return;
      const text = heroName.textContent?.trim() || '';
      heroName.textContent = '';
      heroName.style.minHeight = '1em';
      heroName.style.visibility = 'visible';

      const cursor = document.createElement('span');
      cursor.classList.add('tw-cursor');

      let charIdx = 0;
      const scrollIndicator = document.getElementById('scroll-indicator');

      function typeNext() {
        if (charIdx >= text.length) {
          // Fade cursor out instead of removing (avoids layout snap)
          cursor.style.transition = 'opacity 1s ease';
          cursor.style.opacity = '0';

          // Reveal subtitle and scroll indicator via JS opacity/transform
          // (no CSS transitions — float will handle transforms)
          const subLines = heroSubtitle?.querySelectorAll('.subtitle-line') as NodeListOf<HTMLElement>;

          // Start float immediately — it handles reveal + drift together
          const floatEls = [
            { el: heroName, speed: 0.0008, amp: 12, phase: 0 },
            { el: heroSubtitle, speed: 0.0006, amp: 10, phase: 2 },
            { el: scrollIndicator, speed: 0.0005, amp: 8, phase: 4 },
          ];
          const startTime = performance.now();
          const rampDuration = 2500;

          // Reveal timings (ms after typing ends)
          const subtitleDelay = 150;
          const sub2Delay = 400;
          const scrollDelay = 600;
          const statusDelay = 100;
          const servicesDelay = 500;
          const watermarkDelay = 200;

          // Grab hero detail elements
          const heroStatusEl = document.querySelector('.hero-status') as HTMLElement | null;
          const heroServicesEl = document.querySelector('.hero-services') as HTMLElement | null;
          const heroWatermarkEl = document.querySelector('.hero-watermark') as HTMLElement | null;
          const heroRuleEl = document.querySelector('.hero-rule') as HTMLElement | null;
          const heroYearEl = document.querySelector('.hero-year') as HTMLElement | null;
          const heroBarEl = document.querySelector('.hero-accent-bar') as HTMLElement | null;
          const heroRingEl = document.querySelector('.hero-accent-ring') as HTMLElement | null;
          const heroGridEl = document.querySelector('.hero-grid-overlay') as HTMLElement | null;
          const heroSectionIndex = document.querySelector('.hero-section-index') as HTMLElement | null;
          const heroTitleBlock = document.querySelector('.hero-title-block') as HTMLElement | null;
          const heroTitleLine = document.querySelector('.hero-title-line') as HTMLElement | null;
          const heroCtaEl = document.querySelector('.hero-cta') as HTMLElement | null;
          const heroDataLine = document.querySelector('.hero-data-line') as HTMLElement | null;
          const heroCoordsEls = Array.from(document.querySelectorAll('.hero-coord')) as HTMLElement[];

          // Gate hero float to only run when hero is in viewport
          let heroInView = true;
          const heroSection = document.getElementById('hero');
          if (heroSection) {
            const heroVis = new IntersectionObserver((entries) => {
              entries.forEach((entry) => {
                heroInView = entry.isIntersecting;
              });
            }, { threshold: 0 });
            heroVis.observe(heroSection);
          }

          // Helper: smoothstep reveal (same as subtitle)
          function smoothReveal(t: number, delay: number, duration = 2000) {
            const r = Math.min(1, Math.max(0, (t - delay) / duration));
            return r * r * (3 - 2 * r);
          }

          // ── Canvas dot grid with per-dot shimmer ──
          // Viewport-sized canvas. Parallax + shimmer in draw loop.
          // Dots drawn as fillRect (integer coords) — no anti-aliasing jitter.
          const dotCanvas = document.getElementById('dot-grid') as HTMLCanvasElement | null;
          let dotCtx: CanvasRenderingContext2D | null = null;
          const DOT_SPACING = 28;
          // Total grid covers entire document — per-dot properties seeded by grid index
          const TOTAL_COLS = 200; // enough for any viewport width
          const TOTAL_ROWS = 600; // enough for full page height with parallax
          const TOTAL_DOTS = TOTAL_COLS * TOTAL_ROWS;
          // Pre-compute per-dot properties using deterministic seed from grid index
          const dotPhases = new Float32Array(TOTAL_DOTS);
          const dotJitterX = new Float32Array(TOTAL_DOTS);
          const dotJitterY = new Float32Array(TOTAL_DOTS);
          const dotSizes = new Float32Array(TOTAL_DOTS);
          const dotBrightness = new Float32Array(TOTAL_DOTS);
          // Simple seeded PRNG for deterministic per-dot properties
          function mulberry32(a: number) { return () => { a |= 0; a = a + 0x6D2B79F5 | 0; let t = Math.imul(a ^ a >>> 15, 1 | a); t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t; return ((t ^ t >>> 14) >>> 0) / 4294967296; }; }
          for (let i = 0; i < TOTAL_DOTS; i++) {
            const rng = mulberry32(i * 2654435761);
            dotPhases[i] = rng() * Math.PI * 2;
            dotJitterX[i] = (rng() - 0.5) * 10;
            dotJitterY[i] = (rng() - 0.5) * 10;
            dotSizes[i] = 1 + Math.round(rng() * 2); // 1, 2, or 3 px squares
            dotBrightness[i] = 0.2 + rng() * 0.8;
          }
          let dotW = 0, dotH = 0, dotDpr = 1;
          let lastShimmerDraw = 0;

          if (dotCanvas) {
            dotCtx = dotCanvas.getContext('2d');
            function resizeDotGrid() {
              dotDpr = window.devicePixelRatio || 1;
              dotW = window.innerWidth;
              dotH = window.innerHeight;
              dotCanvas!.width = dotW * dotDpr;
              dotCanvas!.height = dotH * dotDpr;
              dotCanvas!.style.width = dotW + 'px';
              dotCanvas!.style.height = dotH + 'px';
              lastShimmerDraw = 0;
            }
            resizeDotGrid();
            window.addEventListener('resize', resizeDotGrid);
          }

          let smoothScrollY = window.scrollY || 0;

          function heroFloat(now: number) {
            if (dotCanvas && dotCtx) {
              const t0 = now - startTime;
              const revealEase = smoothReveal(t0, subtitleDelay, 2500);
              const isDark = document.documentElement.dataset.theme === 'dark';
              const baseAlpha = isDark ? 0.10 : 0.18;
              const masterAlpha = revealEase * baseAlpha;

              // Smooth scroll lerp — runs every frame (60fps)
              const targetScrollY = window.scrollY || 0;
              smoothScrollY += (targetScrollY - smoothScrollY) * 0.06;
              dotCanvas.style.opacity = `${revealEase}`;

              // Full redraw every frame — fillRect is fast, no anti-alias jitter
              dotCtx.setTransform(dotDpr, 0, 0, dotDpr, 0, 0);
              dotCtx.clearRect(0, 0, dotW, dotH);

              const dotColor = isDark ? '255,255,255' : '0,0,0';
              const time = now * 0.001;

              // Parallax offset
              const parallaxY = smoothScrollY * 0.3;
              const parallaxX = Math.sin(smoothScrollY * 0.0006) * 15;

              // Which grid rows/cols are visible
              const startRow = Math.max(0, Math.floor((parallaxY - 15) / DOT_SPACING));
              const endRow = Math.min(TOTAL_ROWS, Math.ceil((parallaxY + dotH + 15) / DOT_SPACING));
              const startCol = Math.max(0, Math.floor((parallaxX - 15) / DOT_SPACING));
              const endCol = Math.min(TOTAL_COLS, Math.ceil((parallaxX + dotW + 15) / DOT_SPACING));

              dotCtx.fillStyle = `rgb(${dotColor})`;
              for (let row = startRow; row < endRow; row++) {
                for (let col = startCol; col < endCol; col++) {
                  const idx = row * TOTAL_COLS + col;
                  const shimmer = 0.5 + 0.35 * Math.sin(time * 3.0 + dotPhases[idx]) + 0.15 * Math.sin(time * 7.0 + dotPhases[idx] * 2.3);
                  const alpha = masterAlpha * dotBrightness[idx] * (0.1 + 0.9 * shimmer);
                  if (alpha < 0.01) continue;

                  // World → screen position
                  const x = col * DOT_SPACING + dotJitterX[idx] - parallaxX;
                  const y = row * DOT_SPACING + dotJitterY[idx] - parallaxY;

                  dotCtx.globalAlpha = alpha;
                  dotCtx.fillRect(x, y, dotSizes[idx], dotSizes[idx]);
                }
              }
              dotCtx.globalAlpha = 1;
            }

            if (!heroInView) {
              requestAnimationFrame(heroFloat);
              return;
            }
            const t = now - startTime;
            const ramp = Math.min(1, t / rampDuration);
            const easedRamp = ramp * ramp * (3 - 2 * ramp);

            // Float the title
            const titleY = (Math.sin(t * 0.0008) * 12 + Math.sin(t * 0.00056 + 1) * 4.8) * easedRamp;
            heroName.style.transform = `translateY(${titleY}px)`;

            // Reveal + float subtitle
            if (heroSubtitle) {
              heroSubtitle.style.opacity = '1';
              if (subLines) {
                subLines.forEach((line, i) => {
                  const delay = i === 0 ? subtitleDelay : sub2Delay;
                  const eased = smoothReveal(t, delay);
                  const floatY = (Math.sin(t * 0.0006 + 2) * 10 + Math.sin(t * 0.00042 + 3) * 4) * easedRamp;
                  const revealY = (1 - eased) * 24;
                  line.style.opacity = `${eased}`;
                  line.style.transform = `translateY(${revealY + floatY}px)`;
                });
              }
            }

            // Reveal + float scroll indicator
            if (scrollIndicator) {
              const sEased = smoothReveal(t, scrollDelay);
              const sFloatY = (Math.sin(t * 0.0005 + 4) * 8 + Math.sin(t * 0.00035 + 5) * 3.2) * easedRamp;
              const sRevealY = (1 - sEased) * 20;
              scrollIndicator.style.opacity = `${sEased}`;
              scrollIndicator.style.transform = `translateY(${sRevealY + sFloatY}px)`;
            }

            // Reveal status line
            if (heroStatusEl) {
              const e = smoothReveal(t, statusDelay);
              heroStatusEl.style.opacity = `${e * 0.7}`;
              heroStatusEl.style.transform = `translateY(${(1 - e) * 16}px)`;
            }

            // Reveal services
            if (heroServicesEl) {
              const e = smoothReveal(t, servicesDelay);
              heroServicesEl.style.opacity = `${e * 0.5}`;
              heroServicesEl.style.transform = `translateY(${(1 - e) * 16}px)`;
            }

            // Reveal CTA (after services)
            if (heroCtaEl) {
              const e = smoothReveal(t, 650, 2000);
              heroCtaEl.style.opacity = `${e}`;
              heroCtaEl.style.transform = `translateY(${(1 - e) * 12}px)`;
            }

            // Reveal data line (mid-depth horizontal accent)
            if (heroDataLine) {
              const e = smoothReveal(t, 300, 3000);
              heroDataLine.style.opacity = `${e}`;
            }

            // Reveal watermark
            if (heroWatermarkEl) {
              const e = smoothReveal(t, watermarkDelay, 3000);
              const isDark = document.documentElement.dataset.theme === 'dark';
              heroWatermarkEl.style.opacity = `${e * (isDark ? 0.03 : 0.018)}`;
              heroWatermarkEl.style.transform = `translateY(${(1 - e) * 30}px)`;
            }

            // Reveal accent rule
            if (heroRuleEl) {
              const e = smoothReveal(t, subtitleDelay);
              heroRuleEl.style.opacity = `${e}`;
              heroRuleEl.style.transform = `scaleX(${e})`;
            }

            // Reveal year marker (deep layer)
            if (heroYearEl) {
              const e = smoothReveal(t, 300, 2500);
              const isDark = document.documentElement.dataset.theme === 'dark';
              heroYearEl.style.opacity = `${e * (isDark ? 0.06 : 0.04)}`;
              heroYearEl.style.transform = `translateY(${(1 - e) * 20}px)`;
            }

            // Reveal accent bar (mid layer)
            if (heroBarEl) {
              const e = smoothReveal(t, 400, 2500);
              const isDark = document.documentElement.dataset.theme === 'dark';
              heroBarEl.style.opacity = `${e * (isDark ? 0.12 : 0.08)}`;
            }

            // Reveal accent ring (mid layer)
            if (heroRingEl) {
              const e = smoothReveal(t, 350, 2500);
              const isDark = document.documentElement.dataset.theme === 'dark';
              heroRingEl.style.opacity = `${e * (isDark ? 0.08 : 0.05)}`;
              heroRingEl.style.transform = `scale(${0.8 + e * 0.2})`;
            }

            // Reveal grid overlay (deep layer)
            if (heroGridEl) {
              const e = smoothReveal(t, 200, 3000);
              const isDark = document.documentElement.dataset.theme === 'dark';
              heroGridEl.style.opacity = `${e * (isDark ? 0.05 : 0.03)}`;
            }

            // (dot grid parallax handled above, outside heroInView check)

            // Reveal hero title depth layers (timed with typewriter)
            if (heroSectionIndex) {
              const e = smoothReveal(t, watermarkDelay, 2500);
              const isDark = document.documentElement.dataset.theme === 'dark';
              heroSectionIndex.style.opacity = `${e * (isDark ? 0.05 : 0.03)}`;
              heroSectionIndex.style.transform = `translateY(${(1 - e) * 25}px)`;
            }
            if (heroTitleBlock) {
              const e = smoothReveal(t, 100, 2500);
              const isDark = document.documentElement.dataset.theme === 'dark';
              heroTitleBlock.style.opacity = `${e * (isDark ? 0.04 : 0.025)}`;
              heroTitleBlock.style.transform = `translateX(${(1 - e) * 20}px)`;
            }
            if (heroTitleLine) {
              const e = smoothReveal(t, subtitleDelay, 2000);
              const isDark = document.documentElement.dataset.theme === 'dark';
              heroTitleLine.style.opacity = `${e * (isDark ? 0.15 : 0.1)}`;
              heroTitleLine.style.transform = `scaleX(${e})`;
              heroTitleLine.style.transformOrigin = 'left';
            }

            // Reveal coordinates
            heroCoordsEls.forEach((c, i) => {
              const e = smoothReveal(t, 600 + i * 200, 2000);
              c.style.opacity = `${e * 0.3}`;
              c.style.transform = `translateY(${(1 - e) * 10}px)`;
            });

            requestAnimationFrame(heroFloat);
          }
          requestAnimationFrame(heroFloat);
          return;
        }
        heroName.textContent = text.slice(0, charIdx + 1);
        heroName.appendChild(cursor);
        charIdx++;
        const ch = text[charIdx - 1];
        const delay = ch === ' ' ? 40 : 30 + Math.random() * 20;
        setTimeout(typeNext, delay);
      }
      typeNext();
    }

    // ── Scroll-triggered reveals ──
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('[data-reveal]').forEach((el) => {
      revealObserver.observe(el);
    });
    // Section marks — reuse same reveal observer
    document.querySelectorAll('.section-mark').forEach((el) => {
      revealObserver.observe(el);
    });

    // (Float moved to Lenis rAF loop above — uses style.transform instead of style.translate)

    // ── Section dividers ──
    document.querySelectorAll('[data-divider]').forEach((el) => {
      const obs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              setTimeout(() => (entry.target as HTMLElement).classList.add('animate-in'), 200);
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      obs.observe(el);
    });

    // ── Section heading char reveal ──
    document.querySelectorAll('[data-heading-reveal]').forEach((wrap) => {
      const heading = wrap.querySelector('.section-heading') as HTMLElement;
      if (!heading) return;
      const text = heading.textContent?.trim() || '';
      heading.innerHTML = '';
      text.split('').forEach((char, i) => {
        const span = document.createElement('span');
        span.textContent = char === ' ' ? '\u00A0' : char;
        span.classList.add('heading-char');
        span.style.transitionDelay = `${i * 0.04}s`;
        heading.appendChild(span);
      });

      const obs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              heading.classList.add('revealed');
              (entry.target as HTMLElement).classList.add('revealed');
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.2 }
      );
      obs.observe(wrap);

      // Hover bounce on heading chars (desktop) / scroll-triggered bounce (mobile)
      if (hasFineCursor) {
        heading.addEventListener('mouseenter', () => {
          heading.querySelectorAll('.heading-char').forEach((ch, i) => {
            (ch as HTMLElement).style.animation = `none`;
            setTimeout(() => {
              (ch as HTMLElement).style.animation = ``;
              (ch as HTMLElement).style.transform = 'translateY(-8px)';
              setTimeout(() => {
                (ch as HTMLElement).style.transform = '';
              }, 150);
            }, i * 30);
          });
        });
      } else {
        // On mobile, bounce chars when section heading scrolls into view
        const bounceObs = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              heading.querySelectorAll('.heading-char').forEach((ch, i) => {
                setTimeout(() => {
                  (ch as HTMLElement).style.transform = 'translateY(-6px)';
                  setTimeout(() => {
                    (ch as HTMLElement).style.transform = '';
                  }, 150);
                }, i * 30);
              });
              bounceObs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.8 });
        bounceObs.observe(wrap);
      }
    });

    // ── Manifesto word-by-word scroll reveal (setup) ──
    const manifestoData: { el: Element; wordSpans: NodeListOf<Element>; totalWords: number }[] = [];
    document.querySelectorAll('[data-manifesto]').forEach((el) => {
      const text = el.textContent?.trim() || '';
      el.innerHTML = '';
      const words = text.split(/\s+/);
      words.forEach((word, i) => {
        const span = document.createElement('span');
        span.textContent = word;
        span.classList.add('manifesto-word');
        el.appendChild(span);
        if (i < words.length - 1) el.appendChild(document.createTextNode(' '));
      });
      manifestoData.push({ el, wordSpans: el.querySelectorAll('.manifesto-word'), totalWords: words.length });
    });

    // ── Process tagline typewriter ──
    const processTypewriter = document.querySelector('[data-process-typewriter]') as HTMLElement;
    const processSub = document.querySelector('[data-process-sub]') as HTMLElement;

    if (processTypewriter) {
      const fullText = processTypewriter.getAttribute('aria-label') || '';
      let started = false;

      const twObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !started) {
            started = true;
            let idx = 0;
            const cursor = document.createElement('span');
            cursor.className = 'tw-cursor';

            function typeChar() {
              if (idx >= fullText.length) {
                cursor.remove();
                // Fade in the sub-line
                if (processSub) {
                  processSub.style.transition = 'opacity 0.6s ease';
                  processSub.style.opacity = '1';
                }
                return;
              }
              processTypewriter.textContent = fullText.slice(0, idx + 1);
              processTypewriter.appendChild(cursor);
              idx++;
              const ch = fullText[idx - 1];
              const delay = ch === '.' ? 140 : ch === ',' ? 80 : ch === ' ' ? 30 : 25;
              setTimeout(typeChar, delay);
            }
            typeChar();
            twObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });
      twObs.observe(processTypewriter);
    }

    // ── Process steps (setup) ──
    const processSteps = document.querySelectorAll('[data-process-step]');
    const processRailFill = document.querySelector('[data-process-rail]') as HTMLElement;
    const processTimeline = document.querySelector('.process-timeline') as HTMLElement;

    // Staggered reveal for process steps
    if (processSteps.length > 0) {
      const stepRevealObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            stepRevealObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });
      processSteps.forEach((step) => stepRevealObs.observe(step));
    }

    // ── Nav / scroll progress (setup) ──
    const scrollProgress = document.getElementById('scroll-progress');
    const navTop = document.getElementById('nav-top');
    const sections = document.querySelectorAll('section[id]');
    const navNodes = document.querySelectorAll('.nav-node[data-nav-section]');
    const navMobileLinks = document.querySelectorAll('.nav-mobile-link[data-nav-section]');
    const navRailProgress = document.getElementById('nav-rail-progress');

    // ── IntersectionObserver for active section (replaces per-frame getBoundingClientRect) ──
    let currentSection = 'hero';
    let lastActiveSection = '';
    const sectionObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          currentSection = entry.target.id;
        }
      });
    }, { threshold: 0, rootMargin: '-199px 0px -50% 0px' });
    sections.forEach((s) => sectionObs.observe(s));

    // ── IntersectionObserver for manifesto visibility ──
    const manifestoVisible = new Map<Element, boolean>();
    manifestoData.forEach(({ el }) => manifestoVisible.set(el, false));
    const manifestoObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        manifestoVisible.set(entry.target, entry.isIntersecting);
      });
    }, { threshold: 0.05 });
    manifestoData.forEach(({ el }) => manifestoObs.observe(el));

    // ── IntersectionObserver for process timeline visibility ──
    let processVisible = false;
    if (processTimeline) {
      const processObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          processVisible = entry.isIntersecting;
        });
      }, { threshold: 0.05 });
      processObs.observe(processTimeline);
    }

    // ── Skew (variables — logic runs in Lenis rAF above) ──

    // ── Parallax (setup) ──
    const hasPointer = window.matchMedia('(pointer: fine)').matches;
    const parallaxElements = hasPointer ? document.querySelectorAll('[data-parallax]') : [];
    const parallaxVisible = new Set<Element>();
    if (hasPointer && parallaxElements.length > 0) {
      const parObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) parallaxVisible.add(entry.target);
          else parallaxVisible.delete(entry.target);
        });
      }, { threshold: 0, rootMargin: '100px 0px 100px 0px' });
      parallaxElements.forEach((el) => parObs.observe(el));
    }

    // ── Unified scroll handler (one rAF per frame) ──
    let scrollTicking = false;
    const heroScrollFade = document.querySelector('.hero-scroll-fade') as HTMLElement | null;

    function onScrollFrame() {
      const scrollTop = window.scrollY;
      const viewH = window.innerHeight;
      const docHeight = document.documentElement.scrollHeight - viewH;
      const scrollPct = docHeight > 0 ? scrollTop / docHeight : 0;

      // Scroll progress bar
      if (scrollProgress) scrollProgress.style.width = `${scrollPct * 100}%`;

      // Hero scroll-fade — content fades and lifts as user scrolls
      if (heroScrollFade) {
        const fadeEnd = viewH * 0.6;
        const fadeProg = Math.min(1, Math.max(0, scrollTop / fadeEnd));
        heroScrollFade.style.opacity = String(1 - fadeProg);
        heroScrollFade.style.transform = `translateY(${fadeProg * -40}px)`;
      }

      // Nav top background
      const shouldScroll = scrollTop > 80;
      if (shouldScroll !== navTop?.classList.contains('scrolled')) {
        navTop?.classList.toggle('scrolled', shouldScroll);
      }

      // Nav rail progress line
      if (navRailProgress) navRailProgress.style.height = `${scrollPct * 100}%`;

      // Active section detection (driven by IntersectionObserver, only update on change)
      if (currentSection !== lastActiveSection) {
        lastActiveSection = currentSection;
        navNodes.forEach((node) => {
          const section = (node as HTMLElement).dataset.navSection;
          node.classList.toggle('active', section === currentSection);
        });
        navMobileLinks.forEach((link) => {
          const section = (link as HTMLElement).dataset.navSection;
          link.classList.toggle('active', section === currentSection);
        });
      }

      // Manifesto word-by-word reveal (only when visible)
      manifestoData.forEach(({ el, wordSpans, totalWords }) => {
        if (!manifestoVisible.get(el)) return;
        const rect = el.getBoundingClientRect();
        const start = viewH * 0.85;
        const end = viewH * 0.15;
        const progress = Math.max(0, Math.min(1, (start - rect.top) / (start - end)));
        const litCount = Math.floor(progress * totalWords);
        wordSpans.forEach((w, i) => {
          w.classList.toggle('lit', i < litCount);
        });
      });

      // Process step highlighting + rail fill (only when visible)
      if (processSteps.length > 0 && processTimeline && processVisible) {
        const viewCenter = viewH * 0.5;
        let closestStep: Element | null = null;
        let closestDist = Infinity;
        let activeIndex = 0;
        processSteps.forEach((step, i) => {
          const rect = step.getBoundingClientRect();
          const stepCenter = rect.top + rect.height / 2;
          const dist = Math.abs(stepCenter - viewCenter);
          if (dist < closestDist && rect.top < viewH && rect.bottom > 0) {
            closestDist = dist;
            closestStep = step;
            activeIndex = i;
          }
        });
        processSteps.forEach((step) => step.classList.toggle('active', step === closestStep));

        // Fill the rail based on active step
        if (processRailFill) {
          const fillPct = (activeIndex + 1) / processSteps.length;
          processRailFill.style.transform = `scaleY(${fillPct})`;
        }
      }

      // (Skew moved to Lenis rAF loop for continuous decay)

      // Parallax depth layers (only visible elements)
      if (hasPointer) {
        parallaxVisible.forEach((el) => {
          const htmlEl = el as HTMLElement;
          if (htmlEl.id === 'hero-name') return;
          const speed = parseFloat(htmlEl.dataset.parallax || '0');
          const rect = el.getBoundingClientRect();
          const offset = (rect.top + rect.height / 2 - viewH / 2) * speed;
          htmlEl.style.transform = `translateY(${offset}px)`;
        });
      }

      scrollTicking = false;
    }

    window.addEventListener('scroll', () => {
      if (!scrollTicking) {
        scrollTicking = true;
        requestAnimationFrame(onScrollFrame);
      }
    }, { passive: true });

    // Run once on load
    onScrollFrame();

    // ── Mobile menu ──
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuLine1 = document.getElementById('menu-line-1');
    const menuLine2 = document.getElementById('menu-line-2');

    menuToggle?.addEventListener('click', () => {
      const isOpen = mobileMenu?.classList.contains('open');
      if (isOpen) {
        mobileMenu?.classList.remove('open');
        document.body.style.overflow = '';
        if (menuLine1) menuLine1.style.transform = '';
        if (menuLine2) menuLine2.style.transform = '';
      } else {
        mobileMenu?.classList.add('open');
        document.body.style.overflow = 'hidden';
        if (menuLine1) menuLine1.style.transform = 'translateY(3.25px) rotate(45deg)';
        if (menuLine2) menuLine2.style.transform = 'translateY(-3.25px) rotate(-45deg)';
      }
    });

    // ── Magnetic hover elements ──
    if (hasFineCursor) {
      const magneticEls = document.querySelectorAll('[data-magnetic]');
      magneticEls.forEach((el) => {
        const htmlEl = el as HTMLElement;
        const strength = parseFloat(htmlEl.dataset.magnetic || '0.3');
        htmlEl.addEventListener('mousemove', (e: Event) => {
          const me = e as MouseEvent;
          const rect = htmlEl.getBoundingClientRect();
          const cx = rect.left + rect.width / 2;
          const cy = rect.top + rect.height / 2;
          const dx = (me.clientX - cx) * strength;
          const dy = (me.clientY - cy) * strength;
          htmlEl.style.transform = `translate(${dx}px, ${dy}px)`;
        });
        htmlEl.addEventListener('mouseleave', () => {
          htmlEl.style.transform = '';
        });
      });
    }

    // ── Custom cursor ──
    const cursorDot = document.getElementById('cursor-dot');
    const cursorCircle = document.getElementById('cursor-circle');
    let mouseX = -100;
    let mouseY = -100;

    if (window.matchMedia('(pointer: fine)').matches && cursorDot && cursorCircle) {
      let circleX = -100, circleY = -100;
      let dotX = -100, dotY = -100;
      let mouseOnPage = true;

      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
      });

      // Build trail dots
      const trailContainer = document.getElementById('cursor-trail');
      const TRAIL_COUNT = 5;
      const trailDots: HTMLElement[] = [];
      const trailPositions = Array.from({ length: TRAIL_COUNT }, () => ({ x: -100, y: -100 }));
      if (trailContainer) {
        for (let i = 0; i < TRAIL_COUNT; i++) {
          const dot = document.createElement('div');
          dot.classList.add('cursor-trail-dot');
          dot.style.width = `${4 - i * 0.4}px`;
          dot.style.height = `${4 - i * 0.4}px`;
          trailContainer.appendChild(dot);
          trailDots.push(dot);
        }
      }

      // Single unified animation loop for dot + circle + trail
      function animateCursor() {
        dotX += (mouseX - dotX) * 0.85;
        dotY += (mouseY - dotY) * 0.85;
        cursorDot.style.transform = `translate(${dotX}px, ${dotY}px)`;

        circleX += (mouseX - circleX) * 0.12;
        circleY += (mouseY - circleY) * 0.12;
        const isHover = cursorCircle.classList.contains('hover');
        cursorCircle.style.transform = isHover
          ? `translate(${circleX}px, ${circleY}px) scale(1.5)`
          : `translate(${circleX}px, ${circleY}px)`;

        if (trailDots.length && mouseOnPage) {
          // Velocity-based trail visibility — faster = more visible
          const dx = mouseX - dotX;
          const dy = mouseY - dotY;
          const velocity = Math.sqrt(dx * dx + dy * dy);
          const trailIntensity = Math.min(1, velocity / 30);

          trailPositions[0].x += (mouseX - trailPositions[0].x) * 0.3;
          trailPositions[0].y += (mouseY - trailPositions[0].y) * 0.3;
          for (let i = 1; i < TRAIL_COUNT; i++) {
            trailPositions[i].x += (trailPositions[i - 1].x - trailPositions[i].x) * 0.25;
            trailPositions[i].y += (trailPositions[i - 1].y - trailPositions[i].y) * 0.25;
          }
          trailDots.forEach((dot, i) => {
            dot.style.transform = `translate(${trailPositions[i].x - 2}px, ${trailPositions[i].y - 2}px)`;
            dot.style.opacity = `${(0.3 - i * 0.035) * trailIntensity}`;
          });
        }

        requestAnimationFrame(animateCursor);
      }
      animateCursor();

      document.querySelectorAll('a, button, [data-cursor-hover]').forEach((el) => {
        el.addEventListener('mouseenter', () => cursorCircle.classList.add('hover'));
        el.addEventListener('mouseleave', () => cursorCircle.classList.remove('hover'));
      });

      document.addEventListener('mouseleave', () => {
        mouseOnPage = false;
        cursorDot.style.opacity = '0';
        cursorCircle.style.opacity = '0';
        trailDots.forEach((dot) => { dot.style.opacity = '0'; });
      });
      document.addEventListener('mouseenter', () => {
        mouseOnPage = true;
        cursorDot.style.opacity = '1';
        cursorCircle.style.opacity = '0.4';
      });

      // Nav rail nodes magnetic pull toward cursor Y
      const navRailNodes = document.querySelector('.nav-rail-nodes');
      if (navRailNodes) {
        let navPullRaf = 0;
        document.addEventListener('mousemove', (e) => {
          if (Math.abs(scrollVelocity) > 0.5) return;
          const mY = e.clientY;
          if (navPullRaf) return;
          navPullRaf = requestAnimationFrame(() => {
            const rect = navRailNodes.getBoundingClientRect();
            const centerY = rect.top + rect.height / 2;
            const pull = (mY - centerY) * 0.03;
            const clamped = Math.max(-10, Math.min(10, pull));
            (navRailNodes as HTMLElement).style.transform = `translateY(${clamped}px)`;
            navPullRaf = 0;
          });
        }, { passive: true });
      }
    }

    // ── Smooth image scroll on project card hover ──
    if (window.matchMedia('(pointer: fine)').matches) {
      document.querySelectorAll('.project-card-v').forEach((card) => {
        const img = card.querySelector('.project-image-inner') as HTMLImageElement;
        const container = card.querySelector('.project-image') as HTMLElement;
        if (!img || !container) return;

        let scrollPos = 0;
        let scrollRaf: number | null = null;
        let hovering = false;
        let currentStop = 0;
        const stops = [0, 0.25, 0.5, 0.75, 1];
        const pauseDuration = 90; // ~1.5s pause at each stop
        const initialDelay = 90; // ~1.5s delay before first move
        let pauseCounter = 0;
        let isPaused = false;
        let delayCounter = 0;
        let isDelaying = false;
        let cachedMaxScroll = 0;

        function ensureImageLoaded(cb: () => void) {
          if (img.naturalHeight > 0) { cb(); return; }
          img.addEventListener('load', cb, { once: true });
        }

        function cacheMaxScroll() {
          cachedMaxScroll = img.offsetHeight - container.offsetHeight;
        }

        function animateScroll() {
          if (cachedMaxScroll <= 0) { scrollRaf = null; return; }


          if (hovering) {
            // Initial delay before starting to scroll
            if (isDelaying) {
              delayCounter++;
              if (delayCounter >= initialDelay) {
                isDelaying = false;
              }
              img.style.transform = `translateY(${-scrollPos}px)`;
              scrollRaf = requestAnimationFrame(animateScroll);
              return;
            }

            const stopTarget = stops[currentStop] * cachedMaxScroll;

            if (isPaused) {
              pauseCounter++;
              if (pauseCounter >= pauseDuration) {
                isPaused = false;
                pauseCounter = 0;
                if (currentStop < stops.length - 1) currentStop++;
              }
            } else {
              scrollPos += (stopTarget - scrollPos) * 0.04;

              if (Math.abs(scrollPos - stopTarget) < 1) {
                scrollPos = stopTarget;
                if (currentStop < stops.length - 1) {
                  isPaused = true;
                  pauseCounter = 0;
                }
              }
            }
          } else {
            scrollPos += (0 - scrollPos) * 0.05;
            if (Math.abs(scrollPos) < 0.5) {
              scrollPos = 0;
              img.style.transform = '';
              currentStop = 0;
              isPaused = false;
              pauseCounter = 0;
              scrollRaf = null;
              return;
            }
          }

          img.style.transform = `translateY(${-scrollPos}px)`;

          scrollRaf = requestAnimationFrame(animateScroll);
        }

        card.addEventListener('mouseenter', () => {
          hovering = true;
          currentStop = 1;
          isPaused = false;
          pauseCounter = 0;
          isDelaying = true;
          delayCounter = 0;
          ensureImageLoaded(() => {
            cacheMaxScroll(); // read offsetHeight once, not every frame
            if (!scrollRaf) scrollRaf = requestAnimationFrame(animateScroll);
          });
        });

        card.addEventListener('mouseleave', () => {
          hovering = false;
          currentStop = 0;
          if (!scrollRaf) scrollRaf = requestAnimationFrame(animateScroll);
        });
      });
    }

    // ── Mobile: scroll-triggered card effects (replaces hover) ──
    if (!window.matchMedia('(pointer: fine)').matches) {
      // Scroll-triggered image auto-scroll on mobile
      document.querySelectorAll('.project-card-v').forEach((card) => {
        const img = card.querySelector('.project-image-inner') as HTMLImageElement;
        const container = card.querySelector('.project-image') as HTMLElement;
        if (!img || !container) return;

        let scrollPos = 0;
        let scrollRaf: number | null = null;
        let active = false;
        let currentStop = 0;
        const stops = [0, 0.25, 0.5, 0.75, 1];
        const pauseDuration = 100;
        const initialDelay = 60;
        let pauseCounter = 0;
        let isPaused = false;
        let delayCounter = 0;
        let isDelaying = false;
        let cachedMaxScroll = 0;

        function cacheMaxScroll() {
          cachedMaxScroll = img.offsetHeight - container.offsetHeight;
        }

        function animateScroll() {
          if (cachedMaxScroll <= 0) { scrollRaf = null; return; }

          if (active) {
            if (isDelaying) {
              delayCounter++;
              if (delayCounter >= initialDelay) isDelaying = false;
              img.style.transform = `translateY(${-scrollPos}px)`;
              scrollRaf = requestAnimationFrame(animateScroll);
              return;
            }
            const stopTarget = stops[currentStop] * cachedMaxScroll;
            if (isPaused) {
              pauseCounter++;
              if (pauseCounter >= pauseDuration) {
                isPaused = false;
                pauseCounter = 0;
                if (currentStop < stops.length - 1) currentStop++;
              }
            } else {
              scrollPos += (stopTarget - scrollPos) * 0.04;
              if (Math.abs(scrollPos - stopTarget) < 1) {
                scrollPos = stopTarget;
                if (currentStop < stops.length - 1) {
                  isPaused = true;
                  pauseCounter = 0;
                }
              }
            }
          } else {
            scrollPos += (0 - scrollPos) * 0.05;
            if (Math.abs(scrollPos) < 0.5) {
              scrollPos = 0;
              img.style.transform = '';
              currentStop = 0;
              isPaused = false;
              pauseCounter = 0;
              scrollRaf = null;
              return;
            }
          }
          img.style.transform = `translateY(${-scrollPos}px)`;
          scrollRaf = requestAnimationFrame(animateScroll);
        }

        // Activate when card is centered in viewport
        const mobileCardObs = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !active) {
              active = true;
              (card as HTMLElement).classList.add('scroll-active');
              currentStop = 1;
              isPaused = false;
              pauseCounter = 0;
              isDelaying = true;
              delayCounter = 0;
              if (img.naturalHeight > 0) {
                cacheMaxScroll();
                if (!scrollRaf) scrollRaf = requestAnimationFrame(animateScroll);
              } else {
                img.addEventListener('load', () => {
                  cacheMaxScroll();
                  if (!scrollRaf) scrollRaf = requestAnimationFrame(animateScroll);
                }, { once: true });
              }
            } else if (!entry.isIntersecting && active) {
              active = false;
              (card as HTMLElement).classList.remove('scroll-active');
              currentStop = 0;
              if (!scrollRaf) scrollRaf = requestAnimationFrame(animateScroll);
            }
          });
        }, { threshold: 0.5 });
        mobileCardObs.observe(card);
      });
    }

    // ── Floating UI parallax on project cards ──
    if (window.matchMedia('(pointer: fine)').matches) {
      document.querySelectorAll('[data-parallax-container]').forEach((container) => {
        const floats = container.querySelectorAll('[data-float-depth]');
        if (!floats.length) return;

        let targetX = 0, targetY = 0;
        const currentPositions = Array.from(floats, () => ({ x: 0, y: 0 }));
        let isHovering = false;
        let rafId: number | null = null;

        function animateFloats() {
          floats.forEach((el, i) => {
            const depth = parseFloat((el as HTMLElement).dataset.floatDepth || '0.04');
            const goalX = isHovering ? targetX * depth * 600 : 0;
            const goalY = isHovering ? targetY * depth * 600 : 0;
            currentPositions[i].x += (goalX - currentPositions[i].x) * 0.08;
            currentPositions[i].y += (goalY - currentPositions[i].y) * 0.08;
            (el as HTMLElement).style.transform = `translate(${currentPositions[i].x}px, ${currentPositions[i].y}px)`;
          });

          if (!isHovering) {
            const settled = currentPositions.every(p => Math.abs(p.x) < 0.1 && Math.abs(p.y) < 0.1);
            if (settled) {
              floats.forEach((el) => { (el as HTMLElement).style.transform = 'translate(0px, 0px)'; });
              rafId = null;
              return;
            }
          }
          rafId = requestAnimationFrame(animateFloats);
        }

        container.addEventListener('mouseenter', () => {
          isHovering = true;
          if (!rafId) rafId = requestAnimationFrame(animateFloats);
        });

        container.addEventListener('mousemove', (e: Event) => {
          if (Math.abs(scrollVelocity) > 0.5) return; // skip layout reads while scrolling
          const me = e as MouseEvent;
          const rect = (container as HTMLElement).getBoundingClientRect();
          targetX = (me.clientX - rect.left - rect.width / 2) / rect.width;
          targetY = (me.clientY - rect.top - rect.height / 2) / rect.height;
        });

        container.addEventListener('mouseleave', () => {
          isHovering = false;
          targetX = 0;
          targetY = 0;
          if (!rafId) rafId = requestAnimationFrame(animateFloats);
        });
      });
    }

    // ── 3D tilt on project cards (state only — animation runs in main rAF) ──
    if (window.matchMedia('(pointer: fine)').matches) {
      document.querySelectorAll('[data-tilt]').forEach((card) => {
        const el = card as HTMLElement;
        const f = floatItems.find(item => item.el === el);
        if (!f) return;

        el.addEventListener('mouseenter', () => { f.tiltHovering = true; }, { passive: true });
        el.addEventListener('mousemove', (e: MouseEvent) => {
          if (Math.abs(scrollVelocity) > 0.5) return;
          const rect = el.getBoundingClientRect();
          const cx = rect.width / 2, cy = rect.height / 2;
          f.tiltTargetX = ((e.clientY - rect.top - cy) / cy) * -3;
          f.tiltTargetY = ((e.clientX - rect.left - cx) / cx) * 3;
        }, { passive: true });
        el.addEventListener('mouseleave', () => {
          f.tiltHovering = false;
          f.tiltTargetX = 0;
          f.tiltTargetY = 0;
        }, { passive: true });
      });
    }

    // ── Magnetic effect ──
    if (window.matchMedia('(pointer: fine)').matches) {
      document.querySelectorAll('[data-magnetic]').forEach((el) => {
        const element = el as HTMLElement;
        element.addEventListener('mousemove', (e: MouseEvent) => {
          const rect = element.getBoundingClientRect();
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;
          element.style.transform = `translate(${x * 0.25}px, ${y * 0.25}px)`;
        }, { passive: true });
        element.addEventListener('mouseleave', () => { element.style.transform = ''; }, { passive: true });
      });
    }

    // ── Text scramble on project name — on scroll + hover ──
    if (window.matchMedia('(pointer: fine)').matches) {
      document.querySelectorAll('[data-scramble]').forEach((el) => {
        const element = el as HTMLElement;
        const originalText = element.textContent?.trim() || '';
        let intervalId: number | null = null;

        function runScramble() {
          if (intervalId) clearInterval(intervalId);
          const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ&0123456789';
          let step = 0;
          const totalSteps = 14;
          intervalId = window.setInterval(() => {
            step++;
            let result = '';
            for (let i = 0; i < originalText.length; i++) {
              if (originalText[i] === ' ' || originalText[i] === '&') result += originalText[i];
              else if (step / totalSteps > i / originalText.length) result += originalText[i];
              else result += chars[Math.floor(Math.random() * chars.length)];
            }
            element.textContent = result;
            if (step >= totalSteps) {
              clearInterval(intervalId!);
              intervalId = null;
              element.textContent = originalText;
            }
          }, 40);
        }

        // Scramble on scroll reveal
        const scrambleObs = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              runScramble();
              scrambleObs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.5 });
        scrambleObs.observe(element);

        // Also on hover
        element.addEventListener('mouseenter', runScramble);
        element.addEventListener('mouseleave', () => {
          if (intervalId) { clearInterval(intervalId); intervalId = null; }
          element.textContent = originalText;
        });
      });
    }

    // ── Contact section — velocity-reactive marquee ──
    const marqueeSection = document.querySelector('[data-contact-marquee]');
    const leftTrack = document.querySelector('[data-marquee-track="left"]') as HTMLElement;
    const rightTrack = document.querySelector('[data-marquee-track="right"]') as HTMLElement;

    if (leftTrack && rightTrack) {
      let leftPos = 0;
      let rightPos = 0;
      const baseSpeed = 0.8;
      let marqueeActive = false;
      let lenisVelocity = 0;

      // Track scroll velocity for marquee speed
      let lastMarqueeScroll = window.scrollY;
      window.addEventListener('scroll', () => {
        const now = window.scrollY;
        lenisVelocity = (now - lastMarqueeScroll) * 0.5;
        lastMarqueeScroll = now;
      }, { passive: true });

      // Get the width of one full repeat unit (half the track since we duplicated content)
      function getResetWidth(track: HTMLElement) {
        return track.scrollWidth / 2;
      }

      function animateMarquee() {
        if (!marqueeActive) return;

        const speedMultiplier = 1 + Math.abs(lenisVelocity) * 0.15;
        const speed = baseSpeed * speedMultiplier;

        const leftReset = getResetWidth(leftTrack);
        const rightReset = getResetWidth(rightTrack);

        // Left track moves left, right track moves right
        leftPos -= speed;
        rightPos += speed;

        if (Math.abs(leftPos) >= leftReset) leftPos = 0;
        if (rightPos >= rightReset) rightPos = 0;

        leftTrack.style.transform = `translateX(${leftPos}px)`;
        rightTrack.style.transform = `translateX(${rightPos - rightReset}px)`;

        requestAnimationFrame(animateMarquee);
      }

      // Start marquee when section enters viewport
      const marqueeObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            if (!marqueeActive) {
              marqueeActive = true;
              requestAnimationFrame(animateMarquee);
            }
            marqueeSection?.classList.add('revealed');
          } else {
            marqueeActive = false;
          }
        });
      }, { threshold: 0.1 });
      if (marqueeSection) marqueeObs.observe(marqueeSection);
    }

    // Contact split reveal — composites with float system via shared FloatItem state
    const contactDivider = document.querySelector('[data-contact-divider]') as HTMLElement | null;
    const contactLeft = document.querySelector('[data-contact-left]') as HTMLElement | null;
    const contactRight = document.querySelector('[data-contact-right]') as HTMLElement | null;
    const contactFields = Array.from(document.querySelectorAll('[data-contact-field]')) as HTMLElement[];
    const contactSend = document.querySelector('.contact-send') as HTMLElement | null;

    // Find the FloatItems for contact panels so reveal can compose with float
    const contactLeftFloat = floatItems.find(f => f.el === contactLeft);
    const contactRightFloat = floatItems.find(f => f.el === contactRight);

    // Initialize contact panels as hidden (reveal will animate them in)
    if (contactLeftFloat) { contactLeftFloat.revealOpacity = 0; contactLeftFloat.revealX = -12; contactLeftFloat.revealY = 20; }
    if (contactRightFloat) { contactRightFloat.revealOpacity = 0; contactRightFloat.revealX = 12; contactRightFloat.revealY = 20; }

    function contactSmooth(t: number, delay: number, dur = 1800) {
      const r = Math.min(1, Math.max(0, (t - delay) / dur));
      return r * r * (3 - 2 * r);
    }

    if (contactDivider) {
      let contactRevealStart = 0;
      let contactRevealing = false;

      // Remove CSS transitions on non-float elements — JS drives everything
      [contactSend, ...contactFields].forEach(el => {
        if (el) el.style.transition = 'none';
      });

      function contactRevealLoop(now: number) {
        if (!contactRevealing) return;
        const t = now - contactRevealStart;

        // Divider line draws over 1.5s
        if (contactDivider) {
          const e = contactSmooth(t, 0, 1500);
          (contactDivider as HTMLElement).style.width = `${e * 100}%`;
        }

        // Left panel — update FloatItem reveal state (float loop composes the transform)
        if (contactLeftFloat) {
          const e = contactSmooth(t, 400, 1800);
          contactLeftFloat.revealOpacity = e;
          contactLeftFloat.revealX = (1 - e) * -12;
          contactLeftFloat.revealY = (1 - e) * 20;
        }

        // Right panel — update FloatItem reveal state
        if (contactRightFloat) {
          const e = contactSmooth(t, 700, 1800);
          contactRightFloat.revealOpacity = e;
          contactRightFloat.revealX = (1 - e) * 12;
          contactRightFloat.revealY = (1 - e) * 20;
        }

        // Form fields — staggered fade up (no float conflict, direct write OK)
        contactFields.forEach((field, i) => {
          const e = contactSmooth(t, 1000 + i * 250, 1500);
          field.style.opacity = `${e}`;
          field.style.transform = `translateY(${(1 - e) * 14}px)`;
        });

        // Send button — last to appear
        if (contactSend) {
          const e = contactSmooth(t, 1000 + contactFields.length * 250 + 150, 1500);
          contactSend.style.opacity = `${e}`;
          contactSend.style.transform = `translateY(${(1 - e) * 14}px)`;
        }

        // Keep running until everything is fully revealed
        const totalDuration = 1000 + contactFields.length * 250 + 150 + 1500;
        if (t < totalDuration + 100) {
          requestAnimationFrame(contactRevealLoop);
        }
      }

      const splitObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !contactRevealing) {
            contactRevealing = true;
            contactRevealStart = performance.now();
            requestAnimationFrame(contactRevealLoop);
            splitObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.25 });
      splitObs.observe(contactDivider);
    }

    // ── Contact form submit ──
    const formEl = document.getElementById('contact-form') as HTMLFormElement;
    const formSuccess = document.getElementById('form-success');
    const formError = document.getElementById('form-error');

    formEl?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(formEl);
      try {
        const response = await fetch(formEl.action, {
          method: 'POST',
          body: formData,
          headers: { Accept: 'application/json' },
        });
        if (response.ok) {
          formEl.style.display = 'none';
          formSuccess?.classList.remove('hidden');
        } else {
          formError?.classList.remove('hidden');
        }
      } catch {
        formError?.classList.remove('hidden');
      }
    });

    // ── About section scroll animations ──

    // About blocks — fade up on scroll
    document.querySelectorAll('[data-about-block]').forEach((el) => {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            obs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2 });
      obs.observe(el);
    });

    // Rolling digit counters — odometer effect on scroll
    // Stat counters — count up on scroll
    document.querySelectorAll('[data-stat]').forEach((el) => {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            const target = parseInt((entry.target as HTMLElement).dataset.statTarget || '0');
            const suffix = (entry.target as HTMLElement).dataset.statSuffix || '';
            const numEl = entry.target.querySelector('[data-stat-number]') as HTMLElement;
            if (numEl) {
              let current = 0;
              const duration = 1200;
              const start = performance.now();
              function countUp(now: number) {
                const elapsed = now - start;
                const progress = Math.min(elapsed / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                current = Math.round(eased * target);
                numEl.textContent = `${current}${suffix}`;
                if (progress < 1) requestAnimationFrame(countUp);
              }
              requestAnimationFrame(countUp);
            }
            obs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });
      obs.observe(el);
    });

    // Approach items — staggered slide-in
    document.querySelectorAll('[data-approach]').forEach((el, i) => {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            setTimeout(() => entry.target.classList.add('revealed'), i * 120);
            obs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2 });
      obs.observe(el);
    });

    // Skill pills — staggered pop-in
    const pillContainer = document.querySelector('[data-skill-pills]');
    if (pillContainer) {
      const pillObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const pills = entry.target.querySelectorAll('.skill-pill');
            pills.forEach((pill, i) => {
              setTimeout(() => pill.classList.add('revealed'), i * 50);
            });
            pillObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2 });
      pillObs.observe(pillContainer);
    }

    // ── Dark mode toggle ──
    // ── Theme switcher (3-way: light / system / dark) ──
    function getEffectiveTheme(mode: string): string {
      if (mode === 'system') {
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      return mode;
    }

    function applyTheme(mode: string, button?: HTMLElement) {
      const effectiveTheme = getEffectiveTheme(mode);
      const overlay = document.getElementById('theme-transition');

      if (button && overlay) {
        const rect = button.getBoundingClientRect();
        const x = rect.left + rect.width / 2;
        const y = rect.top + rect.height / 2;
        const maxRadius = Math.ceil(Math.sqrt(
          Math.max(x, window.innerWidth - x) ** 2 +
          Math.max(y, window.innerHeight - y) ** 2
        ));
        const newBg = effectiveTheme === 'dark' ? '#0c0c0c' : '#FAFAFA';
        overlay.style.backgroundColor = newBg;
        overlay.style.transition = 'none';
        overlay.style.clipPath = `circle(0px at ${x}px ${y}px)`;
        overlay.offsetHeight;
        const duration = 900;
        const startTime = performance.now();
        function animateBlob(now: number) {
          const elapsed = now - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const eased = progress < 0.5 ? 4 * progress ** 3 : 1 - Math.pow(-2 * progress + 2, 3) / 2;
          const radius = eased * maxRadius;
          const w1 = Math.sin(progress * Math.PI * 3) * radius * 0.08;
          const w2 = Math.cos(progress * Math.PI * 2) * radius * 0.06;
          overlay.style.clipPath = `ellipse(${radius + w1}px ${radius + w2}px at ${x}px ${y}px)`;
          if (progress < 1) requestAnimationFrame(animateBlob);
          else overlay.style.clipPath = 'circle(0px at 50% 50%)';
        }
        requestAnimationFrame(animateBlob);
        setTimeout(() => {
          document.documentElement.dataset.theme = effectiveTheme;
          updateThemeMeta(effectiveTheme);
        }, duration * 0.4);
      } else {
        document.documentElement.dataset.theme = effectiveTheme;
        updateThemeMeta(effectiveTheme);
      }

      // Persist preference
      if (mode === 'system') {
        localStorage.removeItem('theme');
      } else {
        localStorage.setItem('theme', mode);
      }

      // Update active states on all option buttons
      document.querySelectorAll('.theme-option, .theme-option-mobile').forEach((btn) => {
        btn.classList.toggle('active', (btn as HTMLElement).dataset.themeValue === mode);
      });
    }

    function updateThemeMeta(effectiveTheme: string) {
      const meta = document.querySelector('meta[name="theme-color"]');
      if (meta) meta.setAttribute('content', effectiveTheme === 'dark' ? '#0c0c0c' : '#FAFAFA');
    }

    // Listen for system theme changes (applies only when mode is 'system')
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
      if (localStorage.getItem('theme')) return; // user chose light or dark explicitly
      const effectiveTheme = e.matches ? 'dark' : 'light';
      document.documentElement.dataset.theme = effectiveTheme;
      updateThemeMeta(effectiveTheme);
    });

    // Determine initial mode from localStorage
    const storedTheme = localStorage.getItem('theme');
    const initialMode = storedTheme || 'system';
    // Apply effective theme on load (no animation) to ensure system mode works
    const effectiveOnLoad = getEffectiveTheme(initialMode);
    document.documentElement.dataset.theme = effectiveOnLoad;
    updateThemeMeta(effectiveOnLoad);
    // Set correct active button on load
    document.querySelectorAll('.theme-option, .theme-option-mobile').forEach((btn) => {
      btn.classList.toggle('active', (btn as HTMLElement).dataset.themeValue === initialMode);
    });

    // Bind click handlers for all theme option buttons
    document.querySelectorAll('.theme-option, .theme-option-mobile').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        const mode = target.dataset.themeValue || 'system';
        applyTheme(mode, target);
      });
    });

    // ── JS-driven pill expand/collapse with smoothstep easing ──
    const pillEl = document.querySelector('.theme-switcher-options') as HTMLElement | null;
    const labelEls = document.querySelectorAll('.theme-option-label') as NodeListOf<HTMLElement>;
    const themeSwitcherEl = document.getElementById('theme-switcher');
    const themePromptEl = document.getElementById('theme-prompt');

    if (pillEl && themeSwitcherEl) {
      const allOptions = pillEl.querySelectorAll('.theme-option') as NodeListOf<HTMLElement>;
      let pillAnim: number | null = null;
      let pillOpen = false;
      let introHolding = false;

      function smoothstep(t: number): number {
        return t * t * (3 - 2 * t);
      }

      function animatePill(open: boolean, duration = 550) {
        if (pillAnim) cancelAnimationFrame(pillAnim);
        const startTime = performance.now();
        // Snapshot current state of each non-active option
        const inactiveOpts: HTMLElement[] = [];
        allOptions.forEach(o => { if (!o.classList.contains('active')) inactiveOpts.push(o); });

        // Show inactive options and labels for animation (they start as display:none)
        if (open) {
          inactiveOpts.forEach(o => { o.style.display = 'flex'; });
          labelEls.forEach(l => { l.style.display = 'inline'; });
        }

        // Set overflow hidden during animation
        pillEl!.style.overflow = 'hidden';

        function tick(now: number) {
          const elapsed = now - startTime;
          const raw = Math.min(elapsed / duration, 1);
          const t = smoothstep(raw);
          const val = open ? t : 1 - t;

          // Animate non-active options height + opacity
          inactiveOpts.forEach(o => {
            o.style.height = (val * 26) + 'px';
            o.style.opacity = String(val);
          });

          // All options stretch to fill width when expanded
          allOptions.forEach(o => {
            o.style.width = val > 0.01 ? '100%' : '';
            o.style.justifyContent = val > 0.01 ? 'flex-start' : 'center';
            o.style.paddingLeft = (val * 8) + 'px';
          });

          // Container: circle (32×32) → pill (auto height, wider)
          const r = 50 - val * 32; // 50% → 18%
          pillEl!.style.borderRadius = r + '%';
          pillEl!.style.width = (32 + val * 50) + 'px'; // 32px → 82px
          pillEl!.style.height = 'auto';
          pillEl!.style.gap = (val * 2) + 'px';
          pillEl!.style.justifyContent = val < 0.01 ? 'center' : 'flex-start';
          pillEl!.style.boxShadow = `0 ${8 * val}px 28px rgba(0,0,0,${val * 0.2})`;

          // Labels
          const labelDelay = open ? 0.25 : 0;
          const labelRaw = open
            ? Math.max(0, (raw - labelDelay) / (1 - labelDelay))
            : Math.min(raw / 0.4, 1);
          const labelVal = open ? smoothstep(labelRaw) : 1 - smoothstep(labelRaw);
          labelEls.forEach(l => {
            l.style.opacity = String(labelVal);
            l.style.maxWidth = (labelVal * 50) + 'px';
          });

          if (raw < 1) {
            pillAnim = requestAnimationFrame(tick);
          } else {
            pillAnim = null;
            if (!open) {
              // Clean collapsed: perfect circle, hide inactive
              inactiveOpts.forEach(o => {
                o.style.height = '0';
                o.style.opacity = '0';
                o.style.display = 'none';
              });
              // Reset active option to centered circle state
              allOptions.forEach(o => {
                if (o.classList.contains('active')) {
                  o.style.width = '24px';
                  o.style.height = '24px';
                  o.style.justifyContent = 'center';
                  o.style.paddingLeft = '0';
                }
              });
              labelEls.forEach(l => { l.style.opacity = '0'; l.style.maxWidth = '0'; l.style.display = 'none'; });
              pillEl!.style.borderRadius = '50%';
              pillEl!.style.width = '32px';
              pillEl!.style.height = '32px';
              pillEl!.style.overflow = 'visible';
            } else {
              pillEl!.style.overflow = 'visible';
            }
          }
        }
        pillAnim = requestAnimationFrame(tick);
      }

      // Hover handlers
      themeSwitcherEl.addEventListener('mouseenter', () => {
        if (!pillOpen && !introHolding) {
          pillOpen = true;
          animatePill(true);
        }
      });
      themeSwitcherEl.addEventListener('mouseleave', () => {
        if (pillOpen && !introHolding) {
          pillOpen = false;
          animatePill(false, 650); // slower close
        }
      });

      // ── Intro animation — tooltip + pill expand ──
      if (themePromptEl && !sessionStorage.getItem('theme-prompt-shown')) {
        sessionStorage.setItem('theme-prompt-shown', '1');

        // Step 1: tooltip + curly arrow fade in (2.5s after load)
        setTimeout(() => {
          themePromptEl.classList.add('visible');
          themeSwitcherEl.classList.add('intro-glow');

          // Step 2: pill expands smoothly (1s later)
          setTimeout(() => {
            introHolding = true;
            pillOpen = true;
            animatePill(true, 800);

            // Step 3: hold for 3s, then collapse
            setTimeout(() => {
              pillOpen = false;
              animatePill(false, 900);

              // Step 4: dismiss tooltip after pill starts closing
              setTimeout(() => {
                themePromptEl.classList.remove('visible');
                themeSwitcherEl.classList.remove('intro-glow');
                introHolding = false;
              }, 500);
            }, 3000);
          }, 1000);
        }, 2500);
      }
    }

    // ── Live Sydney time + analog clock ──
    const clockHour = document.getElementById('clock-hour');
    const clockMinute = document.getElementById('clock-minute');
    const clockSecond = document.getElementById('clock-second');

    const footerEl = document.querySelector('footer');
    let clockIntervalId: ReturnType<typeof setInterval> | null = null;

    function updateSydneyTime() {
      const el = document.getElementById('sydney-time');
      const now = new Date();
      const sydneyStr = now.toLocaleString('en-AU', { timeZone: 'Australia/Sydney' });
      const sydneyDate = new Date(sydneyStr);
      const h = sydneyDate.getHours();
      const m = sydneyDate.getMinutes();
      const s = sydneyDate.getSeconds();
      if (el) el.textContent = `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
      const hourDeg = ((h % 12) / 12) * 360 + (m / 60) * 30;
      const minDeg = (m / 60) * 360 + (s / 60) * 6;
      const secDeg = (s / 60) * 360;
      if (clockHour) clockHour.style.transform = `translateX(-50%) rotate(${hourDeg}deg)`;
      if (clockMinute) clockMinute.style.transform = `translateX(-50%) rotate(${minDeg}deg)`;
      if (clockSecond) clockSecond.style.transform = `translateX(-50%) rotate(${secDeg}deg)`;
    }

    // Only tick clock when footer is visible
    if (footerEl) {
      const footerObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            updateSydneyTime();
            if (!clockIntervalId) clockIntervalId = setInterval(updateSydneyTime, 1000);
          } else {
            if (clockIntervalId) { clearInterval(clockIntervalId); clockIntervalId = null; }
          }
        });
      }, { threshold: 0 });
      footerObs.observe(footerEl);
    }
  </script>
</Layout>
